msgid "A little cactus."
msgstr "小さなサボテン。"

msgid "An empty flower vase."
msgstr "空の花瓶。"

msgid "Pink flowers in a vase."
msgstr "桃色の花が活けられた花瓶。"

msgid "I could use these flowers..."
msgstr "この花は使えるかも……"

msgid "Bring the flowers to the plant?"
msgstr "花を植物のところに持って行く？"

msgctxt "events.Ch1_MK_Bathroom.misc_flowers.choice.Bring the flowers to the plant?"
msgid "Yes"
msgstr "持って行く"

msgctxt "events.Ch1_MK_Bathroom.misc_flowers.choice.Bring the flowers to the plant?"
msgid "No"
msgstr "持って行かない"

msgid "\"Thank you.\""
msgstr "「ありがとう。」"

msgid "A shelf. Nothing of interest."
msgstr "棚。興味を惹くものはない。"

msgid "A bathtub filled with a black liquid."
msgstr "黒い液体で満たされたバスタブ。"

msgid "It's so big... you could fit like... four of me in there."
msgstr "すごく大きい……私なら……4人は入れそう。"

msgid "Check if there's anything useful inside?"
msgstr "中に役に立つものがないか確かめる？"

msgctxt "events.Ch1_MK_Bathroom.misc_tub.choice.Check if there's anything useful inside?"
msgid "Yes"
msgstr "確かめる"

msgctxt "events.Ch1_MK_Bathroom.misc_tub.choice.Check if there's anything useful inside?"
msgid "No"
msgstr "やめておく"

msgid "A beautiful night sky."
msgstr "美しい夜空。"

msgid "Three moons... ?"
msgstr "月が3つ……？"
