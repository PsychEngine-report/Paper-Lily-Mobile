msgid "Interacting"
msgstr "インタラクト"

msgctxt "tutorials.text.interaction_lacie"
msgid "Press {0} to interact with the environment"
msgstr "{0}で周囲の人や物に対して行動"

msgctxt "tutorials.name.itemuse"
msgid "Using Items"
msgstr "アイテムを使う"

msgid "To use an item, stand close and select the item from the menu ({0})"
msgstr "アイテムを使うには、使いたいものの近くでメニュー({0})からアイテムを選択"

msgctxt "tutorials.name.itemuse_lacie"
msgid "Using Items"
msgstr "アイテムを使う"

msgid "To use an item, stand close and select the item from the menu"
msgstr "アイテムを使うには、使いたいものの近くでメニューからアイテムを選択"

msgctxt "tutorials.name.menu"
msgid "Opening the Menu"
msgstr "メニューを開く"

msgctxt "tutorials.text.menu"
msgid "Press {0} to open the menu and see your items"
msgstr "{0}でメニューを開き、アイテムを確認できる"

