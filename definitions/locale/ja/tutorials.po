msgid "Opening the Menu"
msgstr "メニューを開く"

msgctxt "tutorials.text.menu_lacie"
msgid "Press {0} to open the menu and see your items"
msgstr "{0}でメニューを開き、アイテムを確認できる"

msgctxt "tutorials.name.movement"
msgid "Moving"
msgstr "移動"

msgctxt "tutorials.text.movement"
msgid "Use {0}{1}{2}{3} to move"
msgstr "{0}{1}{2}{3}で移動"

msgctxt "tutorials.name.movement_lacie"
msgid "Moving"
msgstr "移動"

msgctxt "tutorials.text.movement_lacie"
msgid "Use {0}{1}{2}{3} to move"
msgstr "{0}{1}{2}{3}で移動"

msgid "Picking Up Items"
msgstr "アイテムを拾う"

msgid "Press {0} to pick up items"
msgstr "{0}でアイテムを拾う"

msgctxt "tutorials.name.running"
msgid "Running"
msgstr "走る"

msgctxt "tutorials.text.running"
msgid "While moving, hold {0} to run"
msgstr "移動中に{0}を押すと走れる"

msgctxt "tutorials.name.running_lacie"
msgid "Running"
msgstr "走る"

msgctxt "tutorials.text.running_lacie"
msgid "While moving, hold {0} to run"
msgstr "移動中に{0}を押すと走れる"

msgctxt "tutorials.name.save"
msgid "Saving the Game"
msgstr "ゲームをセーブする"

msgctxt "tutorials.text.save"
msgid "Crows can save your game. Save often, since the future is uncertain"
msgstr "カラスでゲームをセーブできる。未来のことはわからないので、頻繁にセーブしよう"

msgctxt "tutorials.name.save_lacie"
msgid "Saving the Game"
msgstr "ゲームをセーブする"

msgctxt "tutorials.text.save_lacie"
msgid "Crows can save your game. Save often, since the future is uncertain"
msgstr "カラスでゲームをセーブできる。未来のことはわからないので、頻繁にセーブしよう"

msgid "Sneaking"
msgstr "スニーク"

msgid "Running will make you easier to spot. Hold {0} to sneak past enemies"
msgstr "走ると見つかりやすくなる。{0}を押しながら移動して、敵をやり過ごそう"

msgid "Climbing Stairs"
msgstr "階段を登る"

msgid "Hold {0} while moving to climb up the stairs"
msgstr "{0}を押しながら移動で階段を登る"

msgid "Timed Event"
msgstr "時間制限イベント"

msgid "Get to the bus before the time runs out!"
msgstr "時間切れになる前にバスに乗ろう！"

msgid "Minigame: Timing Bar"
msgstr "ミニゲーム: タイミングバー"

msgid "Press {0} when the indicator matches the green zone"
msgstr "インジケータが緑の領域に重なるタイミングで{0}を押そう"
