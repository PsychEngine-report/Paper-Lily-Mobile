msgid "It's not a good idea to go down there."
msgstr "降りるのは得策ではない。"

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend_2.choice"
msgid "Descend onto the train tracks?"
msgstr "線路に降りる？"

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend_2.choice.Descend onto the train tracks?"
msgid "Yes"
msgstr "降りる"

