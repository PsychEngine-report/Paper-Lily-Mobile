msgid "A broken, bloody baseball bat lies next to a skeleton."
msgstr "壊れた血だらけの野球バットが骸骨の横に転がっている。"

msgid "A \"W\" is carved into it."
msgstr "バットには「W」と彫ってある。"

msgid "The door is unreachable."
msgstr "このドアには届かない。"

msgid "\"Subject D5. Age: 100-150. Status: Dormant. Awaiting further tests.\""
msgstr "「被験体D5。年齢: 100-150。状態: 休眠中。追加のテスト待ち。」"

msgid "\"Subject D8. Age: Unknown. Status: Highly active. Awaiting further tests.\""
msgstr "「被験体D8。年齢: 不明。状態: 極めて活発。追加のテスト待ち。」"

msgctxt "events.Ch1_Facility_B2F_Dungeon_2.misc_cell_eyes.dlg.narrator"
msgid "A confinement door. It's locked."
msgstr "独房の扉。鍵がかかっている。"

msgid "There's something inside..."
msgstr "中に何かいる……"

msgctxt "events.Ch1_Facility_B2F_Dungeon_2.misc_cell_noeyes.dlg.narrator"
msgid "A confinement door. It's locked."
msgstr "独房の扉。鍵がかかっている。"

msgid "Nothing of interest on the desk."
msgstr "机の上に特に興味を惹くものはない。"

msgid "There's nothing else in the drawer."
msgstr "引き出しには他に何も入っていない。"

msgid "There's a valve handle in the drawer."
msgstr "引き出しにバルブのハンドルが入っている。"

msgid "Take ${item:ch1.facility_handle_diamond}?"
msgstr "${item:ch1.facility_handle_diamond} を取る？"

msgid "Yes"
msgstr "取る"

msgid "No"
msgstr "取らない"

msgid "A hole on the floor."
msgstr "床に開いた穴。"

msgid "(Sai joined your party.)"
msgstr "(サイがパーティに加わった。)"
