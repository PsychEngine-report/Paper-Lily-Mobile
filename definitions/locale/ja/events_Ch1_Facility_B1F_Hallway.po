msgid "There's something in there...!"
msgstr "中に何かいる……！"

msgid "Now is probably not a good time to go inside."
msgstr "今は中に入らない方が良さそうだ。"

msgid "Take ${item:ch1.bucket}?"
msgstr "${item:ch1.bucket} を取る？"

msgid "Yes"
msgstr "取る"

msgid "No"
msgstr "取らない"

msgid "Cool, a bucket."
msgstr "いいね、バケツか。"

msgid "You can do lots of things with that."
msgstr "色んなことに使えるな。"

msgid "Like...?"
msgstr "例えば……？"

msgid "Hmmm..."
msgstr "うーん……"

msgid "We could try removing all the water with it."
msgstr "向こうの水を全部抜くとか。"

msgctxt "events.Ch1_Facility_B1F_Hallway.misc_bucket.dlg.lacie"
msgid "..."
msgstr "……"

msgid "You could wear it as a hat...?"
msgstr "帽子代わりにかぶるとか……？"

msgid "A broken terrarium."
msgstr "壊れた飼育箱。"

msgid "This looks like the box I was carrying the caterpillar in..."
msgstr "私がイモムシを入れて持ってたやつみたい……"

msgid "Large windows."
msgstr "大きな窓。"

msgid "You can vaguely see some machinery inside."
msgstr "中にぼんやりと機械類が見える。"

msgid "You can see something lurking inside."
msgstr "中に何かが潜んでいるのがぼんやり見える。"

msgctxt "events.Ch1_Facility_B1F_Hallway.move_exit.dlg.narrator"
msgid "There's a door here, but it won't open."
msgstr "ドアがあるが、開かない。"

msgid "This is the door to the surface."
msgstr "これが地上へのドアだ。"

msgid "...Huh? It's locked?"
msgstr "……あれ？　鍵がかかってる？"

msgid "Are we trapped after all?"
msgstr "やっぱり閉じ込められたってこと？"

msgid "It can't be, I just came through here... Do we need a key?"
msgstr "おかしいな、ここから来たのに……鍵が要るのか？"

msgid "There's no keyhole."
msgstr "鍵穴はないよ。"

msgid "Huh... good eye."
msgstr "おぉ……目が良いな。"

msgid "We'll just have to do as Rune said and go deeper down."
msgstr "ルーンが言った通り、もっと深くに行くしかないみたい。"

msgctxt "events.Ch1_Facility_B1F_Hallway.move_exit_sai.dlg.narrator"
msgid "There's a door here, but it won't open."
msgstr "ドアがあるが、開かない。"

msgid "There's a crack in the wall."
msgstr "壁にヒビがある。"
