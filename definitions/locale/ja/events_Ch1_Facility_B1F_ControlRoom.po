msgid "Turn it?"
msgstr "回す？"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_2.choice.Turn it?"
msgid "Turn the wheel"
msgstr "ハンドルを回す"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_2.choice.Turn it?"
