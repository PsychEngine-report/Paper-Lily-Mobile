msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_3.dlg.narrator"
msgid "It won't turn anymore."
msgstr "これ以上回らない。"

msgid "A slot to place a valve wheel. The indentation has a diamond shape."
msgstr "ハンドルをはめる穴だ。ダイヤ形をしている。"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_4.choice"
msgid "Turn it?"
msgstr "回す？"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_4.choice.Turn it?"
