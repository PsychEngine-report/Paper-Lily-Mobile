msgstr "ハンドルは回らない。"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_2.dlg.narrator"
msgid "It won't turn anymore."
msgstr "これ以上回らない。"

msgid "A slot to place a valve wheel. The indentation has a star shape."
msgstr "ハンドルをはめる穴だ。星形をしている。"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_3.choice"
msgid "Turn it?"
msgstr "回す？"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_3.choice.Turn it?"
msgid "Turn the wheel"
msgstr "ハンドルを回す"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_3.choice.Turn it?"
