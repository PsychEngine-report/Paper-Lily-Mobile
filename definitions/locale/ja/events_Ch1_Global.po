msgid ""
"[color=green]Tomas_B, 11 months ago[/color]\n"
"[u][color=teal]@Kasaju_86[/color][/u] might have some ideas."
msgstr ""
"[color=green]Tomas_B, 11ヶ月前[/color]\n"
