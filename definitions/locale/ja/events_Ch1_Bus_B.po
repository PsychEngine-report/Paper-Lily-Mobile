msgid "A creature with a huge mouth."
msgstr "巨大な口の生物。"

msgid "hhhhaaaaaa....."
msgstr "っっっはあぁぁぁぁぁ……"

msgid "(It might be best to keep my distance...)"
msgstr "(近づかない方がよさそう……)"

msgid "A scary-looking monster."
msgstr "怖い見た目の怪物。"

msgid "It's looking at me..."
msgstr "こっちを見てる……"

msgid "A person holding what seems like a lamp with fish inside."
msgstr "魚の入ったランプらしきものを持っている人物。"

msgid "A hooded young man is lying down here."
msgstr "フードを被った青年が横になっている。"

msgid "Pardon me..."
msgstr "すみません……"

msgctxt "events.Ch1_Bus_B.chr_sai.dlg.unknown"
msgid "..."
msgstr "……"

msgid "I need some help."
msgstr "助けてくれませんか。"

msgctxt "events.Ch1_Bus_B.chr_sai.dlg.lacie"
msgid "..."
msgstr "……"

msgid "Yeah, I wouldn't talk to me either."
msgstr "うん、私でも返事はしないと思う。"

msgid "Sigh..."
msgstr "はぁ……"

msgid "An odd green man."
msgstr "奇妙な緑の男。"

msgctxt "events.Ch1_Bus_B.chr_sleepy.dlg.lacie"
msgid "..."
msgstr "……"

msgid "zzzzz"
msgstr "zzzzz"

msgid "Uh... excuse me?"
msgstr "その……すみません？"

msgid "zzzzzZZZZZ"
msgstr "zzzzzZZZZZ"

msgid "Looks like he's trying to sleep..."
msgstr "寝ようとしてるみたい……"

msgid "Some purple blobs with ...faces?"
msgstr "いくつかの紫色のかたまり……に、顔がある？"

msgid "If I push them together, will they disappear?"
msgstr "つなげたら消えるかな？"

msgid "The bus driver must be behind these curtains."
msgstr "バスの運転手はこのカーテンの向こうにいるはずだ。"

msgid "Take a look behind the curtains?"
msgstr "カーテンの奥を見る？"

msgctxt "events.Ch1_Bus_B.misc_curtain.choice.Take a look behind the curtains?"
msgid "Yes"
msgstr "見る"

msgctxt "events.Ch1_Bus_B.misc_curtain.choice.Take a look behind the curtains?"
msgid "No"
msgstr "見ない"

msgid "Some colorful goop is dripping from the ceiling."
msgstr "色鮮やかな粘液が屋根から滴っている。"

msgid "An empty seat."
msgstr "誰も座っていない座席。"

msgid "My seat. I didn't forget anything."
msgstr "私の座席。何も忘れてない。"

msgid "Should I sit back down?"
msgstr "座り直す？"

msgctxt "events.Ch1_Bus_B.misc_seat_3.choice.Should I sit back down?"
msgid "Yes"
msgstr "座り直す"

msgctxt "events.Ch1_Bus_B.misc_seat_3.choice.Should I sit back down?"
msgid "No"
msgstr "座り直さない"

msgid "A list of rules for the bus."
msgstr "バスの規則の一覧。"

msgctxt "events.Ch1_Bus_B.misc_sign.dlg.lacie"
msgid "\"No eating on the bus.\""
msgstr "「車内での飲食禁止」"

msgid "Seems pretty reasonable."
msgstr "理に適ってる。"

msgctxt "events.Ch1_Bus_B.misc_sign.dlg.narrator"
msgid "\"No eating on the bus.\""
msgstr "「車内での飲食禁止」"

msgid "The ticketing machine."
msgstr "発券機。"

msgid "You can see the bus stop and some trees out the window."
msgstr "窓の外にはバス停と木々が見える。"

msgid "...She actually got off?"
msgstr "……マジで降りたのか？"

msgid "...Huh."
msgstr "……はん。"
