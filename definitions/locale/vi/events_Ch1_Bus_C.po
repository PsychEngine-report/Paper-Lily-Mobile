msgid "There's curtains where the driver should be."
msgstr "Cái rèm mà tài xế chắc là ở đằng sau."

msgid "Take a look behind the curtains?"
msgstr "Nhòm đằng sau rèm chứ?"

msgid "Yes"
msgstr "Nhòm"

msgid "No"
msgstr "Thôi"

msgid "There's no one there, just an empty driver's seat."
msgstr "Không có ai hết, chỉ là ghế ngồi tài xế trống không."

msgid "There's nobody behind the curtains."
msgstr "Đằng sau rèm không có ai hết."

msgid "My seat."
msgstr "Ghế ngồi của mình."

msgid "It's too dark to see out the window."
msgstr "Tối quá nhìn ra cửa sổ không thấy được."

msgid "Uhm... where am I?"
msgstr "Ừm... mình ở đâu đây?"
