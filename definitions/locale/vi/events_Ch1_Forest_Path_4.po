msgctxt "events.Ch1_Forest_Path_4.misc_tree.dlg.narrator"
msgid "A red tree."
msgstr "Cái cây màu đỏ."

msgid "It stands out..."
msgstr "Nổi bật nhỉ..."

msgid "Is there anything special about it?"
msgstr "Nó có gì đặc biệt không?"

msgctxt "events.Ch1_Forest_Path_4.misc_tree_behind.dlg.narrator"
msgid "A red tree."
msgstr "Cái cây màu đỏ."

msgid "Hmm? There's a paper with something stuck to it."
msgstr "Hừm? Có tờ giấy với cái gì đó dính vào nè."

msgid "Take ${item:ch1.forest_lockedsite_key}?"
msgstr "Lấy ${item:ch1.forest_lockedsite_key} chứ?"

msgid "Yes"
msgstr "Lấy"

msgid "No"
msgstr "Thôi"

msgid "(You don't need that key, so it was discarded.)"
msgstr "(Bạn không cần chiếc chìa đó, nên đã bỏ nó đi.)"

msgid "There's also a note taped to the tree."
msgstr "Còn có tờ ghi được dán băng dính vào cái cây."
