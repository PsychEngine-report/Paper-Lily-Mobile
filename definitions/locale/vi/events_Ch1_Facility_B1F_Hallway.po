msgid "There's something in there...!"
msgstr "Bên trong có cái gì ấy...!"

msgid "Now is probably not a good time to go inside."
msgstr "Giờ chắc không phải lúc hay ho mà vào trong đâu."

msgid "Take ${item:ch1.bucket}?"
msgstr "Lấy ${item:ch1.bucket} chứ?"

msgid "Yes"
msgstr "Lấy"

msgid "No"
msgstr "Thôi"

msgid "Cool, a bucket."
msgstr "Ngon, cái xô này."

msgid "You can do lots of things with that."
msgstr "Dùng xô làm được nhiều chuyện lắm."

msgid "Like...?"
msgstr "Như là...?"

msgid "Hmmm..."
msgstr "Hừmmm..."

msgid "We could try removing all the water with it."
msgstr "Có thể thử dùng xô múc hết nước chẳng hạn."

msgctxt "events.Ch1_Facility_B1F_Hallway.misc_bucket.dlg.lacie"
msgid "..."
msgstr "..."

msgid "You could wear it as a hat...?"
msgstr "Có thể đội lên đầu như đội mũ chẳng hạn...?"

msgid "A broken terrarium."
msgstr "Cái bể địa sinh bị vỡ."

msgid "This looks like the box I was carrying the caterpillar in..."
msgstr "Cái này trông như cái hộp mà lúc trước mình mang chú sâu đấy ở trong..."

msgid "Large windows."
msgstr "Mấy chiếc cửa sổ lớn."

msgid "You can vaguely see some machinery inside."
msgstr "Bạn mơ hồ nhìn được vài máy móc bên trong."

msgid "You can see something lurking inside."
msgstr "Bạn thấy được bên trong có cái gì đó đang lẩn."

msgctxt "events.Ch1_Facility_B1F_Hallway.move_exit.dlg.narrator"
msgid "There's a door here, but it won't open."
msgstr "Ở đây có cánh cửa, nhưng nó không chịu mở."

msgid "This is the door to the surface."
msgstr "Đây là cái cửa lên mặt đất."

msgid "...Huh? It's locked?"
msgstr "...Hở? Bị khóa rồi?"

msgid "Are we trapped after all?"
msgstr "Rốt cuộc ta kẹt rồi á?"

msgid "It can't be, I just came through here... Do we need a key?"
msgstr "Kì ta, tôi vừa đi qua đây xuống mà... Cần chìa khóa hay sao?"

msgid "There's no keyhole."
msgstr "Đâu có lỗ khóa đâu."

msgid "Huh... good eye."
msgstr "Hử... mắt tinh đấy."

msgid "We'll just have to do as Rune said and go deeper down."
msgstr "Mình phải làm theo đúng như Rune nói là đi xuống sâu hơn mà thôi."

msgctxt "events.Ch1_Facility_B1F_Hallway.move_exit_sai.dlg.narrator"
msgid "There's a door here, but it won't open."
msgstr "Ở đây có cánh cửa, nhưng nó không mở được."

msgid "There's a crack in the wall."
msgstr "Trên bức tường có cái vết nứt."
