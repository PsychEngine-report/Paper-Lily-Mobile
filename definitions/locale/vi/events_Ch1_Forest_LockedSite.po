msgid "There's a gate nearby!"
msgstr "Có cái cổng gần kia rồi mà!"

msgid "There's quite a bit of blood in this spot."
msgstr "Ở chỗ này có hơi bị nhiều máu."

msgid "Someone's remains. You can't tell whether they're human or not."
msgstr "Di thể của ai đó. Bạn không biết nổi được liệu đây có phải con người hay không."

msgctxt "events.Ch1_Forest_LockedSite.misc_fence_1.dlg.lacie"
msgid "I'd rather not go back in there."
msgstr "Không quay lại đấy thì hơn."

msgctxt "events.Ch1_Forest_LockedSite.misc_fence_1.dlg.lacie"
msgid "The grass is definitely greener on this side."
msgstr "Cỏ đằng này xanh hơn là cái chắc."

msgctxt "events.Ch1_Forest_LockedSite.misc_fence_1.dlg.narrator"
msgid "A fence blocks your path."
msgstr "Cái hàng rào chặn đường bạn."

