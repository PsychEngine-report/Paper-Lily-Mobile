msgid "Didn't catch your name earlier."
msgstr "Nãy chưa hỏi tên em."

msgctxt "events.Ch1_Facility_B2F_Lab.chr_sai.dlg.lacie"
msgid "..."
msgstr "..."

msgid "Yeah... I see."
msgstr "Ờ... hiểu rồi."

msgid "What's up?"
msgstr "Gì đấy?"

msgid "What... what was that thing?"
msgstr "Cái thứ đó nó... là gì vậy?"

msgid "Huh, you can talk."
msgstr "Hử, em nói chuyện được này."

msgid "I dunno. They call it a primal demon."
msgstr "Chịu. Nghe bảo nó là loài quỷ nguyên sơ."

msgid "Primal?"
msgstr "Nguyên sơ?"

msgid "Well, if you consider all these lively fellows you encountered \"demons\"..."
msgstr "Thì, nếu em coi tất cả mấy kẻ sinh sinh động động mà em đã bắt gặp đấy là \"quỷ\"..."

msgid "...then that would make those shadowy ones \"primal demons\"."
msgstr "...thế thì mấy con bóng bóng ảnh ảnh kia gọi là \"quỷ nguyên sơ\"."

msgid "(Hm...)"
msgstr "(Hừm...)"

msgid "What else do you know?"
msgstr "Anh còn biết gì khác không?"

msgid "I know lots of stuff."
msgstr "Tôi biết nhiều chuyện lắm."

msgid "About primal demons?"
msgstr "Về loài quỷ nguyên sơ á?"

msgid "Ahh, about that..."
msgstr "À, cái đó thì..."

msgid "Not much."
msgstr "Không nhiều mấy."

msgid "I know they'll kill whatever crosses their path."
msgstr "Tôi có biết là cứ cái gì ngáng đường là bọn nó làm thịt hết."

msgid "Contrary to other demons, which will mostly only kill you if you're human."
msgstr "Còn các loài quỷ khác thì ngược lại, hầu như chỉ giết hại nếu đối tượng là con người thôi."

msgid "Hm..."
msgstr "Hừm..."

msgid "Let's wait here a bit longer."
msgstr "Đợi lâu thêm chút nữa đi."

msgid "It might be gone."
msgstr "Có khi là nó đi rồi."

msgid "It's up to you when you wanna go back out."
msgstr "Khi nào em muốn ra ngoài lại thì tùy em thôi."

msgid "Are you going outside?"
msgstr "Bạn định ra ngoài chứ?"

msgctxt "events.Ch1_Facility_B2F_Lab.event_leave_lab.choice.Are you going outside?"
msgid "Yes"
msgstr "Ra"

msgctxt "events.Ch1_Facility_B2F_Lab.event_leave_lab.choice.Are you going outside?"
msgid "No"
msgstr "Thôi"

msgctxt "events.Ch1_Facility_B2F_Lab.event_leave_lab.dlg.lacie"
msgid "..."
msgstr "..."

msgid "I guess the coast is clear."
msgstr "Chắc là hết nguy rồi đấy."

msgid "(Will I find any clues in a place like this...?)"
msgstr "(Ở cái nơi như thế này liệu có tìm được manh mối nào không...?)"

msgid "(Maybe I should focus on getting out of here.)"
msgstr "(Có khi mình nên tập trung tìm cách ra khỏi đây.)"

msgid "(Alright.)"
msgstr "(Được rồi.)"

msgid "You still use a flip phone?!"
msgstr "Em còn xài điện thoại nắp gập hả?!"

msgid "Why??"
msgstr "Tại sao??"

msgctxt "events.Ch1_Facility_B2F_Lab.item_cellphone_on_sai.dlg.lacie"
msgid "..."
msgstr "..."

msgid "(It's just fun to flip it open...)"
msgstr "(Tại gập mở nó kêu lặp cặp thấy vui thôi...)"

msgid "Cool, you've got one of those doorknobs."
msgstr "Ngon, em kiếm được một trong mấy cái núm cửa nè."

msgid "It's pretty fun to see where they take you."
msgstr "Xem mấy cái núm đưa em đi đâu thì khá vui đây."

msgid "Ooh, it's one of those cool rocks."
msgstr "Ồồ, một trong mấy cục đá ngầu ngầu nè."

msgid "Did you know they glow in the dark?"
msgstr "Em có biết là mấy cục này phát sáng trong đêm không?"

msgid "Really?"
msgstr "Thật à?"

msgid "No."
msgstr "Không."

msgctxt "events.Ch1_Facility_B2F_Lab.item_runes_on_sai.dlg.lacie"
msgid "..."
msgstr "..."

msgid "But you totally fell for that!"
msgstr "Thế mà em tin sái cổ kìa!"

msgid "A bloody bag. It smells putrid."
msgstr "Cái túi máu me. Bốc mùi thối rữa."

msgid "An operating table. It has faint blood stains."
msgstr "Cái bàn mổ. Nó có vết máu đã ngả màu."

msgid "An operating table."
msgstr "Cái bàn mổ."

msgid "(What's with the strange shape of this bed...?)"
msgstr "(Hình dáng kì lạ của cái giường này là sao đây...?)"

msgid "Looks like human bones."
msgstr "Trông như xương người."

msgid "A fallen book."
msgstr "Cuốn sách bị rơi."

msgid "Read a passage?"
msgstr "Đọc một đoạn chứ?"

msgctxt "events.Ch1_Facility_B2F_Lab.misc_book.choice.Read a passage?"
msgid "Yes"
msgstr "Đọc"

msgctxt "events.Ch1_Facility_B2F_Lab.misc_book.choice.Read a passage?"
msgid "No"
msgstr "Thôi"

msgid "\"The soul does not reside in a specific physical location."
msgstr "\"Linh hồn không cư ngụ ở một nơi vật lý đặc định."

msgid "The torso must be dissected in its entirety in order for extraction to be successful.\""
msgstr "Để trích xuất được thành công thì thân mình phải được mổ xẻ cho hoàn toàn.\""

msgid "A broken container. Whatever was inside is long gone."
msgstr "Cái bình chứa bị vỡ. Bất kể cái gì bên trong thì đã đi lâu rồi."

msgid "A cage filled with bones."
msgstr "Cái cũi chứa toàn xương."

msgctxt "events.Ch1_Facility_B2F_Lab.misc_counter_left.dlg.narrator"
msgid "Medication bottles and small bones fill the countertop."
msgstr "Mặt trên của cái quầy để đầy chai lọ thuốc thang cùng với mấy chiếc xương nhỏ."

msgctxt "events.Ch1_Facility_B2F_Lab.misc_counter_right.dlg.narrator"
msgid "Medication bottles and small bones fill the countertop."
msgstr "Mặt trên của cái quầy để đầy chai lọ thuốc thang cùng với mấy chiếc xương nhỏ."

msgid "There's something in the drawer."
msgstr "Trong ngăn kéo có cái gì đó."

msgid "There's nothing else of use."
msgstr "Không có gì khác được việc."

msgid "There's a gate here, but it's locked."
msgstr "Ở đây có cánh cổng, nhưng bị khóa rồi."

msgid "Strange goop surrounds the well. It looks like it could come alive."
msgstr "Cái chất nhớt kì lạ vây quanh cái giếng. Trông như thể nó sống dậy được ấy."

msgid "...Indeed, the expected outcome of a light switch."
msgstr "...Quả thực, gạt công tắc đèn thì kết quả đúng như trông đợi."

msgid "The lights aren't working right now."
msgstr "Bây giờ đèn không hoạt động rồi."

msgid "Let's not do that."
msgstr "Đừng làm thế đi thôi."

msgid "A closet for medical supplies."
msgstr "Cái tủ chứa vật dụng y tế."

msgid "It's empty, save for some dirty rags."
msgstr "Trừ vài cái giẻ dơ ra thì trống trơn."

msgid "(It smells...really bad.)"
msgstr "(Bốc mùi... khó ngửi quá.)"

msgid "An incubator of some sort. It's warm to the touch."
msgstr "Cái lồng ươm gì đó. Chạm vào thấy ấm."

msgid "An incubator of some sort. It's broken and nothing's left inside."
msgstr "Cái lồng ươm gì đó. Bị vỡ rồi và bên trong không còn lại gì."

msgid "A well."
msgstr "Cái giếng."

msgid "There's probably nothing else of use in there."
msgstr "Trong đây hẳn là không có gì khác dùng được đâu."

msgid "Rotate the lever?"
msgstr "Xoay cần chứ?"

msgctxt "events.Ch1_Facility_B2F_Lab.misc_well.choice.Rotate the lever?"
msgid "Yes"
msgstr "Xoay"

msgctxt "events.Ch1_Facility_B2F_Lab.misc_well.choice.Rotate the lever?"
msgid "No"
msgstr "Thôi"

msgid "A whiteboard that has been mostly erased. Only a few sticky notes with strange symbols remain."
msgstr "Tấm bảng trắng hầu như đã bị xóa. Chỉ vài tờ dán có ghi những biểu tượng kỳ lạ là còn lại."

msgid "Don't go out, it's still there."
msgstr "Đừng có ra, nó còn đó."
