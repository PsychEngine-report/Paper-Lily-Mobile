msgid "Wait a moment."
msgstr "Chờ tí."

msgid "This doesn't look right. We should've come across stairs a while back."
msgstr "Kì cục vậy. Hồi nãy đúng ra phải đi ngang qua cầu thang rồi chứ."

msgid "That's true."
msgstr "Đúng thế."

msgid "Maybe we took a wrong turn somewhere...?"
msgstr "Hay lộn đường chỗ nào đó chăng...?"

msgid "Let's just keep going."
msgstr "Gì thì cứ đi tiếp thôi nào."

msgid "I want to see what's on the other side of this hallway."
msgstr "Mình muốn thấy được đằng bên kia hành lang có cái gì."
