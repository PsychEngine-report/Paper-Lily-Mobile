msgid "It doesn't seem to be doing anything."
msgstr "Nó không có vẻ là làm cái gì cả."

msgid "The other tickets contain the same image."
msgstr "Mấy tấm vé khác cũng mang hình ảnh như vậy."

msgid "You take a number from the ticket dispenser."
msgstr "Bạn lấy một số từ cái máy phát vé."

msgid "A potted plant sits dangerously in the middle of the tracks."
msgstr "Ở chính giữa đường ray là cái cây trồng chậu tọa một cách nguy hiểm."

msgid "The tracks end here."
msgstr "Đường ray đến đây là kết thúc."

msgid "I'm not giving up just yet... I know I can solve this."
msgstr "Mình chưa bỏ cuộc đâu... Mình biết là mình giải được."

msgid "The tickets from the dispenser probably contain a hint."
msgstr "Mấy tấm vé từ cái máy phát vé chắc hẳn có gợi ý."
