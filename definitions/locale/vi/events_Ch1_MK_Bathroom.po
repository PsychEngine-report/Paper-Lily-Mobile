msgid "A little cactus."
msgstr "Cái cây xương rồng nhỏ bé."

msgid "An empty flower vase."
msgstr "Cái lọ hoa rỗng không."

msgid "Pink flowers in a vase."
msgstr "Trong lọ có mấy bông hoa màu hồng."

msgid "I could use these flowers..."
msgstr "Mấy bông hoa này có khi dùng được..."

msgid "Bring the flowers to the plant?"
msgstr "Mang mấy bông hoa tới chỗ cái cây chứ?"

msgctxt "events.Ch1_MK_Bathroom.misc_flowers.choice.Bring the flowers to the plant?"
msgid "Yes"
msgstr "Mang đi"

msgctxt "events.Ch1_MK_Bathroom.misc_flowers.choice.Bring the flowers to the plant?"
msgid "No"
msgstr "Thôi"

msgid "\"Thank you.\""
msgstr "\"Cảm ơn nhé.\""

msgid "A shelf. Nothing of interest."
msgstr "Cái kệ. Không có gì thú vị."

msgid "A bathtub filled with a black liquid."
msgstr "Cái bồn tắm chứa đầy chất dịch màu đen."

msgid "It's so big... you could fit like... four of me in there."
msgstr "To ghê... Có thể nhét... bốn người như mình vào đây là vừa."

msgid "Check if there's anything useful inside?"
msgstr "Coi xem liệu bên trong có cái gì được việc chứ?"

msgctxt "events.Ch1_MK_Bathroom.misc_tub.choice.Check if there's anything useful inside?"
msgid "Yes"
msgstr "Coi xem"

msgctxt "events.Ch1_MK_Bathroom.misc_tub.choice.Check if there's anything useful inside?"
msgid "No"
msgstr "Thôi"

msgid "A beautiful night sky."
msgstr "Bầu trời đêm tuyệt đẹp."

msgid "Three moons... ?"
msgstr "Ba cái mặt trăng...?"
