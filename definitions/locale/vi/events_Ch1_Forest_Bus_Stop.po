msgid "(The street is clearly looping. There's little point in running around like this.)"
msgstr "(Con đường rõ ràng là bị lặp. Chạy vòng vòng thế này chả có nghĩa lý gì mấy.)"

msgid "A bus stop sign."
msgstr "Biển trạm dừng xe buýt."

msgid "The schedule is empty. It's likely that there's no next bus coming."
msgstr "Lịch xe thì trống trơn. Khả năng là không có xe buýt nào tới tiếp đâu."

msgid "A lamppost that makes this feel like a safe spot."
msgstr "Cây cột đèn khiến đây thấy như chỗ an toàn."

msgid "A crow standing on a rock."
msgstr "Trên hòn đá có con quạ đang đậu."

msgid "It doesn't seem bothered by my presence."
msgstr "Nó không có vẻ gì là bị sự hiện diện của mình làm phiền."

msgid "A trash can. It's overflowing with emptiness."
msgstr "Cái thùng rác. Nó chan chứa sự trống không."
