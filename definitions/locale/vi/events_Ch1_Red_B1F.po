msgctxt "events.Ch1_Red_B1F.event_code_failure.dlg.narrator"
msgid "..."
msgstr "..."

msgid "The code was incorrect."
msgstr "Mã số không đúng rồi."

msgctxt "events.Ch1_Red_B1F.event_code_success.dlg.narrator"
msgid "..."
msgstr "..."

msgid "The door opens!"
msgstr "Cánh cửa mở rồi!"

msgid "Now that I think about it, this is a strange location for such a large mirror."
msgstr "Giờ mới nghĩ, đặt cái gương lớn như vầy ở chỗ này thì đúng là kỳ lạ thật đấy."

msgid "Maybe there's something behind it?"
msgstr "Có khi đằng sau nó có cái gì đó?"

msgid "Kick the mirror?"
msgstr "Đá cái gương chứ?"

msgctxt "events.Ch1_Red_B1F.event_kick_mirror.choice.Kick the mirror?"
msgid "Yes"
msgstr "Đá"

msgctxt "events.Ch1_Red_B1F.event_kick_mirror.choice.Kick the mirror?"
msgid "No"
msgstr "Thôi"

msgid "A door... and a keypad... for a code, I think."
msgstr "Cánh cửa... với cái keypad... thấy là để nhập mã."

msgid "Is it the door behind the mirror?"
msgstr "Đằng sau cái gương là cửa à?"

msgid "(Maybe there's a better way?)"
msgstr "(Hay là có khi có cách tốt hơn?)"

msgctxt "events.Ch1_Red_B1F.event_kick_mirror.dlg.unknown"
msgid "Here you go."
msgstr "Mã số đây."

msgid "...Huh. Thanks."
msgstr "...Hơ. Cám ơn."

msgid "I'm not carrying this thing around..."
msgstr "Mình không đem cái thứ này theo bên đâu..."

msgid "Pssst."
msgstr "Xuuyỵt."

msgid "Hey girlie."
msgstr "Ê cô em."

msgctxt "events.Ch1_Red_B1F.event_prisoner.dlg.lacie"
msgid "...?"
msgstr "...?"

msgid "Been a while since I've seen anybody come down here."
msgstr "Lâu lắm rồi mới thấy có người xuống đây."

msgid "Even that smug asshole hasn't been around."
msgstr "Cả cái thằng khốn kiếp khỉnh khỉnh đó cũng biến đi đâu rồi."

msgid "Who do you mean?"
msgstr "Ông đang nói ai vậy?"

msgid "You know who I mean, or you wouldn't be snooping around here, would ya?"
msgstr "Cô em biết ta nói ai mà, chứ không cô em đi rình mò dưới này làm cái gì nhể?"

msgid "...Red?"
msgstr "...Red á?"

msgid "Ding ding diiiing!"
msgstr "Đinh đinh điiiinh!"

msgid "Did Red lock you in here?"
msgstr "Red nhốt ông ở đây à?"

msgctxt "events.Ch1_Red_B1F.event_prisoner.dlg.unknown"
msgid "Correct."
msgstr "Chính xác."

msgid "Why?"
msgstr "Tại sao?"

msgid "My, aren't you asking lots of questions..."
msgstr "Trời, cô em hỏi nhiều câu hỏi thế..."

msgid "Maybe I'll tell you if you come a bit closer."
msgstr "Cô em lại gần đây có khi ta sẽ kể cho."

msgctxt "events.Ch1_Red_B1F.event_prisoner.choice"
msgid "Get closer?"
msgstr "Lại gần hơn chứ?"

msgctxt "events.Ch1_Red_B1F.event_prisoner.choice.Get closer?"
msgid "Yes"
msgstr "Lại gần hơn"

msgctxt "events.Ch1_Red_B1F.event_prisoner.choice.Get closer?"
msgid "No"
msgstr "Thôi"

msgid "Aww... What a shame."
msgstr "Ơờ... tiếc thế."

msgid "No more chit chat then."
msgstr "Vậy không tán dóc nữa nhan."

msgid "(Better safe than sorry.)"
msgstr "(Cẩn tắc vô áy náy.)"

msgctxt "events.Ch1_Red_B1F.event_prisoner.dlg.unknown"
msgid "That's the spirit."
msgstr "Khí phách có thế chứ."

msgctxt "events.Ch1_Red_B1F.event_prisoner.dlg.unknown"
msgid "Red locked me in here because I can be a bit of a nuisance."
msgstr "Red nhốt ta ở đây bởi vì ta có thể trở thành mối làm rầy với hắn."

msgctxt "events.Ch1_Red_B1F.event_prisoner.dlg.unknown"
msgid "I'm the only one who can cast curses."
msgstr "Ta là kẻ duy nhất có thể ếm lời nguyền."

msgctxt "events.Ch1_Red_B1F.event_prisoner.dlg.lacie"
msgid "Curses...?"
msgstr "Lời nguyền...?"

msgctxt "events.Ch1_Red_B1F.event_prisoner.dlg.lacie"
msgid "You're the only one? Then, did you have something to do with my curse?"
msgstr "Ông là kẻ duy nhất á? Vậy ông có dính dáng gì đến lời nguyền trong người tôi không?"

msgctxt "events.Ch1_Red_B1F.event_prisoner.dlg.unknown"
msgid "If you come a bit closer, maybe I'll tell you."
msgstr "Nếu cô em lại gần chút nữa, có khi ta kể cho."

msgctxt "events.Ch1_Red_B1F.event_prisoner_2.dlg.unknown"
msgid "That's the spirit."
msgstr "Khí phách có thế chứ."

msgid "Welcome back, what is it you wanted to know again?"
msgstr "Chào mừng trở lại, cô em muốn biết cái gì lại nào?"

msgid "Why are you locked up?"
msgstr "Tại sao ông bị nhốt ở đây thế?"

msgctxt "events.Ch1_Red_B1F.event_prisoner_2.dlg.unknown"
msgid "Red locked me in here because I can be a bit of a nuisance."
msgstr "Red nhốt ta ở đây bởi vì ta có thể trở thành mối làm rầy với hắn."

msgctxt "events.Ch1_Red_B1F.event_prisoner_2.dlg.unknown"
msgid "I'm the only one who can cast curses."
msgstr "Ta là kẻ duy nhất có thể ếm lời nguyền."

msgctxt "events.Ch1_Red_B1F.event_prisoner_2.dlg.lacie"
msgid "Curses...?"
msgstr "Lời nguyền...?"

msgctxt "events.Ch1_Red_B1F.event_prisoner_2.dlg.lacie"
msgid "You're the only one? Then, did you have something to do with my curse?"
msgstr "Ông là kẻ duy nhất á? Vậy ông có dính dáng gì đến lời nguyền trong người tôi không?"

msgctxt "events.Ch1_Red_B1F.event_prisoner_2.dlg.unknown"
msgid "If you come a bit closer, maybe I'll tell you."
msgstr "Nếu cô em lại gần chút nữa, có khi ta kể nữa cho."

msgctxt "events.Ch1_Red_B1F.event_prisoner_2.choice"
msgid "Get closer?"
msgstr "Lại gần hơn chứ?"

msgctxt "events.Ch1_Red_B1F.event_prisoner_2.choice.Get closer?"
msgid "Yes"
msgstr "Lại gần hơn"

msgctxt "events.Ch1_Red_B1F.event_prisoner_2.choice.Get closer?"
msgid "No"
msgstr "Thôi"

msgid "I have a feeling you'll just try to kill me."
msgstr "Tôi có cảm giác ông chỉ toan lấy mạng tôi mà thôi."

msgid "Hahahaha!"
msgstr "Hahahaha!"

msgid "Fine then, I'll humor you this time."
msgstr "Tốt thôi, lần này chiều lòng cô em."

msgid "I didn't curse you."
msgstr "Ta không có ếm nguyền cô em gì hết."

msgctxt "events.Ch1_Red_B1F.event_prisoner_3.dlg.lacie"
msgid "Then who did? You said you're the only one who can inflict curses."
msgstr "Vậy ai làm? Ông nói ông là kẻ duy nhất có thể giáng lời nguyền..."

msgctxt "events.Ch1_Red_B1F.event_prisoner_3.dlg.unknown"
msgid "...and live."
msgstr "...mà sống được tiếp."

msgctxt "events.Ch1_Red_B1F.event_prisoner_3.dlg.lacie"
msgid "...?"
msgstr "...?"

msgid "Look girlie, I hate doing shit for free."
msgstr "Này cô em, ta không có ưa làm không công."

msgid "Yep. It's a shortcut."
msgstr "Đúng rồi. Đó là đường tắt đấy."

msgid "It needs a code."
msgstr "Nó đòi nhập mã."

msgctxt "events.Ch1_Red_B1F.event_prisoner_door.dlg.unknown"
msgid "Correct."
msgstr "Chính xác."

msgid "I can give it to you, provided you do one more thing for me."
msgstr "Ta đưa mã cho cô em được, miễn là cô em làm thêm một chuyện nữa cho ta."

msgid "How do I know it's actually a shortcut?"
msgstr "Lấy gì đảm bảo có lối đi tắt thật hay là không?"

msgid "You don't. You'll just have to trust me."
msgstr "Chẳng có đâu, cô em phải tin tưởng ta thôi."

msgid "Sounds like a bad choice."
msgstr "Nghe như là lựa chọn tệ rồi."

msgid "Your call, girlie."
msgstr "Tùy cô em thôi à."

msgid "If you bring me a blue light, I'll give you the code."
msgstr "Nếu cô em mang cho ta một cái ánh sáng lam, thì ta đưa cô em mã số."

msgid "A blue light?"
msgstr "Cái ánh sáng màu lam á?"

msgid "Correct. A blue light. Not green, not red, certainly not white. A blue light."
msgstr "Chính xác. Cái ánh sáng lam. Không lục, không đỏ, dĩ nhiên không trắng. Ánh sáng lam ấy."

msgid "I have this blue candle, does it count?"
msgstr "Tôi có cái nến màu lam này rồi, có tính không?"

msgid "I'll be damned, you already have it?"
msgstr "Kinh đấy, cô em có rồi kia à?"

msgid "Then give it to me, unless you don't want the code."
msgstr "Vậy thì đưa nó cho ta, trừ phi cô em không muốn lấy mã nữa."

msgid "Where am I going to find that?"
msgstr "Tôi biết đi đâu mà tìm cái đó?"

msgid "Don't know. I think I saw a candle-looking guy selling some a while back."
msgstr "Chịu. Ta nhớ hồi lâu rồi trước đây ta có thấy cái thằng nào trông giống cây nến có bán vài cái."

msgctxt "events.Ch1_Red_B1F.event_prisoner_door.dlg.lacie"
msgid "..."
msgstr "..."

msgid "Hey wait wait!"
msgstr "Ê từ từ đợi đã!"

msgid "Won't you do something for me? Pretty please little girl?"
msgstr "Cô em làm gì cho ta đi chứ? Làm ơn đi mà cô bé ơi?"

msgctxt "events.Ch1_Red_B1F.event_prisoner_leave.dlg.lacie"
msgid "No thank you."
msgstr "Thôi xin kiếu."

msgid "Come oooonnn, I've been stuck here for years, help me out!"
msgstr "Ơ kìaaaaaa, ta bị kẹt chốn này mấy năm trời rồi, cứu ta ra!"

msgctxt "events.Ch1_Red_B1F.event_prisoner_leave.dlg.lacie"
msgid "..."
msgstr "..."

msgid "Tch."
msgstr "Chậc."

msgid "When I get out of here..."
msgstr "Khi ta mà ra khỏi đây được..."

msgid "I'll make you suffer."
msgstr "Ta sẽ làm cho cô em phải đau khổ."

msgid "It's a promise."
msgstr "Hứa là làm."

msgid "You do something I ask, and I'll answer one of your questions. Yeah?"
msgstr "Ta nhờ chuyện, cô em làm, rồi ta sẽ trả lời một trong các câu hỏi của cô em. Được nhá?"

msgid "You want me to open your cage?"
msgstr "Ông muốn tôi mở cũi cho ông à?"

msgid "Hahahaha as if you could! You severely overestimate yourself, kid."
msgstr "Hahahaha làm như mình mở được ấy! Cô em đánh giá quá ư là cao bản thân rồi cô bé ạ."

msgid "No, this is something you can actually do."
msgstr "Không, ta nhờ chuyện cô em thực sự có thể làm được cơ."

msgid "I can't see it from here, but somewhere in this room there should be a jar of slugs."
msgstr "Ở chỗ này ta không thấy được, nhưng đâu đó trong cái phòng này ắt phải có cái hũ đựng sên."

msgid "Slugs?"
msgstr "Sên á!?"

msgid "Yeah. Large, slimy, gross? You know."
msgstr "Ờ. To, nhớt, gớm? Hiểu rồi đấy."

msgid "Bring it to me and we can continue this conversation."
msgstr "Đem lại đây giùm rồi chúng ta có thể tiếp tục chuyện trò."

msgid "I won't be coming anywhere close to you."
msgstr "Không có chuyện tôi lại chỗ nào gần ông đâu."

msgid "Fair."
msgstr "Phải lý thôi."

msgid "Throw it to me from where you're standing right now then, if you're such a scaredy cat."
msgstr "Nếu cô em nhát cáy như vậy thì cứ đứng ngay chỗ đang đứng đó mà liệng vào cho ta."

msgctxt "events.Ch1_Red_B1F.event_prisoner_request.dlg.lacie"
msgid "..."
msgstr "..."

msgid "...!"
msgstr "...!"

msgctxt "events.Ch1_Red_B1F.event_strangle_success.dlg.unknown"
msgid "..."
msgstr "..."

msgid "You tricked me."
msgstr "Ông lừa tôi."

msgid "Not exactly."
msgstr "Không hẳn đâu."

msgid "Just tell me. Did you curse me?"
msgstr "Nói ngay. Có phải là ông ếm nguyền tôi không?"

msgid "I did not."
msgstr "Ta không hề."

msgctxt "events.Ch1_Red_B1F.event_strangle_success.dlg.lacie"
msgid "Then who did? You said you're the only one who can inflict curses."
msgstr "Vậy thì ai làm? Ông nói ông là kẻ duy nhất có thể giáng lời nguyền..."

msgctxt "events.Ch1_Red_B1F.event_strangle_success.dlg.unknown"
msgid "...and live."
msgstr "...mà sống được tiếp."

msgctxt "events.Ch1_Red_B1F.event_strangle_success.dlg.lacie"
msgid "...?"
msgstr "...?"

msgid "Look girlie, you get the drift."
msgstr "Đấy, cô em nắm được ý rồi đấy."

msgid "Amazing..."
msgstr "Tuyệt..."

msgid "I haven't seen a light in years..."
msgstr "Ngần ấy năm rồi ta chưa được thấy ánh sáng..."

msgid "So bright..."
msgstr "Ngời quá..."

msgid "So warm..."
msgstr "Ấm quá..."

msgid "*Ahem*"
msgstr "*È hèm*"

msgid "Yeah yeah, thanks girlie."
msgstr "Ờ ờ, cảm ơn cô em."

msgid "You really did me a solid here."
msgstr "Cô em thực cứu vớt ta rồi."

msgctxt "events.Ch1_Red_B1F.item_bluecandle_on_prisoner.dlg.unknown"
msgid "I'll remember this."
msgstr "Ta sẽ nhớ lấy."

msgctxt "events.Ch1_Red_B1F.item_bluecandle_on_prisoner.dlg.lacie"
msgid "..."
msgstr "..."

msgctxt "events.Ch1_Red_B1F.item_bluecandle_on_prisoner.dlg.unknown"
msgid "Here you go."
msgstr "Mã số đây."

msgid "Thanks."
msgstr "Cám ơn."

msgid "What's your name?"
msgstr "Tên ông là gì?"

msgid "There's no need to get buddy-buddy. You won't be alive for long enough for us to meet again."
msgstr "Không cần phải thân thiết. Cô em không sống được đủ lâu đên khi hai ta tái ngộ đâu."

msgid "...But if we do, I'll make sure to introduce myself properly."
msgstr "...Nhưng nếu lại được thế, ta cam đoan sẽ giới thiệu bản thân đàng hoàng."

msgid "Why... why are you giving this to me?"
msgstr "Sao... tại sao cô em lại đưa cái này cho ta?"

msgid "I don't know... just a feeling?"
msgstr "Tôi chịu... linh cảm thôi?"

msgid "Hahahahahaha incredible... were you just screwing with me before?"
msgstr "Hahahahahaha kì diệu thật... lúc nãy cô em chỉ giỡn mặt ta thôi à?"

msgid "I guess I'm not gonna make you suffer after all."
msgstr "Chắc là ta rốt cuộc sẽ không làm cô em phải đau khổ rồi."

msgid "Here, take the slugs as well."
msgstr "Đây, ông lấy sên luôn nè."

msgid "Huh..."
msgstr "Òa..."

msgid "I don't know who you are but..."
msgstr "Ta không biết cô em là ai nhưng mà..."

msgid "So... about this room..."
msgstr "Thế... về cái phòng này..."

msgid "Oh man you're slow. Check the mirror."
msgstr "Ôi dào cô em chậm thế. Coi cái gương đi."

msgid "Hahahahahaha oh god... so good..."
msgstr "Hahahahahaha ôi trời ơi... tốt quá..."

msgid "There's your jar."
msgstr "Cái hũ cho ông đây."

msgid "Good..."
msgstr "Tốt..."

msgid "What would you like to know?"
msgstr "Cô em muốn biết gì nào?"

msgid "You said you're the only demon who can inflict curses, correct?"
msgstr "Ông nói ông là con quỷ duy nhất có thể giáng lời nguyền, đúng không?"

msgid "Did you place this curse on me?"
msgstr "Có phải ông đặt lời nguyền này lên tôi không?"

msgid "I'm the only demon who can inflict curses and LIVE."
msgstr "Ta là con quỷ duy nhất có thể giáng lời nguyền, và SỐNG TIẾP ĐƯỢC."

msgid "Any demon can place a curse on someone on their dying breath."
msgstr "Bất kỳ con quỷ nào cũng có thể đặt lời nguyền lên ai đó trong cơn hấp hối."

msgid "But I can place a thousand, with no repercussions."
msgstr "Nhưng ta có thể đặt hàng ngàn lời nguyền mà không có hậu quả gì."

msgid "(Isn't that a bit OP?)"
msgstr "(Thế có phải hơi O.P quá không?)"

msgid "That sounds too powerful."
msgstr "Nghe hùng mạnh quá nhỉ."

msgid "Why do you think I'm locked up?"
msgstr "Cô em nghĩ tại sao ta lại bị nhốt lại?"

msgid "Red's being a little bitch about it."
msgstr "Thằng Red hơi bị khó ở với cái điều này."

msgctxt "events.Ch1_Red_B1F.item_jar_on_prisoner.dlg.lacie"
msgid "..."
msgstr "..."

msgid "You're obviously a human with a weird aura."
msgstr "Rõ ràng cô em là một con người có cái khí quang kì cục."

msgid "You lookin' to remove your curse?"
msgstr "Cô em tìm cách phá nguyền hả?"

msgid "Yes."
msgstr "Vâng."

msgid "Then you'd probably need Red's help."
msgstr "Vậy cô em chắc là cần thằng Red giúp rồi."

msgid "Yes, that's the idea."
msgstr "Vâng, ý tưởng là thế."

msgid "How do you plan to do that?"
msgstr "Cô em dự tính làm thế nào?"

msgid "Someone told me to go to the lighthouse, so I have to go North."
msgstr "Có người bảo tôi đi tới cái nhà hải đăng, nên tôi phải lên phía Bắc."

msgid "Ooh~ North."
msgstr "Ốồ~ phía Bắc."

msgid "You're gonna die if you go through the locked site, y'know?"
msgstr "Cô em mà đi qua khu bị khóa là chết đấy biết không?"

msgid "What other choice do I have?"
msgstr "Tôi có lựa chọn nào khác đâu?"

msgid "There's always another choice."
msgstr "Luôn luôn có lựa chọn khác."

msgid "Do you mean that door to the right?"
msgstr "Ý ông là cái cửa bên phải kia á?"

msgid "Is that so..."
msgstr "Ủa vậy à..."

msgid "You just haven't looked around this room well enough."
msgstr "Do cô em vẫn chưa coi hết cái phòng này ấy thôi."

msgid "...Actually, I have no idea."
msgstr "...Thực ra, tôi không biết làm sao hết."

msgid "Ahahahaha, you crack me up!"
msgstr "Ahahahaha, cô em làm ta cười vỡ bụng!"

msgid "Any suggestions?"
msgstr "Có kiến nghị gì không?"

msgid "Why not follow Red? That little shit left through here last time."
msgstr "Sao không đi theo thằng Red? Cái thằng nhãi đó lúc lần trước có ra qua đây nè."

msgid "But that was long ago."
msgstr "Nhưng mà hồi đó thì lâu rồi."

msgid "Do you mean through that door to the right?"
msgstr "Ý ông là đi qua cái cửa đằng bên phải kia à?"

msgid "Through... here? What do you mean?"
msgstr "Ra qua... đây? Ý ông là sao?"

msgid "You haven't looked at this room much, have you?"
msgstr "Cô em vẫn chưa coi kĩ cái phòng này lắm đúng không?"

msgid "A plain cardboard box."
msgstr "Cái thùng các-tông đơn sơ."

msgid "Some cardboard boxes."
msgstr "Vài cái thùng các-tông."

msgid "A blue butterfly."
msgstr "Con bướm xanh lam."

msgid "A sturdy cage housing a being."
msgstr "Cái cũi kiên cố có trú ngụ một hữu thể."

msgctxt "events.Ch1_Red_B1F.misc_drawer_1.dlg.narrator"
msgid "The drawers are empty."
msgstr "Mấy ngăn kéo đều trống không."

msgid "A jar filled with slugs."
msgstr "Cái hũ chứa đầy sên."

msgid "(They're alive in there...)"
msgstr "(Bọn nó còn ngọ nguậy trong đấy kìa...)"

msgid "Take ${item:ch1.red_jar}?"
msgstr "Lấy ${item:ch1.red_jar} chứ?"

msgctxt "events.Ch1_Red_B1F.misc_drawer_2.choice.Take ${item:ch1.red_jar}?"
msgid "Yes"
msgstr "Lấy"

msgctxt "events.Ch1_Red_B1F.misc_drawer_2.choice.Take ${item:ch1.red_jar}?"
msgid "No"
msgstr "Thôi"

msgid "The drawers underneath are empty."
msgstr "Mấy ngăn kéo bên dưới đều trống không."

msgctxt "events.Ch1_Red_B1F.misc_drawer_2.dlg.narrator"
msgid "The drawers are empty."
msgstr "Mấy ngăn kéo đều trống không."

msgid "Bug-themed lamps."
msgstr "Mấy cái đèn mang chủ đề côn trùng."

msgid "I'm not going to carry the slugs with me..."
msgstr "Mình không đem mấy con sên theo bên đâu..."

msgid "A large mirror."
msgstr "Tấm gương lớn."

