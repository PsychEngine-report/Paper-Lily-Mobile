msgid "It's a donation box. The label reads:"
msgstr "Cái hộp quyên góp. Nhãn đọc là:"

msgid "\"All proceeds go towards the construction of a bridge somewhere. We appreciate your donation!\""
msgstr "\"Tất cả tiền quyên góp là dành để xây dựng một cây cầu ở đâu đấy. Chúng tôi cảm kích tấm lòng quý vị!\""

msgid "The lid is loose, and there's a single coin inside."
msgstr "Nắp hộp bị long, và bên trong có một đồng xu."

msgid "Take the ${item:ch1.coin}?"
msgstr "Lấy ${item:ch1.coin} chứ?"

msgid "Yes"
msgstr "Lấy"

msgid "No"
msgstr "Thôi"

msgid "The box is now empty."
msgstr "Cái hộp giờ trống không rồi."
