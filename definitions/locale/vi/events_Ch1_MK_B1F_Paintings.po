msgid "No need to mess with it anymore."
msgstr "Không cần nghịch với nó nữa."

msgid "The paintings have been destroyed..."
msgstr "Mấy bức tranh bị thiêu hủy rồi..."

msgid "Various paintings of a young girl are stored here."
msgstr "Ở đây cất trữ mấy bức tranh khác nhau về một thiếu nữ."

msgid "The hands are charred."
msgstr "Đôi bàn tay hóa than rồi."

msgid "The hands are on fire."
msgstr "Đôi bàn tay đang bốc cháy."
