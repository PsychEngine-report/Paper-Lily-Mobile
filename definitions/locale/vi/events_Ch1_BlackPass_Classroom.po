msgid "Hey, where do you think you're going?"
msgstr "Ê, tính đi đâu mày?"

msgctxt "events.Ch1_BlackPass_Classroom.event_bouncer.dlg.lacie"
msgid "..."
msgstr "..."

msgctxt "events.Ch1_BlackPass_Classroom.event_cutscene.dlg.lacie"
msgid "..."
msgstr "..."

msgid "There she is."
msgstr "Nó kia kìa."

msgid "That's her?"
msgstr "Con này hả?"

msgid "She's so cursed that the bird dropped dead."
msgstr "Cái con này nó xúi quẩy quá làm con chim chết luôn rồi nè."

msgid "If she can make a bird die, I wonder what she could do to people."
msgstr "Con chim mà nó làm chết được thì không biết nó làm cái gì với người ta được đây."

msgid "What a freak."
msgstr "Đồ quái dị."

msgid "Hey, you killed that poor bird."
msgstr "Ê, tội con chim chưa, mày giết con chim rồi."

msgid "...N-no..."
msgstr "...Kh-không phải..."

msgid "It flew into the window next to YOUR seat."
msgstr "Con chim nó bay vào cái cửa sổ ĐÚNG NGAY chỗ MÀY ngồi."

msgid "...but.. I didn't..."
msgstr "...nhưng mà... tao đâu có..."

msgid "It died because of you."
msgstr "Tại mày nó chết đấy."

msgid "This is your fault."
msgstr "Ra vầy là do mày cả."

msgid "Aargh!"
msgstr "Aaaư!"

msgid "........"
msgstr "........"

msgid "What the hell!?"
msgstr "Cái đéo gì đấy?"

msgid "Did she kill him?"
msgstr "Nó đâm thằng kia à?"

msgid "Is he dead?"
msgstr "Thằng kia chết rồi hả?"

msgctxt "events.Ch1_BlackPass_Classroom.item_knife_on_person_left.dlg.unknown"
msgid "MURDERER!"
msgstr "ĐỒ GIẾT NGƯỜI!"

msgctxt "events.Ch1_BlackPass_Classroom.item_knife_on_person_left.dlg.unknown"
msgid "MURDERER! MURDERER! MURDERER!"
msgstr "ĐỒ GIẾT NGƯỜI! ĐỒ GIẾT NGƯỜI! ĐỒ GIẾT NGƯỜI!"

msgctxt "events.Ch1_BlackPass_Classroom.item_knife_on_person_left.dlg.lacie"
msgid "....."
msgstr "....."

msgid "Wait... what are you doing!?"
msgstr "Từ từ... mày tính làm gì!?"

msgid "I'm doing something, unlike you."
msgstr "Tao làm gì đó, chứ đâu như mày."

msgid "AAAAH!"
msgstr "AAAA!"

msgid "She killed him!"
msgstr "Nó giết thằng kia rồi!"

msgid "Oh my god! She's crazy!"
msgstr "Trời đất ơi! Con này nó bị điên!"

msgctxt "events.Ch1_BlackPass_Classroom.item_knife_on_person_right.dlg.unknown"
msgid "MURDERER!"
msgstr "ĐỒ GIẾT NGƯỜI!"

msgctxt "events.Ch1_BlackPass_Classroom.item_knife_on_person_right.dlg.unknown"
msgid "MURDERER! MURDERER! MURDERER!"
msgstr "ĐỒ GIẾT NGƯỜI! ĐỒ GIẾT NGƯỜI! ĐỒ GIẾT NGƯỜI!"

msgctxt "events.Ch1_BlackPass_Classroom.item_knife_on_person_right.dlg.lacie"
msgid "....."
msgstr "....."

msgid "Pick up ${item:global.reditem_3}?"
msgstr "Nhặt ${item:global.reditem_3} lên chứ?"

msgctxt "events.Ch1_BlackPass_Classroom.item_red_item_get.choice.Pick up ${item:global.reditem_3}?"
msgid "Yes"
msgstr "Nhặt lên"

msgctxt "events.Ch1_BlackPass_Classroom.item_red_item_get.choice.Pick up ${item:global.reditem_3}?"
msgid "No"
msgstr "Thôi"

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.dlg.lacie"
msgid "..."
msgstr "..."

msgid "This isn't my fault..."
msgstr "Không phải là do tao..."

msgid "Can't believe you're still acting innocent."
msgstr "Tầm này mà mày còn giả oan à."

msgid "You disgust me."
msgstr "Làm tao kinh tởm."

msgid "You cause nothing but ruin everywhere you go!"
msgstr "Mày đi đến đâu là mày hủy hoại đến đó!"

msgid "I-I'm sorry... I'm really sorry... I don't do it on purpose... I didn't do anything..."
msgstr "T-Tao xin lỗi... tao xin lỗi mà... tao không có cố ý... tao đâu có làm gì..."

msgid "Maybe you SHOULD do something..."
msgstr "Có khi mày NÊN làm cái gì đó..."

msgid "...Huh?"
msgstr "...Hơ?"

msgid "...To make it up to us. Why don't you take responsibility for messing up everything?"
msgstr "...Để mà làm lành với cả lớp đấy. Cái nào cái nấy cũng phá hỏng thì sao mày không chịu trách nhiệm đi?"

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.dlg.lacie"
msgid "....."
msgstr "....."

msgid "...H-How...?"
msgstr "...Ch-Chịu trách nhiệm làm sao...?"

msgid "Hmmm."
msgstr "Hừmmm."

msgid "Make her eat it!"
msgstr "Bắt nó ăn đi!"

msgid "Yeah! Eat the bird!"
msgstr "Đúng rồi! Ăn con chim đê!"

msgid "...What..?!"
msgstr "...Hả...?!"

msgid "You heard them."
msgstr "Mày nghe cả lớp nói rồi đấy."

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.dlg.unknown"
msgid "Eat it, witch."
msgstr "Ăn đi, con phù thủy."

msgid "If you eat it, maybe we'll forgive you."
msgstr "Mày ăn thì có khi cả lớp tha cho mày."

msgid "Eat the bird, murderer."
msgstr "Ăn con chim đi đồ sát sinh."

msgid "(This isn't real...)"
msgstr "(Đây không phải thật...)"

msgid "(Do I really have to do this...?)"
msgstr "(Mình có thật sự phải làm thế không...?)"

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.choice.(Do I really have to do this...?)"
msgid "Eat the bird"
msgstr "Ăn con chim"

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.choice.(Do I really have to do this...?)"
msgid "Do not"
msgstr "Không"

msgid "Take the _____"
msgstr "Lấy cái _____"

msgid "(Will this get them to stop...?)"
msgstr "(Làm thế này rồi bọn nó có dừng lại không...?)"

msgid "(Ugh... I feel sick...)"
msgstr "(Ựa... Mình thấy ớn quá...)"

msgid "She actually did it! She's insane!"
msgstr "Nó ăn thật kìa! Nó rồ rồi chúng mày ơi!"

msgid "She's such a freak! HAHAHAHA!"
msgstr "Nó đúng chuẩn quái dị mà! HAHAHAHA!"

msgid "HAHAHAHA It's all bloody now!"
msgstr "HAHAHAHA Máu tùm lum kìa bay!"

msgid "HAHAHAHAHA"
msgstr "HAHAHAHAHA"

msgid "HAHAHAHAHAHAHAHAHAHAHA"
msgstr "HAHAHAHAHAHAHAHAHAHAHA"

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.choice"
msgid "..."
msgstr "..."

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.choice...."
msgid "Stab self"
msgstr "Đâm bản thân"

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.choice...."
msgid "Do not"
msgstr "Không"

msgid "(This dream...)"
msgstr "(Giấc mơ này...)"

msgid "(The easiest way to get out...)"
msgstr "(Cách dễ nhất để thoát ra...)"

msgid "(It's obvious, isn't it?)"
msgstr "(Hiển nhiên rồi mà nhỉ?)"

msgid "...Ah! It hurts! ...it hurts..."
msgstr "...A! Đau!...đau quá..."

msgid "...When am I waking up..."
msgstr "...Khi nào thức dậy..."

msgid "...Let this stupid... nightmare... end..."
msgstr "...để cái cơn ác mộng... ngu ngục này... biến đi..."

msgid "...Why..."
msgstr "...Tại sao..."

msgid "...It's just a dream... so why..."
msgstr "...Đây chỉ là mơ... mà sao lại..."

msgid "...It hurts..."
msgstr "...Đau quá..."

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.choice...."
msgid "Eat the bird"
msgstr "Ăn con chim"

msgid "Do nothing"
msgstr "Không làm gì"

msgid "There's nothing else to do here."
msgstr "Chỗ này không có gì khác mà làm cả."

msgctxt "events.Ch1_BlackPass_Classroom.misc_person_left.dlg.unknown"
msgid "Eat it, witch."
msgstr "Ăn nó đi, đồ phù thủy."

msgid "Sorry, I can't let you pass."
msgstr "Không được, làm gì có chuyện cho mày đi."

msgid "Please?"
msgstr "Xin đấy?"

msgid "Just do what they say."
msgstr "Người ta bảo làm gì thì làm."

msgid "(A strong force prevents you from entering the wardrobe.)"
msgstr "(Có cái lực mạnh ngăn cản bạn bước vào trong tủ quần áo.)"

msgid "(Push through?)"
msgstr "(Đùn qua chứ?)"

msgctxt "events.Ch1_BlackPass_Classroom.misc_wardrobe.choice.(Push through?)"
msgid "Yes"
msgstr "Đùn qua"

msgctxt "events.Ch1_BlackPass_Classroom.misc_wardrobe.choice.(Push through?)"
msgid "No"
msgstr "Thôi"

msgid "\"MURDERER\""
msgstr "\"ĐỒ SÁT SINH\""

msgid "The passageway has closed behind you."
msgstr "Lối đi đằng sau bạn đóng lại rồi."
