msgid "It's already unlocked."
msgstr "Khóa đã mở rồi."

msgid "...but there's nothing inside."
msgstr "...song bên trong chả cất gì cả."

msgid "There's some schematics for some sort of machine you don't really understand."
msgstr "Có vài tấm lược đồ của cái máy móc nào đó mà bạn nhìn chả hiểu gì lắm."

msgid "What's that?"
msgstr "Đó là cái gì?"

msgid "Not a clue... but I'm taking it."
msgstr "Bó tay... nhưng mà tao cầm đi thôi."

msgid "There's some official-looking documents here."
msgstr "Ở đây có mấy giấy tờ trông như là công văn."

msgid "Read them?"
msgstr "Đọc chứ?"

msgid "Yes"
msgstr "Đọc"

msgid "No"
msgstr "Thôi"

msgid "${img:stamp_council} MEETING 176 NOTES"
msgstr "${img:stamp_council} BIÊN BẢN CUỘC HỌP 176"

msgid "\"...disagreements on the distribution of the....\""
msgstr "\"...bất nhất trí về sự phân bố của...\""

msgid "\"...is still not participating in our...\""
msgstr "\"...thì vẫn chưa tham gia vào... của chúng ta...\""

msgid "\"...the secondary duty of guardians...\""
msgstr "\"...trách vụ thứ yếu của người hộ vệ...\""

msgid "\"...collection of stones from every...\""
msgstr "\"...thu thập thạch đá từ tất thảy....\""

msgid "The document continues making little sense for several pages."
msgstr "Nội dung nối tiếp suốt mấy trang hầu như chả ra cái nghĩa gì hết."

msgctxt "events.Prologue_Ending_K7_2.event_read_documents.dlg.kat"
msgid "..."
msgstr "..."

msgid "What the hell am I reading?"
msgstr "Mình đang đọc cái quái gì đây?"

msgid "There's nothing else of interest."
msgstr "Chẳng có thứ gì khác hấp dẫn."

msgid "The hairpin doesn't fit into this lock."
msgstr "Kẹp tóc không khít với khóa này."

