msgid "Looks like the large gate we saw earlier..."
msgstr "Trông như cái cổng lớn mà ta thấy ban nãy..."

msgid "Doors?"
msgstr "Cửa?"

msgid "This is probably an elevator."
msgstr "Cái này chắc hẳn là thang máy."

msgid "Lights."
msgstr "Đèn."

msgid "Water?"
msgstr "Nước?"

msgid "An empty slot where a fuse may fit."
msgstr "Cái ổ trống mà có thể cắm vừa cầu chì vào."

msgid "(Looks like I have to rearrange the fuses to match the display.)"
msgstr "(Trông như mình cần phải sắp xếp lại cầu chì để ứng với hiển thị.)"

msgid "An empty fuse slot."
msgstr "Cái ổ cắm cầu chì đang trống."

msgid "Place a fuse?"
msgstr "Cắm cầu chì nào vào?"

msgid "Place fuse no.5"
msgstr "Cắm cầu chì số 5 vào"

msgid "Place fuse no.10"
msgstr "Cắm cầu chì số 10 vào"

msgid "Place fuse no.15"
msgstr "Cắm cầu chì số 15 vào"

msgid "Place fuse no.20"
msgstr "Cắm cầu chì số 20 vào"

msgid "Place fuse no.25"
msgstr "Cắm cầu chì số 25 vào"

msgid "Place fuse no.40"
msgstr "Cắm cầu chì số 40 vào"

msgid "Do not"
msgstr "Không cắm"

msgid "It's a spider!"
msgstr "Nhện kìa!"

msgid "I see that."
msgstr "Tôi thấy rồi."

msgid "Are you scared of spiders?"
msgstr "Em có sợ nhện không?"

msgid "Not really."
msgstr "Không hẳn."

msgid "So, what, if you see a spider in your house you just LEAVE it there?!"
msgstr "Ơ thế, nếu em thấy nhện trong nhà mình là em cứ KỆ nó vậy à?!"

msgid "That's crazy."
msgstr "Dễ sợ."

msgid "What else should I be doing?"
msgstr "Vậy tôi nên làm cái gì khác cơ?"

msgid "I don't know, most people kill it with a shoe or something."
msgstr "Không biết nữa, thấy người ta hầu hết lấy dép đập chết nó hoặc đại loại."

msgid "Why?"
msgstr "Tại sao?"

msgid "I dunno, they crawl and stuff. They're creepy."
msgstr "Chịu, bọn nó bò bò này nọ. Ghê lắm."

msgid "Why should it die for something that isn't its fault?"
msgstr "Tại sao nó không có tội tình gì cả mà phải chết?"

msgid "..."
msgstr "..."

msgid "That's fair."
msgstr "Nói phải."

msgid "Just so you know, I don't kill spiders."
msgstr "Bảo em này, tôi không có giết nhện."

msgid "I see."
msgstr "Vậy à."

msgid "I used to, but now I just put them outside."
msgstr "Có từng, nhưng giờ tôi chỉ gạt bọn nó ra ngoài thôi."

msgid "Great."
msgstr "Tốt đấy."

msgid "A spider hangs from here."
msgstr "Con nhện treo toòng teng từ chỗ đây."

msgid "A spider sits here."
msgstr "Chỗ này có con nhện bám."

msgid "Take out the fuse?"
msgstr "Rút cầu chì ra chứ?"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.pnc_fusebox_takefuse.choice.Take out the fuse?"
msgid "Yes"
msgstr "Rút ra"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.pnc_fusebox_takefuse.choice.Take out the fuse?"
msgid "No"
msgstr "Thôi"
