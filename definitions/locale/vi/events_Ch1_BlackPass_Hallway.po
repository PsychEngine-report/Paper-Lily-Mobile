msgid "I just need to open my locker, and then the closet to end this."
msgstr "Mình chỉ cần mở tủ đồ của mình ra, rồi mở tủ quần áo ra là hết."

msgid "My locker is..."
msgstr "Tủ đồ của mình thì ở..."

msgid "It's pretty obvious, isn't it?"
msgstr "Nhìn là biết ngay rồi nhỉ?"

msgid "This isn't your locker."
msgstr "Đây không phải tủ đồ của bạn."

msgid "A locker."
msgstr "Cái tủ đồ."

msgid "Huh? What's that red thing? It's the first time I see it."
msgstr "Hở? Cái gì màu đỏ đây? Lần đầu tiên thấy đó."

msgid "There's nothing else to see here."
msgstr "Ở đây không còn gì khác mà xem."

msgid "..."
msgstr "..."

msgid "Trash fills your locker."
msgstr "Trong tủ đồ đầy nhóc rác rưởi."

msgid "What a mess."
msgstr "Lộn xộn thật đấy."

msgid "\"Welcome back, Lacie."
msgstr "\"Chào mừng trở lại nhé, Lacie."

msgid "We've missed you at school."
msgstr "Ở trường mọi người nhớ em lắm."

msgid "You'll have a lot to catch up on, so your classmates organized the reading material for you."
msgstr "Em sẽ phải theo kịp bài vở trên lớp nhiều, nên bạn cùng lớp có sửa soạn tài liệu đọc cho em."

msgid "You can find it in your locker."
msgstr "Em tìm trong tủ đồ của mình nhé."

msgid "Please be sure to look over everything carefully."
msgstr "Em nhớ xem học cho kĩ."

msgid "You wouldn't want to fail the year.\""
msgstr "Không là rớt năm đó.\""

msgid "...sigh."
msgstr "...Haầy."

msgid "...Blah blah blah."
msgstr "...Này nọ lọ chai."

msgid "It's always the same text."
msgstr "Lúc nào cũng là mấy dòng đó."

msgid "The note will be back in this spot next time, even if I crumple it."
msgstr "Mình có vò nát đi nữa thì lần sau tờ ghi vẫn cứ trở lại như cũ chỗ này."

msgid "Peace and quiet."
msgstr "Yên tĩnh và thanh bình."

msgid "Nah, it's better like this."
msgstr "Hông, để thế này tốt hơn."

msgid "...Heh... never gets old."
msgstr "...Hê... làm hoài không chán."

msgid "Pick up ${item:global.reditem_1}?"
msgstr "Nhặt ${item:global.reditem_1} lên chứ?"

msgid "Yes"
msgstr "Nhặt"

msgid "No"
msgstr "Thôi"

msgid "It's the exit."
msgstr "Đó là lối ra."

msgid "It doesn't open until I check the locker..."
msgstr "Đến khi mình coi tủ đồ rồi thì nó mới mở ra..."

msgid "Blindingly white light is all you can see."
msgstr "Những gì thấy được chỉ có ánh sáng trắng chói cả mắt."

msgid "Students, laughing at you."
msgstr "Đám học sinh, chúng nó cười nhạo bạn."

msgid "...I hate them."
msgstr "...Phát ghét."

msgid "The passageway has closed behind you."
msgstr "Lối đi đằng sau bạn đóng lại rồi."
