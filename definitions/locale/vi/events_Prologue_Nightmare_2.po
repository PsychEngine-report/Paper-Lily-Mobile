msgid "...Damn it."
msgstr "...Chết tiệt."

msgid "There's nothing there."
msgstr "Ở đó không có gì cả."

msgid "It's too dark to see anything on the other side."
msgstr "Tối quá bên phía kia chả thấy gì."

msgid "Do you even know where you are? You chose a one-way trip to hell, kid."
msgstr "Cả đây là đâu mày cũng không có biết luôn hả? Mày lựa vé một chiều xuống địa ngục rồi con ạ."

msgid "Where are you...?"
msgstr "Mày đang ở đâu...?"

msgid "Well, If you're not gonna help, then be quiet."
msgstr "Được lắm, nếu không có ý định giúp đỡ thì im mồm đi."

msgid "I'll leave once I find what I came for."
msgstr "Một khi tao kiếm được thứ tao cần tìm là tao ra về luôn."

msgid "The door is stuck. It won't open."
msgstr "Cửa bị kẹt không mở được."
