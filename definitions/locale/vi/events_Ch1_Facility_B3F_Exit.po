msgid "Ah... here it is."
msgstr "A... đây rồi nè."

msgid "I suppose these cursed doors must be fairly common."
msgstr "Chắc mấy cánh cửa nguyền này phải khá là phổ biến đấy nhỉ."

msgid "Not that common. And they kinda suck."
msgstr "Không phổ biến lắm đâu. Với cũng hay dở dở ương ương nữa."

msgid "Sometimes you get stuck with no way to go back."
msgstr "Thỉnh thoảng là bị kẹt không có đường về luôn ấy."

msgid "I see."
msgstr "Ra là thế."

msgid "So it's a dead end after all."
msgstr "Vậy ra rốt cuộc là đường cùng."

msgid "Since there's no doorknobs here..."
msgstr "Vì chỗ này không có cái núm cửa nào..."

msgid "Looks like it."
msgstr "Có vẻ là thế."

msgid "An empty slot."
msgstr "Cái lỗ trống."

msgid "Place a doorknob?"
msgstr "Lắp núm cửa nào vào?"

msgid "Gray Doorknob"
msgstr "Núm cửa Màu xám"

msgid "White Doorknob"
msgstr "Núm cửa Màu trắng"

msgid "Return Doorknob"
msgstr "Núm cửa Trở về"

msgid "Do not"
msgstr "Không lắp gì"

msgid "I guess it's finally time to use this."
msgstr "Chắc cuối cùng đến lúc xài cái này rồi."
