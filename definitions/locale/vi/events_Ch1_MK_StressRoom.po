msgid "I think this doll has been stabbed enough times."
msgstr "Mình nghĩ con búp-bê này đã bị đâm đủ lần rồi."

msgid "The lighter doesn't seem to work on it..."
msgstr "Bật lửa không có vẻ là dùng lên được..."

msgid "The burnt doll blocks your path."
msgstr "Con búp-bê bị cháy chặn đường bạn."

msgid "Someone is tied to the stake, with black knives all over their body."
msgstr "Có ai đó bị trói vào cọc, trên khắp cơ thể bị cắm dao màu đen."

msgid "Pull out ${item:ch1.mk_knife}?"
msgstr "Rút ${item:ch1.mk_knife} ra chứ?"

msgid "Yes"
msgstr "Rút ra"

msgid "No"
msgstr "Thôi"

msgid "When you pulled out a knife, the rest of them crumbled apart."
msgstr "Khi bạn rút con dao ra rồi, các con dao còn lại vỡ vụn ra."

msgid "Someone is tied to the stake."
msgstr "Có ai đó bị trói vào cọc."
