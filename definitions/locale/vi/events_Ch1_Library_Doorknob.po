msgstr "Có cuốn sách không có nhan đề nổi bật ra. Đọc một đoạn chứ?"

msgctxt "events.Ch1_Library_Doorknob.misc_books_4.choice.An untitled book stands out. Read a passage?"
msgid "Yes"
msgstr "Đọc"

msgctxt "events.Ch1_Library_Doorknob.misc_books_4.choice.An untitled book stands out. Read a passage?"
msgid "No"
msgstr "Thôi"

msgid "Demons won't hesitate to kill and consume ______"
msgstr "Loài quỷ sẽ không ngần ngại giết chóc và tiêu thụ ______"

msgid "_____'s regulations don't allow free consumption of souls ________ must be reported."
msgstr "Quy định của _____ không cho phép tự do tiêu thụ linh hồn ________ phải được báo cáo."

msgid "Any demand ________ through the appropriate channels."
msgstr "Bất kì nhu cầu nào ________ thông qua các kênh thích hợp."

msgid "White grass is growing on the floor. It's soft to the touch."
msgstr "Trên sàn mọc cỏ trắng. Sờ vào thấy mềm mịn."

msgid "You can spot some faint shapes in the window."
msgstr "Bạn thấy được trong cửa sổ vài hình thù mờ nhạt."
