msgid "I don't have the brain power for this right now."
msgstr "Bây giờ lại chẳng có não lực để mà giải rồi."

msgid "You know... I could just jump over those boxes and get you the thingy."
msgstr "Biết sao không... Em cứ để tôi leo phắt qua mấy cái thùng lấy cái đồ gì gì đó là được mà."

msgid "Still not interested?"
msgstr "Vẫn không thèm nhờ hả?"

msgid "Ask Sai to get the shiny?"
msgstr "Nhờ Sai lấy giùm cái sáng bóng chứ?"

msgctxt "events.Ch1_Facility_B2F_Hallway_West.event_react_fail_puzzle.choice.Ask Sai to get the shiny?"
msgid "Yes"
msgstr "Nhờ"

msgctxt "events.Ch1_Facility_B2F_Hallway_West.event_react_fail_puzzle.choice.Ask Sai to get the shiny?"
msgid "No"
msgstr "Thôi"

msgid "Alright... knock yourself out."
msgstr "Được rồi... triển đi anh."

msgid "Be right back!"
msgstr "Đợi tí ra ngay!"

msgid "Moments later..."
msgstr "Mấy lát sau..."

msgid "Easy peasy."
msgstr "Dễ ẹc."

msgid "Still not interested."
msgstr "Vẫn không thèm."

msgid "No, I want to do it myself."
msgstr "Không, tôi muốn tự làm cơ."

msgid "The key fits!"
msgstr "Chìa vừa rồi!"

msgid "Nothing happens."
msgstr "Không gì xảy ra hết."

msgid "An elevator door."
msgstr "Cánh cửa thang máy."

msgid "There's a massive gap on the floor. You can't reach the door."
msgstr "Dưới sàn có chỗ hổng to. Bạn không bắt đến cánh cửa được."

msgid "The plank allows you to cross freely."
msgstr "Tấm ván cho phép bạn băng qua thoải mái."

msgid "I've seen another hole that could use a plank like this..."
msgstr "Mình có nhìn thấy chỗ cái hố khác có thể bắc tấm ván thế này được."

msgid "Move the plank to the other hole?"
msgstr "Di chuyển tấm ván tới cái hố chỗ kia chứ?"

msgctxt "events.Ch1_Facility_B2F_Hallway_West.misc_unreachable_door.choice.Move the plank to the other hole?"
msgid "Yes"
msgstr "Di chuyển"

msgctxt "events.Ch1_Facility_B2F_Hallway_West.misc_unreachable_door.choice.Move the plank to the other hole?"
msgid "No"
msgstr "Thôi"

msgid "Uugh... This is really heavy..."
msgstr "Ưưư... Cái này nặng thật đấy..."

msgid "Hey, let me carry that."
msgstr "Ê, để tôi mang giùm cho."

msgid "Since you removed the plank, you can't cross anymore."
msgstr "Vì bạn đã lấy tấm ván đi rồi, bạn không thể băng qua được nữa."

msgid "It's locked."
msgstr "Bị khóa rồi."
