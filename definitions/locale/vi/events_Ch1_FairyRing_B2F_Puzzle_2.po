msgid "Can we do this?"
msgstr "Tụi mình qua cái này được không?"

msgid "Yes, I think so."
msgstr "Được, tôi thấy qua được."

msgid "At least we haven't seen the bodies of the fairies around..."
msgstr "Ít nhất vẫn chưa thấy thân của mấy con yêu tinh đâu đây cả..."

msgid "A fairy head, or something."
msgstr "Cái đầu yêu tinh, hay gì đó."

msgid "It has both nostrils and a mouth..."
msgstr "Nó có cả lỗ mũi và miệng..."

msgid "It has both eyes and a mouth..."
msgstr "Nó có cả mắt và miệng..."

msgid "This one has nostrils AND a mouth."
msgstr "Con này có CẢ lỗ mũi và miệng."

msgid "This one has both eyes AND a mouth."
msgstr "Con này có CẢ mắt và miệng."

msgid "Does it mean it can see both in front and to the sides?"
msgstr "Nghĩa là nó thấy được cả đằng trước lẫn sang ngang luôn à?"
