msgid "There's some red lipstick."
msgstr "Có thỏi son môi đỏ nào đó."

msgid "I wonder if I can use something like this to draw the symbol..."
msgstr "Không biết mình dùng cái như thế này vẽ biểu tượng có được không..."

msgid "Take ${item:ch1.lipstick}?"
msgstr "Lấy ${item:ch1.lipstick} chứ?"

msgid "Yes"
msgstr "Lấy"

msgid "No"
msgstr "Thôi"

msgid "A bathtub."
msgstr "Cái bồn tắm."

msgid "A relaxing bathtub."
msgstr "Cái bồn tắm để thư giãn."

msgid "The drawer contains various toiletries."
msgstr "Ngăn kéo chứa các loại đồ tẩy rửa và trang điểm."

msgid "The drawer contains a hair dryer and other appliances."
msgstr "Ngăn kéo chứa máy sấy tóc và các đồ dùng khác."

msgid "It's just you."
msgstr "Chỉ là bạn mà thôi."

msgid "Even in the bathroom, there are plants."
msgstr "Ngay cả trong phòng tắm cũng có cây."

msgid "This one is fake, though."
msgstr "Mà cây này là giả thôi."

msgid "A plant."
msgstr "Cái cây."

msgid "Soap, shampoo, conditioner."
msgstr "Xà-phòng, dầu gội đầu, dầu xả."

msgid "Some towels and a laundry basket."
msgstr "Vài cái khăn tắm và cái giỏ đựng quần áo."

msgid "A stool."
msgstr "Cái ghế đẩu."

msgid "Thankfully, there's plenty of toilet paper."
msgstr "May thay, có đầy đủ giấy vệ sinh đây."

msgid "Toilet paper."
msgstr "Giấy vệ sinh."

msgid "A towel."
msgstr "Tấm khăn lau."

msgid "A trash can."
msgstr "Cái sọt rác."

msgid "Nothing but air fills this trash can."
msgstr "Chẳng có gì ngoài không khí chứa đầy cái sọt rác này."
