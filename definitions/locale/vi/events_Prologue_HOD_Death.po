msgid "A beheaded corpse."
msgstr "Xác chết bị chém lìa đầu."

msgid "Saki's beheaded corpse lies here."
msgstr "Xác chết bị chém lìa đầu của Saki đang nằm lăn lóc."

msgctxt "events.Prologue_HOD_Death.chr_girl1.dlg.kat"
msgid "..."
msgstr "..."

msgid "That can't be..."
msgstr "Làm sao... mà lại... như thế này..."

msgid "How is this possible?"
msgstr "Lẽ nào mà lại như vầy được?"

msgid "I just saw her a while ago..."
msgstr "Ít lúc trước mới còn gặp nó mà..."

msgid "I-I don't understand..."
msgstr "Mình... mình không hiểu nổi..."

msgid "A bloody corpse. The lower half is missing."
msgstr "Xác chết bê bết máu. Nửa thân dưới đã không còn."

msgid "Juli's bloody corpse. Her lower half is missing."
msgstr "Xác chết bê bết máu của Juli. Nửa thân dưới đã không còn."

msgctxt "events.Prologue_HOD_Death.chr_girl2.dlg.kat"
msgid "..."
msgstr "..."

msgid "I..."
msgstr "Tại..."

msgid "This is my fault..."
msgstr "Tại mình cả..."

msgid "A bloody corpse."
msgstr "Xác chết bê bết máu."

msgid "Kaya's bloody corpse."
msgstr "Xác chết bê bết máu của Kaya."

msgid "Oh no no no no no..."
msgstr "Không không không không không không..."

msgid "Oh my god."
msgstr "Trời ơi là trời."

msgid "This can't be real... It's not real..."
msgstr "Không thể là thật được... đây không phải là sự thật được..."

msgid "Right...?"
msgstr "Phải không...?"

msgid "...The door..."
msgstr "...Cánh cửa..."

msgid "I can... leave...?"
msgstr "Mình có thể... đi ra...?"

msgid "I can... go home...?"
msgstr "Mình có thể... về nhà...?"

msgid "I don't want to die..."
msgstr "Mình không muốn chết..."

msgid "Why not? Everybody should try it at least once."
msgstr "Sao lại không nhỉ? Ai cũng nên thử một lần cho biết."

msgid "Right."
msgstr "Phải rồi."

msgid "...It doesn't light up..."
msgstr "...Bật lửa không soi sáng được..."

msgid "It's as if this place isn't dark... it's just black..."
msgstr "Cứ như thể nơi này không phải là tối... chỗ này thực sự có màu đen kịt luôn ấy..."

msgid "That's not going to help."
msgstr "Thế chẳng được việc gì đâu."

msgid "Unfortunately, the door has no keyhole."
msgstr "Không may thay, cánh cửa này không có lỗ khóa."

msgid "Blood."
msgstr "Là máu."

msgid "Blood puddles."
msgstr "Là vũng máu."

msgctxt "events.Prologue_HOD_Death.misc_blood_2.dlg.kat"
msgid "..."
msgstr "..."

msgid "There's no door here."
msgstr "Ở đây không có cửa."

msgid "I cant... go back..."
msgstr "Không... quay lại được..."

msgid "A welcoming door."
msgstr "Cánh cửa trông như đang mời gọi."

msgid "It's locked."
msgstr "Bị khóa rồi."

msgctxt "events.Prologue_HOD_Death.move_exit.dlg.kat"
msgid "..."
msgstr "..."

msgid "I... have to..."
msgstr "Phải ra..."

msgid "...get out..."
msgstr "...khỏi đây..."
