msgid "A heavy-looking door."
msgstr "Cánh cửa trông nặng nề."

msgid "Are we underwater...?"
msgstr "Mình đang ở dưới nước à...?"

msgid "Looks like it."
msgstr "Có vẻ là thế."

msgid "The other side seems flooded."
msgstr "Ở phía bên kia có vẻ bị chìm trong nước."

msgid "Nothing happens."
msgstr "Không gì xảy ra hết."

msgid "An elevator door."
msgstr "Cánh cửa thang máy."

msgid "There are stairs that go further down, but it's completely flooded."
msgstr "Có các bậc thang đi xuống nữa, nhưng dưới đó hoàn toàn bị ngập rồi."
