msgid "Are you sure you'll be okay?"
msgstr "Anh chắc là không sao đấy chứ?"

msgid "Yeah for sure!"
msgstr "Ừ chắc mà!"

msgid "Tip top shape."
msgstr "Thể trạng đỉnh của chóp."

msgid "..."
msgstr "..."

msgid "Take your time."
msgstr "Cứ thong thả đi em."

msgid "I mean... it's not like I'm bleeding out or anything."
msgstr "Tôi thì... không có chuyện tôi kiệt huyết hay gì đâu."

msgid "(I need to find an exit fast.)"
msgstr "(Mình cần tìm đường thoát mau.)"

msgid "Sai is not moving."
msgstr "Sai không động đậy."

msgid "She's back..... She's back."
msgstr "Nó quay lại rồi..... Nó quay lại rồi."

msgid "She's singing in my ears....."
msgstr "Cái con đó đang hát vào tai ta....."

msgid "Singing all the time....."
msgstr "Hát hoài hát miết..."

msgid "Humming..."
msgstr "Ngưm nga..."

msgid "Burning..."
msgstr "Thiêu đốt..."

msgid "Oh no... burning...."
msgstr "Trời ơi... thiêu đốt....."

msgid "Hahahahaha....."
msgstr "Hahahahaha....."

msgid "Burning."
msgstr "Thiêu đốt."
