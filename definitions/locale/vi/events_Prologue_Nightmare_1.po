msgid "Interestingly, there's no keyhole on this side."
msgstr "Thú vị thay, đằng bên này không có lỗ khóa."

msgid "A paper slip with some rules and regulations."
msgstr "Mảnh giấy có ghi mấy dòng nội quy trường."

msgid ""
"\"No running in the hallways.\n"
"No screaming during recess.\n"
"No escaping, ever.\""
msgstr ""
"\"Không được chạy trong hành lang.\n"
"Không được hét trong giờ nghỉ.\n"
"Không được bỏ trốn, nghe chưa?\""

msgid "\"Classroom 4-A\""
msgstr "\"Lớp 4-A\""

msgid "\"Classroom 56-W\""
msgstr "\"Lớp 56-W\""

msgid "It's too dark to see anything on the other side."
msgstr "Tối quá bên phía kia chả thấy gì."

msgid "Huh? What's this?"
msgstr "Ủa? Chỗ này là?"

msgid "Am I back at the school already?"
msgstr "Quay trở lại trường rồi sao?"

msgid "Let's have some fun, shall we? Entertain me for a while, and in return you get..."
msgstr "Tiêu khiển tí chứ nhể? Hãy khiến cho tao vui vẻ trong chốc lát, và đổi lại tao sẽ cho mày..."

msgid "Nothing."
msgstr "không được gì hết."

msgid "Huh?"
msgstr "Hở?"

msgid "Who's talking...?"
msgstr "Ai nói đấy...?"

msgid "The door won't open. It seems to be locked."
msgstr "Cửa không mở được. Có vẻ bị khóa rồi."
