msgid "That entrance... wasn't there before."
msgstr "Cái lối vào này... nãy đâu có."

msgid "Is it underground?"
msgstr "Đây là xuống đường hầm à?"

msgid "There's another signpost here. It's loose, so it can be rotated."
msgstr "Ở đây có tấm biển chỉ đường khác. Nó bị long, nên có thể xoay được."

msgid "Alright, I think I understand."
msgstr "Được, mình nghĩ mình hiểu rồi."

