msgid "This illusion should break apart now, shouldn't it?"
msgstr "Cái ảo ảnh này giờ sẽ tan vỡ thôi chứ nhỉ?"

msgid "Too bad, I was starting to like this place."
msgstr "Tệ quá, tôi lại bắt đầu thích nơi này rồi cơ."

msgctxt "events.Ch1_MK_Livingroom.event_ending_12.dlg.lacie"
msgid "..."
msgstr "..."

msgid "That's probably not good..."
msgstr "Thế hẳn là không tốt rồi..."

msgid "Did you see that? The painting opened its eyes!"
msgstr "Em có thấy không? Cái bức tranh nó mở mắt ra rồi!"

msgid "Um... did you burn the things in the right order?"
msgstr "Ừm... em có đốt mấy món đồ đúng thứ tự không đấy?"

msgid "I... think... so?"
msgstr "Có... lẽ... thế?"

msgid "Did I do something wrong...?"
msgstr "Mình làm gì sai rồi à...?"

msgid "Was the illusion supposed to LITERALLY break apart?"
msgstr "Cái ảo ảnh này phải tan vỡ THEO ĐÚNG NGHĨA ĐEN á?"

msgid "I don't know...!"
msgstr "Tôi không biết...!"

msgid "Maybe we should leave..."
msgstr "Có khi ta nên đi thôi..."

msgid "Oh crap, the doors are gone!"
msgstr "Thôi vãi, mấy cái cửa biến mất rồi!"

msgid "What do I do...? I need to get out of here!"
msgstr "Làm gì đây...? Cần ra khỏi chỗ này!"

msgid "Hey, be careful."
msgstr "Ê, coi chừng."

msgid "....."
msgstr "....."

msgctxt "events.Ch1_MK_Livingroom.event_ending_12.dlg.lacie"
msgid "(My foot... it hurts...!)"
msgstr "(Chân mình... đau quá...!)"

msgid "(Where are we...?)"
msgstr "(Ta ở đâu rồi đây...?)"

msgid "We need to find a way out..."
msgstr "Ta cần tìm đường ra..."

msgid "Yeahh.... WELL..."
msgstr "Ừừ... THÌ..."

msgid "About that..."
msgstr "Về vụ đó..."

msgid "I..."
msgstr "Tôi..."

msgid "...might have landed on something hard."
msgstr "...có khi là bị đáp lên cái gì đó cứng rồi."

msgid "Doesn't look great."
msgstr "Trông không tuyệt lắm."

msgid "...W-what do we do...?"
msgstr "...L-Làm sao đây trời...?"

msgid "If you can still move, go on ahead."
msgstr "Nếu em vẫn cử động được, đi trước đi."

msgid "I need a moment."
msgstr "Tôi cần một lát."

msgid "O-okay..."
msgstr "Đ-Được rồi..."

msgid "Uh... hey..."
msgstr "Ờ... ê..."

msgid "You'll uh.... You'll come back, right?"
msgstr "Em sẽ ờ... Em sẽ quay lại, phải không?"

msgid "Yes."
msgstr "Sẽ quay lại."

msgid "Thanks."
msgstr "Cám ơn."

msgid "(Where am I...?)"
msgstr "(Mình đang ở đâu...?)"

msgid "I need to find a way out..."
msgstr "Cần tìm đường ra..."

msgid "This item is yet to be unsealed."
msgstr "Món đồ này chưa được giải phong ấn."

msgid "The fire needs to be lit first."
msgstr "Cần phải nhóm lửa lên cái đã."

msgid "Light the fireplace?"
msgstr "Nhóm lò sưởi lên chứ?"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.Light the fireplace?"
msgid "Yes"
msgstr "Nhóm"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.Light the fireplace?"
msgid "No"
msgstr "Thôi"

msgid "I don't have all 5 items ready to burn yet..."
msgstr "Mình chưa có hết 5 món đồ sẵn sàng mà đốt..."

msgid "If I light this on, I'll just lure that lady here for no reason."
msgstr "Nếu nhóm lửa lên thì chỉ có mà vô duyên vô cớ nhử bà cô đó lại đây thôi."

msgid "(What should I burn first?)"
msgstr "(Mình nên đốt cái gì trước đây?)"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.(What should I burn first?)"
msgid "The knife"
msgstr "Con dao"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.(What should I burn first?)"
msgid "The foot"
msgstr "Cái chân"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.(What should I burn first?)"
msgid "The sketchbook"
msgstr "Cuốn vở phác thảo"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.(What should I burn first?)"
msgid "The mirror"
msgstr "Chiếc gương"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.(What should I burn first?)"
msgid "The cold compress"
msgstr "Cái khăn chườm lạnh"

msgid "(What should I burn next?)"
msgstr "(Mình nên đốt cái gì tiếp đây?)"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.(What should I burn next?)"
msgid "The knife"
msgstr "Con dao"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.(What should I burn next?)"
msgid "The foot"
msgstr "Cái chân"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.(What should I burn next?)"
msgid "The sketchbook"
msgstr "Cuốn vở phác thảo"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.(What should I burn next?)"
msgid "The mirror"
msgstr "Chiếc gương"

msgctxt "events.Ch1_MK_Livingroom.item_lighter_on_fireplace.choice.(What should I burn next?)"
msgid "The cold compress"
msgstr "Cái khăn chườm lạnh"

msgid "And finally... the knife."
msgstr "Và cuối cùng là... con dao."

msgid "And finally... the foot."
msgstr "Và cuối cùng là... cái chân."

msgid "And finally... the sketchbook."
msgstr "Và cuối cùng là... cuốn vở phác thảo."

msgid "And finally... the mirror."
msgstr "Và cuối cùng là... chiếc gương."

msgid "And finally... the cold compress."
msgstr "Và cuối cùng là... cái khăn chườm lạnh."

msgid "Take ${item:ch1.lockpick}?"
msgstr "Lấy ${item:ch1.lockpick} chứ?"

msgctxt "events.Ch1_MK_Livingroom.item_lockpick_get.choice.Take ${item:ch1.lockpick}?"
msgid "Yes"
msgstr "Lấy"

msgctxt "events.Ch1_MK_Livingroom.item_lockpick_get.choice.Take ${item:ch1.lockpick}?"
msgid "No"
msgstr "Thôi"

msgid "You pour some liquid onto the rag..."
msgstr "Bạn rót chút chất lỏng lên miếng giẻ..."

msgid "It's already wet enough."
msgstr "Nó ướt đủ rồi."

msgid "\"Alcohol tastes just like water.\""
msgstr "\"Rượu có vị y như nước vậy.\""

msgctxt "events.Ch1_MK_Livingroom.item_water_on_plant4.dlg.narrator"
msgid "\"Thank you.\""
msgstr "\"Cảm ơn nhé.\""

msgctxt "events.Ch1_MK_Livingroom.item_water_on_plant4.dlg.narrator"
msgid "(You watered the plant.)"
msgstr "(Bạn tưới nước cho cái cây.)"

msgid "(You pour water into the empty pot...)"
msgstr "(Bạn rót nước vào cái chậu trống...)"

msgid "(...but nothing happens.)"
msgstr "(...nhưng không gì xảy ra cả.)"

msgctxt "events.Ch1_MK_Livingroom.item_water_on_plants.dlg.narrator"
msgid "(You watered the plant.)"
msgstr "(Bạn tưới nước cho cái cây.)"

msgid "Various useless trinkets are displayed on these shelves."
msgstr "Trên mấy cái kệ này trưng bày đủ thứ đồ vặt vô tích sự."

msgid "A teapot, full of some liquid. Seems to be water."
msgstr "Cái ấm trà, có đầy chất lỏng. Có vẻ là nước."

msgid "I could use this..."
msgstr "Cái này có khi dùng được..."

msgid "Bring water to the plant?"
msgstr "Mang nước tới chỗ cái cây chứ?"

msgctxt "events.Ch1_MK_Livingroom.misc_cart.choice.Bring water to the plant?"
msgid "Yes"
msgstr "Mang đi"

msgctxt "events.Ch1_MK_Livingroom.misc_cart.choice.Bring water to the plant?"
msgid "No"
msgstr "Thôi"

msgctxt "events.Ch1_MK_Livingroom.misc_cart.dlg.narrator"
msgid "\"Thank you.\""
msgstr "\"Cảm ơn nhé.\""

msgctxt "events.Ch1_MK_Livingroom.misc_fireplace.dlg.narrator"
msgid "A fireplace."
msgstr "Cái chỗ nhóm lửa."

msgid "There's no fire, so it's just... a place."
msgstr "Không có lửa, nên này chỉ là... cái chỗ không thôi."

msgid "Haha, good one!"
msgstr "Haha, vui tính đấy em!"

msgctxt "events.Ch1_MK_Livingroom.misc_fireplace.dlg.lacie"
msgid "..."
msgstr "..."

msgid "A place."
msgstr "Cái chỗ."

msgid "An old gramophone."
msgstr "Cái máy hát cũ."

msgid "What to do?"
msgstr "Làm gì đây?"

msgid "Play music"
msgstr "Chơi nhạc"

msgid "Stop the music"
msgstr "Dừng nhạc lại"

msgid "Do nothing"
msgstr "Không làm gì"

msgid "A floor lamp."
msgstr "Cái đèn đứng."

msgid "A rotary phone."
msgstr "Chiếc điện thoại quay số."

msgid "It's old... but there's a certain charm to it."
msgstr "Nó cũ rồi... nhưng mà lại có sức quyến rũ nào đó."

msgid "There's no dial tone."
msgstr "Không có âm quay số."

msgid "A tall plant."
msgstr "Cái cây cao."

msgid "A tall, pretty plant."
msgstr "Cái cây cao, xinh đẹp."

msgid "An empty flower vase."
msgstr "Cái lọ hoa rỗng không."

msgid "Purple flowers in a vase."
msgstr "Trong lọ có mấy bông hoa màu tía."

msgid "I could use these flowers..."
msgstr "Mấy bông hoa này có khi dùng được..."

msgid "Bring the flowers to the plant?"
msgstr "Mang mấy bông hoa chỗ cái cây chứ?"

msgctxt "events.Ch1_MK_Livingroom.misc_plant1.choice.Bring the flowers to the plant?"
msgid "Yes"
msgstr "Mang đi"

msgctxt "events.Ch1_MK_Livingroom.misc_plant1.choice.Bring the flowers to the plant?"
msgid "No"
msgstr "Thôi"

msgctxt "events.Ch1_MK_Livingroom.misc_plant1.dlg.narrator"
msgid "\"Thank you.\""
msgstr "\"Cảm ơn nhé\""

msgctxt "events.Ch1_MK_Livingroom.misc_plant2.dlg.narrator"
msgid "It's dead."
msgstr "Nó chết rồi."

msgctxt "events.Ch1_MK_Livingroom.misc_plant2.dlg.narrator"
msgid "A plant with a tag attached. It says:"
msgstr "Cái cây có đính tag. Ghi là:"

msgctxt "events.Ch1_MK_Livingroom.misc_plant2.dlg.narrator"
msgid "\"Thank you.\""
msgstr "\"Cảm ơn nhé.\""

msgid "\"It was good while it lasted.\""
msgstr "\"Tiệc còn thì vui, xong tiệc hùi hụi.\""

msgid "\"Requires medium light."
msgstr "\"Yêu cầu ánh sáng vừa."

msgid "For enrichment, provide music.\""
msgstr "Để làm tươi tốt, cung cấp âm nhạc.\""

msgctxt "events.Ch1_MK_Livingroom.misc_plant3.dlg.narrator"
msgid "It's dead."
msgstr "Nó chết rồi."

msgctxt "events.Ch1_MK_Livingroom.misc_plant3.dlg.narrator"
msgid "A plant with a tag attached. It says:"
msgstr "Cái cây có đính tag. Ghi là:"

msgctxt "events.Ch1_MK_Livingroom.misc_plant3.dlg.narrator"
msgid "\"Thank you.\""
msgstr "\"Cảm ơn nhé.\""

msgctxt "events.Ch1_MK_Livingroom.misc_plant3.dlg.narrator"
msgid "\"Requires dim light."
msgstr "\"Yêu cầu ánh sáng mờ."

msgid "Feed it once a day to avoid irritability. Appropriate diet includes meat of various kinds.\""
msgstr "Mỗi ngày cho ăn một lần để tránh bị kích ứng. Khẩu phần thích hợp bao gồm thịt các loại.\""

msgctxt "events.Ch1_MK_Livingroom.misc_plant4.dlg.narrator"
msgid "It's dead."
msgstr "Nó chết rồi."

msgctxt "events.Ch1_MK_Livingroom.misc_plant4.dlg.narrator"
msgid "A plant with a tag attached. It says:"
msgstr "Cái cây có đính tag. Ghi là:"

msgctxt "events.Ch1_MK_Livingroom.misc_plant4.dlg.narrator"
msgid "\"Thank you.\""
msgstr "\"Cảm ơn nhé.\""

msgid "\"Requires medium light. Provide alcohol twice daily to keep its leaves moist."
msgstr "\"Yêu cầu ánh sáng vừa. Hằng ngày hai lần cung cấp rượu để giữ cho lá ẩm."

msgid "Water is a valid substitute, as it can't tell the difference.\""
msgstr "Nước là chất thay thế hữu hiệu, vì nó không phân biệt được.\""

msgid "The pot has been destroyed."
msgstr "Cái chậu bị phá hủy rồi."

msgid "An empty pot."
msgstr "Cái chậu trống."

msgctxt "events.Ch1_MK_Livingroom.misc_plant6.dlg.narrator"
msgid "It's dead."
msgstr "Nó chết rồi."

msgctxt "events.Ch1_MK_Livingroom.misc_plant6.dlg.narrator"
msgid "A plant with a tag attached. It says:"
msgstr "Cái cây có đính tag. Ghi là:"

msgctxt "events.Ch1_MK_Livingroom.misc_plant6.dlg.narrator"
msgid "\"Thank you.\""
msgstr "\"Cảm ơn nhé.\""

msgctxt "events.Ch1_MK_Livingroom.misc_plant6.dlg.narrator"
msgid "\"Requires dim light."
msgstr "\"Yêu cầu ánh sáng mờ."

msgid "For enrichment, give it a flower crown once a month.\""
msgstr "Để làm tươi tốt, mỗi tháng đưa miện hoa một lần.\""

msgid "A warning sign."
msgstr "Cái biển cảnh báo."

msgid "It doesn't say what the warning is for."
msgstr "Nó không nói là cảnh báo cái gì."
