msgid "Dozens of books are neatly organized on the shelves."
msgstr "书架上整齐地摆放着好几十本书。"

msgctxt "events.Ch1_Library_Doorknob.misc_books_1.choice"
msgid "An untitled book stands out. Read a passage?"
msgstr "一本无题之书很显眼。要读一段吗？"

msgctxt "events.Ch1_Library_Doorknob.misc_books_1.choice.An untitled book stands out. Read a passage?"
msgid "Yes"
msgstr "是"

msgctxt "events.Ch1_Library_Doorknob.misc_books_1.choice.An untitled book stands out. Read a passage?"
msgid "No"
msgstr "否"

msgid "Variations of rituals ______carefully documented ______ recipient."
msgstr "仪式的各种变体______详尽记录了______收件人。"

msgid "Any human that enters ______ by way of a ritual is carefully tracked."
msgstr "任何通过仪式进入______的人类都会被精确定位。"

msgid "No accounts of humans infiltrating by their own means exist, _________ easily detected."
msgstr "没有任何关于人类通过自己的方式进行渗透的记载，_________很容易被检测。"

msgctxt "events.Ch1_Library_Doorknob.misc_books_2.choice"
msgid "An untitled book stands out. Read a passage?"
msgstr "一本无题之书很显眼。要读一段吗？"

