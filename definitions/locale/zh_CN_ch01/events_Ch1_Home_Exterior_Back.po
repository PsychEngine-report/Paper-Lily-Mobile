msgid "A potted plant."
msgstr "一株盆栽植物。"

msgid "A potted plant. This one is called Lucardo."
msgstr "一株盆栽植物。这株叫卢卡多。"

msgctxt "events.Ch1_Home_Exterior_Back.misc_pottedplant_3.dlg.narrator"
msgid "A potted plant."
msgstr "一株盆栽植物。"

msgid "A nice table."
msgstr "一张好桌子。"

msgid "A tree."
msgstr "一棵树。"
