msgid "A slot to place a valve wheel. The indentation has a star shape."
msgstr "用于放置阀轮的槽位。凹痕呈星形。"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_3.choice"
msgid "Turn it?"
msgstr "要打开吗？"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_3.choice.Turn it?"
