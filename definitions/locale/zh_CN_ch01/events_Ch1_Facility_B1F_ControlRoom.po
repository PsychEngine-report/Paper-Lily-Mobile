msgid "Turn it?"
msgstr "要打开吗？"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_1.choice.Turn it?"
msgid "Turn the wheel"
msgstr "转动阀轮"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_1.choice.Turn it?"
msgid "Remove the wheel"
msgstr "移除阀轮"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_1.choice.Turn it?"
msgid "Do nothing"
msgstr "什么也不做"

