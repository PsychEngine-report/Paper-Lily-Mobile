msgid "The wheel won't turn."
msgstr "阀轮转不动了。"

msgctxt "events.Ch1_Facility_B1F_ControlRoom.misc_valve_1.dlg.narrator"
msgid "It won't turn anymore."
msgstr "它转不动了。"

msgid "A slot to place a valve wheel. The indentation has a pentagon shape."
msgstr "用于放置阀轮的槽位。凹痕呈五边形。"

