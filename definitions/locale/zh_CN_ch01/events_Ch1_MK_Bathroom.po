msgid "No"
msgstr "否"

msgid "\"Thank you.\""
msgstr "“谢谢你。”"

msgid "A shelf. Nothing of interest."
msgstr "一个架子。没什么有趣的。"

msgid "A bathtub filled with a black liquid."
msgstr "一个装满黑色液体的浴缸。"

msgid "It's so big... you could fit like... four of me in there."
msgstr "好大...大得可以装下...四个我。"

msgid "Check if there's anything useful inside?"
msgstr "要找找里面有用的东西吗？"

msgctxt "events.Ch1_MK_Bathroom.misc_tub.choice.Check if there's anything useful inside?"
msgid "Yes"
msgstr "是"

msgctxt "events.Ch1_MK_Bathroom.misc_tub.choice.Check if there's anything useful inside?"
msgid "No"
msgstr "否"

msgid "A beautiful night sky."
msgstr "美丽的夜空。"

msgid "Three moons... ?"
msgstr "有三个月亮... ？"
