msgid "Are you sure you'll be okay?"
msgstr "你确定你没事吗？"

msgid "Yeah for sure!"
msgstr "当然！"

msgid "Tip top shape."
msgstr "正处于最佳状态。"

msgid "..."
msgstr "..."

msgid "Take your time."
msgstr "别着急。"

msgid "I mean... it's not like I'm bleeding out or anything."
msgstr "我的意思是...我还没失血过多呢。"

msgid "(I need to find an exit fast.)"
msgstr "（我需要赶紧找到出口。）"

msgid "Sai is not moving."
msgstr "赛伊不动了。"

msgid "She's back..... She's back."
msgstr "她回来了......她回来了。"

msgid "She's singing in my ears....."
msgstr "她在我的耳内吟唱......"

msgid "Singing all the time....."
msgstr "无时无刻吟唱着......"

msgid "Humming..."
msgstr "哼唱着..."

msgid "Burning..."
msgstr "燃烧着..."

msgid "Oh no... burning...."
msgstr "哦不...燃烧着..."

msgid "Hahahahaha....."
msgstr "哈哈哈哈哈......"

msgid "Burning."
msgstr "燃烧着。"
