msgid "There's no boat."
msgstr "Човен зник."

msgid "Only red."
msgstr "Все червоне."

msgid "A red rabbit."
msgstr "Червоний кролик."

msgid "It's not breathing."
msgstr "Він не дихає."

msgid "The crow that was here is gone."
msgstr "Ґава зникла."

msgid "Wooden logs stick out from the bloody water."
msgstr "З кривавої води стирчать дерев'яні стовпи."

msgid "A note is attached to the tree. It says:"
msgstr "До дерева прикріплена записка. У ній написано:"

msgid ""
"\"THE MONSTER\n"
"LOVED MEAT\n"
"HATED WATER\""
msgstr ""
"\"ЧУДОВИСЬКО\n"
"ЛЮБИЛО М'ЯСО\n"
"НЕНАВИДІЛО ВОДУ\""

msgid "The way to the temple is sealed off."
msgstr "Шлях до храму закрився."

msgid "Nothing but trees here."
msgstr "Нічого, окрім дерев."

msgid "The way back seems to be gone."
msgstr "Шлях назад зник."

msgid "This way is closed off by trees."
msgstr "Цей шлях закритий деревами."
