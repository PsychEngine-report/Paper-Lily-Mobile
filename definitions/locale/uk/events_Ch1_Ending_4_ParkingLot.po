msgid "What seems like a trash bag."
msgstr "Схоже на мішок зі сміттям."

msgid "It has dust all over."
msgstr "Він весь у пилу."

msgid "A wooden crate."
msgstr "Дерев'яний ящик."

msgid "A bus. It doesn't seem to have been used in a long time."
msgstr "Автобус. Схоже, ним давно ніхто не користувався."

msgid "There's another bus stacked on top of it."
msgstr "Зверху на ньому стоїть ще один автобус."

msgid "A broken bus is stacked on top of it."
msgstr "Зверху на ньому стоїть побитий автобус."

msgid "A keypad."
msgstr "Кодова панель."

msgid "It doesn't seem to be working."
msgstr "Не схоже, що вона працює."

msgid "Touch some buttons?"
msgstr "Доторкнутися до кнопок?"

msgid "Yes"
msgstr "Так"

msgid "No"
msgstr "Ні"

msgid "The keypad does not respond in any way."
msgstr "Панель ніяк не реагує."

msgid "Looks like a mailbox."
msgstr "Схоже на поштову скриньку."

msgid "There's no mail right now."
msgstr "Пошти немає."

msgid "A small light. It changes colors every few seconds."
msgstr "Невелика лампочка. Кожні декілька секунд вона змінює колір."

msgid "Strange street signs fill the walls."
msgstr "По стінах розвішані дивні дорожні знаки."

msgid "A garage door."
msgstr "Двері гаража."

msgid "Can I get this open somehow?"
msgstr "Чи вдасться їх якось відчинити?"
