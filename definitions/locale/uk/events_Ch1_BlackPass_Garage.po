msgid "It's here!"
msgstr "Знайшла!"

msgid "What was that...?"
msgstr "Що це було?.."

msgid "It's not here."
msgstr "Він не тут."

msgid "Nothing else of interest."
msgstr "Нічого цікавого."

msgid "The garage door is missing. It's just a wall here."
msgstr "Тут не вистачає дверей гаража. Замість них тут тільки стіна."

msgid "There's nothing else to do here."
msgstr "Тут більше нічого робити."

msgid "It won't open!"
msgstr "Не відчиняється!"
