msgid "Climb back up?"
msgstr "Залізти назад?"

msgid "Yes"
msgstr "Так"

msgid "No"
msgstr "Ні"

msgid "There's no need to go this way."
msgstr "Немає потреби йти цим шляхом."

msgid "Walk down the train tracks in this direction?"
msgstr "Піти по рейках в цьому напрямі?"

msgid "Is it just me or the path is getting narrower...?"
msgstr "Мені здається, або рейки стають вужче?.."

msgid "Wait... no!!!"
msgstr "Заждіть… ні!!!"
