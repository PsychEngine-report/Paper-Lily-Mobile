msgid "It's just a flipped version of the other one..."
msgstr "Це ж просто віддзеркалена версія іншої картини..."

msgid "It's not strong enough to cut through this. It must be reinforced somehow."
msgstr "Ним це не проріжеш. Ці двері, мабуть, якось укріплені."

msgid "There's a pair of scissors here."
msgstr "Тут лежать ножиці."

msgid "Take ${item:ch1.scissors}?"
msgstr "Взяти предмет: ${item:ch1.scissors}?"

msgid "Yes"
msgstr "Так"

msgid "No"
msgstr "Ні"

msgid "You have a bad feeling about this. Are you sure?"
msgstr "У вас погане передчуття. Ви точно впевнені?"

msgid "These scissors can't cut through metal."
msgstr "Цими ножицями не проріжеш метал."

msgid "An abstract painting."
msgstr "Абстрактна картина."

msgid "An entrance to some sort of tunnel. It's locked and doesn't seem to have been opened in a while."
msgstr "Вхід до якогось тунелю. Він зачинений і його, схоже, давно не відчиняли."
