msgid "That doesn't seem like a good idea."
msgstr "Це не дуже слушна думка."

msgid "The hole is big enough."
msgstr "Лаз вже досить великий."

msgid "There's no reason to go back."
msgstr "Немає потреби туди вертатись."

msgid "There's no reason to do that."
msgstr "Немає потреби це робити."

msgid "There's a gate nearby!"
msgstr "Ворота вже поруч!"

msgid "There's quite a bit of blood in this spot."
msgstr "Тут досить багато крові."

msgid "Someone's remains. You can't tell whether they're human or not."
msgstr "Чиїсь рештки. Незрозуміло, чи вони людські, чи ні."

msgid "I'd rather not go back in there."
msgstr "Мені не дуже хочеться туди вертатись."

msgid "The grass is definitely greener on this side."
msgstr "З цього боку трава зеленіша."

msgid "A fence blocks your path."
msgstr "Огорожа заважає вам пройти."

msgid "Use ${item:ch1.forest_bolt_cutter}?"
msgstr "Скористатися предметом: ${item:ch1.forest_bolt_cutter}?"

msgid "Yes"
msgstr "Так"

msgid "No"
msgstr "Ні"

msgid "A long fence."
msgstr "Висока огорожа."

msgid "There's no way I'm going back in there."
msgstr "Я туди ні за що не повернусь."

msgid "There's a note on the floor:"
msgstr "На землі лежить записка:"

msgid "The petal trail ends here."
msgstr "Стежка с пелюсток обривається тут."

msgid "They didn't make it to the exit..."
msgstr "Комусь не вдалося дістатися виходу..."
