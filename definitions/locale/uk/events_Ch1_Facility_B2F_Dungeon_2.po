msgid "A broken, bloody baseball bat lies next to a skeleton."
msgstr "Поряд зі скелетом лежить розтрощена та покрита кров'ю бейсбольна бита."

msgid "A \"W\" is carved into it."
msgstr "На ній вирізьблена літера \"В\"."

msgid "The door is unreachable."
msgstr "До цих дверей не дотягнутися."

msgid "\"Subject D5. Age: 100-150. Status: Dormant. Awaiting further tests.\""
msgstr "\"Суб'єкт D5. Вік: 100-150. Стан: У сплячці. Очікуються подальші тести.\""

msgid "\"Subject D8. Age: Unknown. Status: Highly active. Awaiting further tests.\""
msgstr "\"Суб'єкт D8. Вік: Невідомий. Стан: Високоактивний. Очікуються подальші тести.\""

msgid "A confinement door. It's locked."
msgstr "Двері камери. Вони зачинені."

msgid "There's something inside..."
msgstr "Там хтось є..."

msgid "Nothing of interest on the desk."
msgstr "На столі немає нічого корисного."

msgid "There's nothing else in the drawer."
msgstr "У шухлядці більше нічого немає."

msgid "There's a valve handle in the drawer."
msgstr "У шухлядці лежить вентиль."

msgid "Take ${item:ch1.facility_handle_diamond}?"
msgstr "Взяти предмет: ${item:ch1.facility_handle_diamond}?"

msgid "Yes"
msgstr "Так"

msgid "No"
msgstr "Ні"

msgid "A hole on the floor."
msgstr "Діра в підлозі."

msgid "(Sai joined your party.)"
msgstr "(Сай приєднується до групи.)"
