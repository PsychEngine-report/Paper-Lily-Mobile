msgid "It's a donation box. The label reads:"
msgstr "É uma caixa de doações. A etiqueta diz:"

msgid "\"All proceeds go towards the construction of a bridge somewhere. We appreciate your donation!\""
msgstr "\"Todo dinheiro vai para a construção de uma ponte em algum lugar. Agradecemos a sua doação!\""

msgid "The lid is loose, and there's a single coin inside."
msgstr "A tampa está solta e há uma única moeda dentro."

msgid "Take the ${item:ch1.coin}?"
msgstr "Pegar a ${item:ch1.coin}?"

msgid "Yes"
msgstr "Sim"

msgid "No"
msgstr "Não"

msgid "The box is now empty."
msgstr "A caixa agora está vazia."
