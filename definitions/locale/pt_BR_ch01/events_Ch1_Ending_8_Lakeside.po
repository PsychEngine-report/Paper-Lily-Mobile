msgid "There's no boat."
msgstr "Não há barco."

msgid "Only red."
msgstr "Apenas vermelho."

msgid "A red rabbit."
msgstr "Um coelho vermelho."

msgid "It's not breathing."
msgstr "Não está respirando."

msgid "The crow that was here is gone."
msgstr "O corvo que estava aqui se foi."

msgid "Wooden logs stick out from the bloody water."
msgstr "Troncos de madeira sobressaem da água ensanguentada."

msgid "A note is attached to the tree. It says:"
msgstr "Uma nota está anexada à árvore. Diz:"

msgid ""
"\"THE MONSTER\n"
"LOVED MEAT\n"
"HATED WATER\""
msgstr ""
"\"O MONSTRO\n"
"CARNE ADORADA\n"
"ÁGUA ODIADA\""

msgid "The way to the temple is sealed off."
msgstr "O caminho para o templo está fechado."

msgid "Nothing but trees here."
msgstr "Nada além de árvores aqui."

msgid "The way back seems to be gone."
msgstr "O caminho de volta parece ter desaparecido."

msgid "This way is closed off by trees."
msgstr "Este caminho é fechado por árvores."
