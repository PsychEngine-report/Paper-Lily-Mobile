msgid "A red tree."
msgstr "Uma árvore vermelha."

msgid "It stands out..."
msgstr "Isso se destaca..."

msgid "Is there anything special about it?"
msgstr "Tem alguma coisa especial nisso?"

msgid "Hmm? There's a paper with something stuck to it."
msgstr "Hmm? Tem um papel com algo preso nele."

msgid "Take ${item:ch1.forest_lockedsite_key}?"
msgstr "Pegar a ${item:ch1.forest_lockedsite_key}?"

msgid "Yes"
msgstr "Sim"

msgid "No"
msgstr "Não"

msgid "(You don't need that key, so it was discarded.)"
msgstr "(Você não precisa dessa chave, então ela foi descartada.)"

msgid "There's also a note taped to the tree."
msgstr "Também tem uma nota presa na árvore com fita adesiva."
