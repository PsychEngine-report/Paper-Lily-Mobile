msgid "There's a paddle here."
msgstr "Tem um remo aqui."

msgid "Take ${item:ch1.forest_paddles}?"
msgstr "Pegar o ${item:ch1.forest_paddles}?"

msgid "Yes"
msgstr "Sim"

msgid "No"
msgstr "Não"

msgid "The pier ends here."
msgstr "O píer acaba aqui."

msgid "Some purple flowers."
msgstr "Algumas flores roxas."

msgid "They're growing abundantly between these rocks."
msgstr "Elas estão crescendo abundantemente entre essas pedras."

msgid "Take some ${item:ch1.lakeside_petals_purple}?"
msgstr "Pegar algumas ${item:ch1.lakeside_petals_purple}?"

msgid "A large structure looms over the lake in the distance."
msgstr "Uma estrutura larga se ergue sobre o lago ao longe."

msgid "What is that place..?"
msgstr "O que é esse lugar?"

msgid "..."
msgstr "..."

msgid "Hmm... I can't see the lighthouse from here."
msgstr "Hmm... Eu não consigo ver o farol daqui."

msgid "It might be beyond those trees."
msgstr "Ele pode estar além dessas árvores."

msgid "Oh well."
msgstr "Ah, bem."
