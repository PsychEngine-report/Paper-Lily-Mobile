msgid "(You plugged in the cable using the adapter.)"
msgstr "(Podłączyłaś kabel za pomocą adaptera.)"

msgid "There's an electrical socket hiding behind the bush."
msgstr "Za krzakiem ukryte jest gniazdko elektryczne."

msgid "The plug and the socket don't match, so you can't plug it in."
msgstr "Wtyczka i gniazdo nie pasują do siebie, więc nie można ich podłączyć."

msgid "I suppose I could try this adapter I found."
msgstr "Być może mogłabym wypróbować ten adapter, który znalazłam."

msgid "Do I need an adapter? That's so weird."
msgstr "Czy potrzebuję adaptera? To takie dziwne."

msgid "The campfire is plugged here."
msgstr "Ognisko jest tu podłączone."

msgid "The cable is plugged in."
msgstr "Kabel jest podłączony."

msgid "\"Red's Treehouse\""
msgstr "\"Domek na drzewie Reda\""

msgid "\"Treehouse\"... sheesh!"
msgstr "\"Domek na drzewie\"... łał!"

msgid "...?"
msgstr "...?"

msgid "The floor here is unusual..."
msgstr "Podłoga w tym miejscu jest jakaś inna…"

msgid "There's a key hidden here."
msgstr "Tutaj ukryty jest klucz."

msgid "Take ${item:ch1.forest_lockedsite_key}?"
msgstr "Wziąć ${item:ch1.forest_lockedsite_key}?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"

msgid "(You don't need that key, so it was discarded.)"
msgstr "(Ten klucz nie jest ci już potrzebny, więc został on wyrzucony.)"

msgid "There's a note as well."
msgstr "Jest też notatka."

msgid "There's nothing else here."
msgstr "Nie ma tu nic więcej."
