msgid "What seems like a trash bag."
msgstr "Wygląda jak worek na śmieci."

msgid "It has dust all over."
msgstr "Cały jest zakurzony."

msgid "A wooden crate."
msgstr "Drewniana skrzynka."

msgid "A bus. It doesn't seem to have been used in a long time."
msgstr "Autobus. Wygląda, jakby od dłuższego czasu nie był używany."

msgid "There's another bus stacked on top of it."
msgstr "Na nim jest ustawiony jeszcze jeden autobus."

msgid "A broken bus is stacked on top of it."
msgstr "Jest na nim ustawiony zepsuty autobus."

msgid "A keypad."
msgstr "Panel z przyciskami."

msgid "It doesn't seem to be working."
msgstr "Wygląda na to, że nie działa."

msgid "Touch some buttons?"
msgstr "Wcisnąć kilka przycisków?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"

msgid "The keypad does not respond in any way."
msgstr "Panel nie reaguje w żaden sposób."

msgid "Looks like a mailbox."
msgstr "Przypomina skrzynkę pocztową."

msgid "There's no mail right now."
msgstr "W tej chwili nie ma żadnej poczty."

msgid "A small light. It changes colors every few seconds."
msgstr "Mała lampka. Zmienia kolory co kilka sekund."

msgid "Strange street signs fill the walls."
msgstr "Ściany są obwieszone dziwnymi znakami ulicznymi."

msgid "A garage door."
msgstr "Brama garażowa."

msgid "Can I get this open somehow?"
msgstr "Czy mogę ją jakoś otworzyć?"
