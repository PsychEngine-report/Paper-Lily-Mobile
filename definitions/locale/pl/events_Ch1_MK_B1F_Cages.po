msgid "The room where you were locked in is directly under you."
msgstr "Pomieszczenie, w którym byłaś zamknięta, znajduje się bezpośrednio pod tobą."

msgid "You can see Sai from here. He doesn't seem to be doing anything."
msgstr "Widać stąd Saia. Nie wygląda na to, żeby cokolwiek robił."

msgid "Empty bird cages."
msgstr "Puste klatki dla ptaków."

msgid "There seems to be something strange inside the cage."
msgstr "Zdaje się, że w klatce leży coś dziwnego."

msgid "Try to get ${item:ch1.mk_hand_mirror}?"
msgstr "Spróbować sięgnąć po ${item:ch1.mk_hand_mirror}?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"

msgid "There's nothing else in there."
msgstr "W środku już nic nie ma."

msgid "The painting lady is gone."
msgstr "Kobieta z obrazu zniknęła."

msgid "A painting of a lady."
msgstr "Portret kobiety."

msgid "Her golden eye stands out..."
msgstr "Jej złote oko się wyróżnia..."

msgid "Pull it out?"
msgstr "Wyciągnąć je?"

msgid "(You don't need an extra eye, so you discarded it.)"
msgstr "(Nie potrzebujesz dodatkowego oka, więc je porzuciłaś.)"

msgid "Some abstract paintings."
msgstr "Niektóre abstrakcyjne obrazy."
