msgid "That doesn't seem like a good idea."
msgstr "To raczej nie jest najlepszy pomysł."

msgid "The hole is big enough."
msgstr "Dziura jest już wystarczająco duża."

msgid "There's no reason to go back."
msgstr "Nie masz po co wracać."

msgid "There's no reason to do that."
msgstr "Nie masz po co tego robić."

msgid "There's a gate nearby!"
msgstr "W pobliżu jest furtka!"

msgid "There's quite a bit of blood in this spot."
msgstr "W tym miejscu jest dosyć sporo krwi."

msgid "Someone's remains. You can't tell whether they're human or not."
msgstr "Czyjeś szczątki. Trudno powiedzieć, czy ludzkie."

msgid "I'd rather not go back in there."
msgstr "Wolałabym tam nie wracać."

msgid "The grass is definitely greener on this side."
msgstr "Trawa zdecydowanie jest o wiele źeleńsza po tej stronie."

msgid "A fence blocks your path."
msgstr "Ogrodzenie uniemożliwia ci przejście."

msgid "Use ${item:ch1.forest_bolt_cutter}?"
msgstr "Użyć ${item:ch1.forest_bolt_cutter}?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"

msgid "A long fence."
msgstr "Długie ogrodzenie."

msgid "There's no way I'm going back in there."
msgstr "Za żadne skarby tam nie wracam."

msgid "There's a note on the floor:"
msgstr "Na ziemi leży notatka:"

msgid "The petal trail ends here."
msgstr "Ślad płatków się tutaj urywa."

msgid "They didn't make it to the exit..."
msgstr "Nie udało mu się dotrzeć do wyjścia..."
