msgid "A heavy-looking door."
msgstr "Toporne drzwi."

msgid "Are we underwater...?"
msgstr "Czy jesteśmy pod wodą...?"

msgid "Looks like it."
msgstr "Na to wygląda."

msgid "The other side seems flooded."
msgstr "Druga strona wydaje się być zalana."

msgid "Nothing happens."
msgstr "Nic się nie dzieje."

msgid "An elevator door."
msgstr "Drzwi do windy."

msgid "There are stairs that go further down, but it's completely flooded."
msgstr "Schody prowadzą niżej, ale są całkowicie zalane."
