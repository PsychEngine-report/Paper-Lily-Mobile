msgid "A little cactus."
msgstr "Mały kaktus."

msgid "An empty flower vase."
msgstr "Pusty wazon na kwiaty."

msgid "Pink flowers in a vase."
msgstr "Różowe kwiaty w wazonie."

msgid "I could use these flowers..."
msgstr "Mogłabym ich użyć..."

msgid "Bring the flowers to the plant?"
msgstr "Przynieść kwiaty roślinie?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"

msgid "\"Thank you.\""
msgstr "\"Dziękuję.”"

msgid "A shelf. Nothing of interest."
msgstr "Półka. Nic interesującego."

msgid "A bathtub filled with a black liquid."
msgstr "Wanna wypełniona czarnym płynem."

msgid "It's so big... you could fit like... four of me in there."
msgstr "Jest taka duża... można by w niej zmieścić... cztery osoby."

msgid "Check if there's anything useful inside?"
msgstr "Sprawdzić, czy w środku jest coś przydatnego?"

msgid "A beautiful night sky."
msgstr "Przepiękne nocne niebo."

msgid "Three moons... ?"
msgstr "Trzy księżyce... ?"
