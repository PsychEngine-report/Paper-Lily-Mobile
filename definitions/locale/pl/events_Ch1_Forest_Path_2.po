msgid "That entrance... wasn't there before."
msgstr "To zejście... nie było go tutaj wcześniej."

msgid "Is it underground?"
msgstr "Czy prowadzi do metra?"

msgid "There's another signpost here. It's loose, so it can be rotated."
msgstr "Jest tu kolejny drogowskaz. Jest luźny, więc można go obrócić."

msgid "Alright, I think I understand."
msgstr "Dobra, chyba rozumiem."

msgid "This sign says [color=#8080FF]\"Daylight Gate\"[/color]. Rotate it?"
msgstr "Na znaku widnieje napis [color=#8080FF]\"Brama Światła Dziennego\"[/color]. Obrócić znak?"

msgid "North"
msgstr "Północ"

msgid "South"
msgstr "Południe"

msgid "West"
msgstr "Zachód"

msgid "East"
msgstr "Wschód"

msgid "Don't Rotate"
msgstr "Nie obracaj"

msgid "This sign says [color=#8080FF]\"Daylight Gate\"[/color]."
msgstr "Na znaku widnieje napis [color=#8080FF]\"Brama Światła Dziennego\"[/color]."

msgid "It's fixed in place, so it cannot be rotated."
msgstr "Jest on zamocowany na stałe, więc nie można go obrócić."

msgid "This sign says [color=#FF8080]\"Secret\"[/color]. Rotate it?"
msgstr "Na znaku widnieje napis [color=#FF8080]\"Sekret\"[/color]. Obrócić znak?"

msgid "This sign says [color=#FFFF80]\"Train Station Access\"[/color]. Rotate it?"
msgstr "Na znaku widnieje napis [color=#FFFF80]”Stacja Kolejowa”[/color]. Obrócić znak?"

msgid "A dark pathway through the trees. Enter?"
msgstr "Ciemna droga przez drzewa. Wejść?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"
