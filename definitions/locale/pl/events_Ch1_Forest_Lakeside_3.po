msgid "It seems to like the white tree."
msgstr "Zdaje się lubić to drzewo."

msgid "Take ${item:ch1.doorknob_grave}?"
msgstr "Wziąć ${item:ch1.doorknob_grave}?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"

msgid "Fallen white leaves surround the tree."
msgstr "Wokół drzewa leży mnóstwo białych liści."

msgid "Take some ${item:ch1.lakeside_petals_white}?"
msgstr "Zebrać ${item:ch1.lakeside_petals_white}?"

msgid "A wooden log."
msgstr "Kłoda."

msgid "It's too short to use as a bridge."
msgstr "Jest zbyt krótka, by jej użyć jako mostu."

msgid "I could use this to cross the river..."
msgstr "Mogłabym jej użyć, by się przedostać na drugą stronę..."

msgid "Push it into the water?"
msgstr "Wepchnąć to do wody?"

msgid "Something's weird about this spot, but you don't know what it is."
msgstr "W tym miejscu coś ci nie pasuje, ale nie masz pewności, co dokładnie."

msgid "It's just trees... right?"
msgstr "To tylko drzewa... prawda?"

msgid "The passage is camouflaged."
msgstr "Przejście jest zakamuflowane."

msgid "There's no way to open it from this side."
msgstr "Z tej strony nie da się go otworzyć."

msgid "A beautiful tree with white leaves."
msgstr "Przepiękne drzewo z białymi liśćmi."

msgid "It's too far to jump."
msgstr "Za daleko, by doskoczyć."

msgid "The river fades into obscurity."
msgstr "Rzeka niknie w ciemnościach."

msgid "White leaves cover the ground."
msgstr "Białe liście pokrywają ziemię."
