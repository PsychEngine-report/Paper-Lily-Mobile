msgid "Climb back up?"
msgstr "Wspiąć się z powrotem na górę?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"

msgid "There's no need to go this way."
msgstr "Nie ma sensu iść tą drogą."

msgid "Walk down the train tracks in this direction?"
msgstr "Pójść po torach w tym kierunku?"

msgid "Is it just me or the path is getting narrower...?"
msgstr "Czy mi się zdaje, czy ta ścieżka staje się coraz węższa...?"

msgid "Wait... no!!!"
msgstr "Chwila... nie!!!"
