msgid "There's a paddle here."
msgstr "Jest tu wiosło."

msgid "Take ${item:ch1.forest_paddles}?"
msgstr "Wziąć ${item:ch1.forest_paddles}?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"

msgid "The pier ends here."
msgstr "Pomost kończy się w tym miejscu."

msgid "Some purple flowers."
msgstr "Kilka fioletowych kwiatów."

msgid "They're growing abundantly between these rocks."
msgstr "Rośnie obficie między tymi skałami."

msgid "Take some ${item:ch1.lakeside_petals_purple}?"
msgstr "Wziąć trochę ${item:ch1.lakeside_petals_purple}?"

msgid "A large structure looms over the lake in the distance."
msgstr "W oddali nad jeziorem góruje duża budowla."

msgid "What is that place..?"
msgstr "Co to za miejsce..?"

msgid "..."
msgstr "..."

msgid "Hmm... I can't see the lighthouse from here."
msgstr "Hmm... Nie widzę stąd latarni morskiej."

msgid "It might be beyond those trees."
msgstr "Może znajdować się za tymi drzewami."

msgid "Oh well."
msgstr "No cóż."
