msgid "Are you sure you'll be okay?"
msgstr "Jesteś pewien, że nic ci nie będzie?"

msgid "Yeah for sure!"
msgstr "Tak, na pewno!"

msgid "Tip top shape."
msgstr "Normalnie czuję się świetnie."

msgid "..."
msgstr "..."

msgid "Take your time."
msgstr "Nie spiesz się."

msgid "I mean... it's not like I'm bleeding out or anything."
msgstr "To znaczy... wcale się wykrwawiam, czy coś."

msgid "(I need to find an exit fast.)"
msgstr "(Muszę szybko znaleźć wyjście.)"

msgid "Sai is not moving."
msgstr "Sai się nie rusza."

msgid "She's back..... She's back."
msgstr "Wróciła..... Wróciła."

msgid "She's singing in my ears....."
msgstr "Śpiewa mi do uszu....."

msgid "Singing all the time....."
msgstr "Śpiewa cały czas..."

msgid "Humming..."
msgstr "Nuci..."

msgid "Burning..."
msgstr "Pali się…"

msgid "Oh no... burning...."
msgstr "O nie... pali się…"

msgid "Hahahahaha....."
msgstr "Hahahahaha....."

msgid "Burning."
msgstr "Pali się."
