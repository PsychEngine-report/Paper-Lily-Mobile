msgid "A red tree."
msgstr "Czerwone drzewo."

msgid "It stands out..."
msgstr "Wyróżnia się..."

msgid "Is there anything special about it?"
msgstr "Czy jest w nim coś szczególnego?"

msgid "Hmm? There's a paper with something stuck to it."
msgstr "Hmm? Tu jest papier, coś jest do niego przyklejone."

msgid "Take ${item:ch1.forest_lockedsite_key}?"
msgstr "Wziąć ${item:ch1.forest_lockedsite_key}?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"

msgid "(You don't need that key, so it was discarded.)"
msgstr "(Ten klucz nie jest ci już potrzebny, więc został on wyrzucony.)"

msgid "There's also a note taped to the tree."
msgstr "Do drzewa przyklejona jest również notatka."
