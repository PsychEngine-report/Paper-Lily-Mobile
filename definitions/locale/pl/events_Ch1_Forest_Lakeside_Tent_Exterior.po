msgid "What to do?"
msgstr "Co z nią zrobić?"

msgid "Kill it here"
msgstr "Zabij ją tutaj"

msgid "Release it around this area"
msgstr "Wypuść ją w tej okolicy"

msgid "Do nothing"
msgstr "Nic nie rób"

msgid "It's not wise to do that here."
msgstr "Robienie tego tutaj nie jest rozsądne."

msgid "I don't think I should release it so close to them..."
msgstr "Chyba nie powinnam wypuszczać go tak blisko nich..."

msgid "HEY! I'M WATCHING YOU!"
msgstr "HEJ! WIDZĘ WAS!"

msgid "IF YOU LET THAT SHIT FREE I'LL COME OUT AND KILL YOU BOTH MYSELF!!!"
msgstr "JEŚLI WYPUŚCISZ TEGO ŚMIECIA, WYJDĘ I ZABIJĘ WAS OBU!!!"

msgid "(...Sorry...)"
msgstr "(...Przepraszam...)"

msgid "A rudimentary lamp."
msgstr "Prymitywna lampa."

msgid "A tent. Looks rather cozy."
msgstr "Namiot. Wygląda raczej przytulnie."

msgid "There's nothing particularly interesting about the backside of the tent."
msgstr "Z tyłu namiotu nie ma nic szczególnie interesującego."

msgid "Stay away!!!"
msgstr "Nie zbliżaj się!!!"
