msgid "Nothing happened."
msgstr "Nic się nie stało."

msgid "A crack in the wall."
msgstr "Pęknięcie w ścianie."

msgid "There's nothing else in there."
msgstr "Nic więcej tam nie ma."

msgid "There seems to be something inside..."
msgstr "Wygląda na to, że w środku coś jest..."

msgid "Take ${item:ch1.doorknob_library_fragment}?"
msgstr "Wziąć ${item:ch1.doorknob_library_fragment}?"

msgid "Yes"
msgstr "Tak"

msgid "No"
msgstr "Nie"

msgid "The gate is locked. A keypad is attached to it."
msgstr "Brama jest zamknięta. Jest do niej przymocowany panel."

msgid "Input a code?"
msgstr "Wprowadzić kod?"
