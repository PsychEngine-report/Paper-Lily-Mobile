msgid "Are you sure you'll be okay?"
msgstr "С тобой точно всё будет хорошо?"

msgid "Yeah for sure!"
msgstr "Ну разумеется!"

msgid "Tip top shape."
msgstr "Всё чётко!"

msgid "..."
msgstr "..."

msgid "Take your time."
msgstr "Не спеши."

msgid "I mean... it's not like I'm bleeding out or anything."
msgstr "Я же тут... не истекаю кровью, в конце-то концов."

msgid "(I need to find an exit fast.)"
msgstr "(Нужно как можно скорее найти выход.)"

msgid "Sai is not moving."
msgstr "Сай не шевелится."

msgid "She's back..... She's back."
msgstr "Она вернулась...... Она вернулась."

msgid "She's singing in my ears....."
msgstr "Она поёт в мои уши....."

msgid "Singing all the time....."
msgstr "Поёт непрестанно...."

msgid "Humming..."
msgstr "Напевает...."

msgid "Burning..."
msgstr "Горит..."

msgid "Oh no... burning...."
msgstr "О нет... горит..."

msgid "Hahahahaha....."
msgstr "Ха-ха-ха-ха-ха...."

msgid "Burning."
msgstr "Горит."
