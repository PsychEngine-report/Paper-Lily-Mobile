msgctxt "events.Ch1_Forest_Path_4.misc_tree.dlg.narrator"
msgid "A red tree."
msgstr "Красное дерево."

msgid "It stands out..."
msgstr "Оно выделяется..."

msgid "Is there anything special about it?"
msgstr "Оно какое-то особенное?"

msgctxt "events.Ch1_Forest_Path_4.misc_tree_behind.dlg.narrator"
msgid "A red tree."
msgstr "Красное дерево."

msgid "Hmm? There's a paper with something stuck to it."
msgstr "Хм-м? К нему прилеплено что-то, обёрнутое бумагой."

msgid "Take ${item:ch1.forest_lockedsite_key}?"
msgstr "Взять предмет: ${item:ch1.forest_lockedsite_key}?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Нет"

msgid "(You don't need that key, so it was discarded.)"
msgstr "(Вам не нужен этот ключ, поэтому вы оставили его на месте.)"

msgid "There's also a note taped to the tree."
msgstr "К дереву также прилеплена записка."
