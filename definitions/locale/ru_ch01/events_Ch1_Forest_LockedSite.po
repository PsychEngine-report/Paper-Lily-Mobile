msgid "A long fence."
msgstr "Длинный забор."

msgctxt "events.Ch1_Forest_LockedSite.misc_fence_door.dlg.narrator"
msgid "That doesn't seem like a good idea."
msgstr "Это не самая умная затея."

msgid "There's no way I'm going back in there."
msgstr "Я ни за что туда не вернусь."

msgid "There's a note on the floor:"
msgstr "На земле лежит записка:"

msgid "The petal trail ends here."
msgstr "След из лепестков обрывается здесь."

msgid "They didn't make it to the exit..."
msgstr "Кто-то так и не добрался до выхода..."
