msgctxt "events.Ch1_Forest_LockedSite.item_boltcutter_on_fence_3.dlg.narrator"
msgid "That doesn't seem like a good idea."
msgstr "Это не самая умная затея."

msgid "There's no reason to do that."
msgstr "Нет причин этого делать."

msgid "There's a gate nearby!"
msgstr "Недалеко отсюда ворота!"

msgid "There's quite a bit of blood in this spot."
msgstr "Здесь довольно много крови."

msgid "Someone's remains. You can't tell whether they're human or not."
msgstr "Чьи-то останки. Непонятно, то ли человеческие, то ли нет."

msgctxt "events.Ch1_Forest_LockedSite.misc_fence_1.dlg.lacie"
msgid "I'd rather not go back in there."
msgstr "Я бы туда не возвращалась."

msgctxt "events.Ch1_Forest_LockedSite.misc_fence_1.dlg.lacie"
msgid "The grass is definitely greener on this side."
msgstr "По эту сторону трава явно зеленее."

msgctxt "events.Ch1_Forest_LockedSite.misc_fence_1.dlg.narrator"
msgid "A fence blocks your path."
msgstr "Ваш путь преграждает забор."

msgctxt "events.Ch1_Forest_LockedSite.misc_fence_1.choice"
msgid "Use ${item:ch1.forest_bolt_cutter}?"
msgstr "Использовать ${item:ch1.forest_bolt_cutter}?"

msgctxt "events.Ch1_Forest_LockedSite.misc_fence_1.choice.Use ${item:ch1.forest_bolt_cutter}?"
msgid "Yes"
msgstr "Да"

msgctxt "events.Ch1_Forest_LockedSite.misc_fence_1.choice.Use ${item:ch1.forest_bolt_cutter}?"
