msgid "The room where you were locked in is directly under you."
msgstr "Комната, в которой вас ранее заперли, находится прямо под вами."

msgid "You can see Sai from here. He doesn't seem to be doing anything."
msgstr "Сай по-прежнему в своей клетке."

msgid "Empty bird cages."
msgstr "Пустые клетки для птиц."

msgid "There seems to be something strange inside the cage."
msgstr "Внутри клетки есть что-то необычное."

msgid "Try to get ${item:ch1.mk_hand_mirror}?"
msgstr "Попытаться взять предмет: ${item:ch1.mk_hand_mirror}?"

msgctxt "events.Ch1_MK_B1F_Cages.misc_cage_mirror.choice.Try to get ${item:ch1.mk_hand_mirror}?"
msgid "Yes"
msgstr "Да"

msgctxt "events.Ch1_MK_B1F_Cages.misc_cage_mirror.choice.Try to get ${item:ch1.mk_hand_mirror}?"
msgid "No"
msgstr "Нет"

msgid "There's nothing else in there."
msgstr "Здесь больше ничего нет."

msgid "The painting lady is gone."
msgstr "Девушка из картины пропала."

msgid "A painting of a lady."
msgstr "Картина девушки."

msgid "Her golden eye stands out..."
msgstr "Её золотой глаз выделяется..."

msgid "Pull it out?"
msgstr "Вытащить его?"

msgctxt "events.Ch1_MK_B1F_Cages.misc_painting.choice.Pull it out?"
msgid "Yes"
msgstr "Да"

msgctxt "events.Ch1_MK_B1F_Cages.misc_painting.choice.Pull it out?"
msgid "No"
msgstr "Нет"

msgid "(You don't need an extra eye, so you discarded it.)"
msgstr "(Вам не нужен ещё один глаз, так что вы его оставили.)"

msgid "Some abstract paintings."
msgstr "Абстрактные картины."
