msgctxt "tutorials.name.itemuse"
msgid "Using Items"
msgstr "Использование предметов"

msgid "To use an item, stand close and select the item from the menu ({0})"
msgstr "Чтобы использовать предмет, подойдите к объекту и выберите предмет в меню ({0})"

