msgid "Battle"
msgstr "Сражение"

msgid "Move around to avoid the spikes!"
msgstr "Перемещайтесь, чтобы уклониться от шипов!"

msgid "Minigame: Box Puzzle"
msgstr "Мини игра: Коробки"

msgid "Push the desks into the green zones to complete the puzzle"
msgstr "Расставьте парты в зелёные области, чтобы пройти мини игру"

msgid "Documents"
msgstr "Записи"

msgid "Your papers and notes are stored in the notebook in your inventory."
msgstr "Все найденные документы и записки будут храниться в блокноте у вас в инвентаре."

msgid "Hiding"
msgstr "Прятки"

msgid "Hide in the bushes with {0} to avoid being caught."
msgstr "Прячьтесь в кусты, нажав на {0}, чтобы вас не поймали."

msgctxt "tutorials.name.interaction"
msgid "Interacting"
msgstr "Взаимодействие"

msgctxt "tutorials.text.interaction"
msgid "Press {0} to interact with the environment"
msgstr "Нажмите на {0}, чтобы взаимодействовать с окружением"

