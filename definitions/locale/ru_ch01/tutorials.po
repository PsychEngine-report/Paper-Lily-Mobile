msgctxt "tutorials.name.save"
msgid "Saving the Game"
msgstr "Сохранение игры"

msgctxt "tutorials.text.save"
msgid "Crows can save your game. Save often, since the future is uncertain"
msgstr "С помощью ворон можно сохранять игру. Сохраняйтесь почаще, ведь кто знает, как сложится будущее?"

msgctxt "tutorials.name.save_lacie"
msgid "Saving the Game"
msgstr "Сохранение игры"

msgctxt "tutorials.text.save_lacie"
msgid "Crows can save your game. Save often, since the future is uncertain"
msgstr "С помощью ворон можно сохранять игру. Сохраняйтесь почаще, ведь кто знает, как сложится будущее?"

msgid "Sneaking"
msgstr "Скрытность"

msgid "Running will make you easier to spot. Hold {0} to sneak past enemies"
msgstr "Вас легче заметить, когда вы бежите. Удерживайте {0} во время движения, чтобы прокрасться мимо врагов"

msgid "Climbing Stairs"
msgstr "Взбирание по лестницам"

msgid "Hold {0} while moving to climb up the stairs"
msgstr "Нажмите {0} во время движения, чтобы взобраться на ступеньки"

msgid "Timed Event"
msgstr "Проверка на скорость"

msgid "Get to the bus before the time runs out!"
msgstr "Доберитесь до автобуса, пока не вышло время!"

msgid "Minigame: Timing Bar"
msgstr "Мини игра: Точность"

msgid "Press {0} when the indicator matches the green zone"
msgstr "Нажмите {0} в момент, когда индикатор попадёт на зелёную область"
