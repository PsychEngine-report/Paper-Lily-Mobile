msgstr "Подбор предметов"

msgid "Press {0} to pick up items"
msgstr "Чтобы подобрать предмет, нажмите {0}"

msgctxt "tutorials.name.running"
msgid "Running"
msgstr "Бег"

msgctxt "tutorials.text.running"
msgid "While moving, hold {0} to run"
msgstr "Удерживайте {0} во время движения, чтобы бежать"

