msgid "There's curtains where the driver should be."
msgstr "Шторы, за которыми должен сидеть водитель."

msgid "Take a look behind the curtains?"
msgstr "Заглянуть за шторы?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Нет"

msgid "There's no one there, just an empty driver's seat."
msgstr "За ними лишь пустое водительское сиденье."

msgid "There's nobody behind the curtains."
msgstr "За шторами никого нет."

msgid "My seat."
msgstr "Моё место."

msgid "It's too dark to see out the window."
msgstr "За окном слишком темно, ничего не видно."

msgid "Uhm... where am I?"
msgstr "Эм... а где я?"
