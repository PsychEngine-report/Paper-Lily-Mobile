msgid "A floor indicator."
msgstr "Лампочки, показывающие, на каком вы сейчас этаже."

msgid "The elevator has no power, so the indicator lights are off."
msgstr "Лифт обесточен, поэтому лампочки не работают."

msgid "Where to?"
msgstr "Куда отправиться?"

msgid "B1F"
msgstr "Подземный этаж 1"

msgid "B2F"
msgstr "Подземный этаж 2"

msgid "B3F"
msgstr "Подземный этаж 3"

msgid "B4F"
msgstr "Подземный этаж 4"

msgid "Never mind"
msgstr "Ничего не делать"

msgid "Nothing happens."
msgstr "Ничего не произошло."

msgid "The button is not responding."
msgstr "Кнопка не реагирует."

msgid "An emblem that looks like an eye of some sort."
msgstr "Эмблема, похожая на глаз."

msgid "The doors are stuck..."
msgstr "Двери, должно быть, заело..."
