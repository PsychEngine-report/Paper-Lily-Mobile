msgid "A red tree."
msgstr "Червено дърво."

msgid "It stands out..."
msgstr "Отличава се…"

msgid "Is there anything special about it?"
msgstr "Има ли нещо специално в него?"

msgid "Hmm? There's a paper with something stuck to it."
msgstr "Хмм? Има хартия с нещо залепено на нея."

msgid "Take ${item:ch1.forest_lockedsite_key}?"
msgstr "Вземи ${item:ch1.forest_lockedsite_key}?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Не"

msgid "(You don't need that key, so it was discarded.)"
msgstr "(Този ключ не ви е необходим, затова беше изхвърлен.)"

msgid "There's also a note taped to the tree."
msgstr "На дървото е залепена и бележка."
