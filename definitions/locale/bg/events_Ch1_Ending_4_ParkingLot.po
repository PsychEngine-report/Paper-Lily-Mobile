msgid "What seems like a trash bag."
msgstr "Нещо, което прилича на торба за боклук."

msgid "It has dust all over."
msgstr "Цялото е покрито с прах."

msgid "A wooden crate."
msgstr "Дървен сандък."

msgid "A bus. It doesn't seem to have been used in a long time."
msgstr "Автобус. Изглежда от дълго време не е ползван."

msgid "There's another bus stacked on top of it."
msgstr "Върху него е сложен още един автобус."

msgid "A broken bus is stacked on top of it."
msgstr "Върху него е сложен счупен автобус."

msgid "A keypad."
msgstr "Клавиатура."

msgid "It doesn't seem to be working."
msgstr "Изглежда май не работи."

msgid "Touch some buttons?"
msgstr "Докоснете някои бутони?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Не"

msgid "The keypad does not respond in any way."
msgstr "Клавиатурата не реагира по никакъв начин."

msgid "Looks like a mailbox."
msgstr "Прилича на пощенска кутия."

msgid "There's no mail right now."
msgstr "В момента няма поща."

msgid "A small light. It changes colors every few seconds."
msgstr "Дребна светлина. Променя цветовете си на всеки няколко секунди."

msgid "Strange street signs fill the walls."
msgstr "Стените са изпълнени със странни улични табели."

msgid "A garage door."
msgstr "Гаражна врата."

msgid "Can I get this open somehow?"
msgstr "Мога ли по някакъв начин да го отворя?"
