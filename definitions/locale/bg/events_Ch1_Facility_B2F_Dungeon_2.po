msgid "A broken, bloody baseball bat lies next to a skeleton."
msgstr "Счупена, окървавена бейзболна бухалка лежи до скелет."

msgid "A \"W\" is carved into it."
msgstr "В него е издълбана буквата \"W\"."

msgid "The door is unreachable."
msgstr "Вратата е недостъпна."

msgid "\"Subject D5. Age: 100-150. Status: Dormant. Awaiting further tests.\""
msgstr "\"Субект Д5. Възраст: 100–150. Състояние: Неактивен. В очакване на последващи тестове.\""

msgid "\"Subject D8. Age: Unknown. Status: Highly active. Awaiting further tests.\""
msgstr "\"Субект Д8. Възраст: Неизвестна. Състояние: Свръх активен. В очакване на последващи тестове.\""

msgid "A confinement door. It's locked."
msgstr "Врата за задържане. Заключена е."

msgid "There's something inside..."
msgstr "Има нещо вътре…"

msgid "Nothing of interest on the desk."
msgstr "На бюрото няма нищо интересно."

msgid "There's nothing else in the drawer."
msgstr "В чекмеджето няма нищо друго."

msgid "There's a valve handle in the drawer."
msgstr "В чекмеджето има дръжка на клапан."

msgid "Take ${item:ch1.facility_handle_diamond}?"
msgstr "Вземи ${item:ch1.facility_handle_diamond}?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Не"

msgid "A hole on the floor."
msgstr "Дупка на пода."

msgid "(Sai joined your party.)"
msgstr "(Саи се присъедини към вашата група.)"
