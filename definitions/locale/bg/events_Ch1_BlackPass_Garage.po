msgid "It's here!"
msgstr "Тук е!"

msgid "What was that...?"
msgstr "Какво бе това…?"

msgid "It's not here."
msgstr "Не е тук."

msgid "Nothing else of interest."
msgstr "Нищо друго не представлява интерес."

msgid "The garage door is missing. It's just a wall here."
msgstr "Гаражната врата липсва. Тук има само една стена."

msgid "There's nothing else to do here."
msgstr "Вече няма какво да се направи тук."

msgid "It won't open!"
msgstr "Не се отваря!"
