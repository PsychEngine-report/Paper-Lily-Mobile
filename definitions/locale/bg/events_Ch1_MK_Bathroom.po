msgid "A little cactus."
msgstr "Малък кактус."

msgid "An empty flower vase."
msgstr "Празна ваза за цвете."

msgid "Pink flowers in a vase."
msgstr "Розови цветя във ваза."

msgid "I could use these flowers..."
msgstr "Бих могла да използвам тези цветя…"

msgid "Bring the flowers to the plant?"
msgstr "Донеси цветята до растението?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Не"

msgid "\"Thank you.\""
msgstr "\"Благодаря ти.\""

msgid "A shelf. Nothing of interest."
msgstr "Рафт. Нищо интересно."

msgid "A bathtub filled with a black liquid."
msgstr "Вана, пълна с черна течност."

msgid "It's so big... you could fit like... four of me in there."
msgstr "Толкова е голяма… че можеш да побереш… четирима като мен там."

msgid "Check if there's anything useful inside?"
msgstr "Провери дали вътре има нещо полезно?"

msgid "A beautiful night sky."
msgstr "Красиво нощно небе."

msgid "Three moons... ?"
msgstr "Три луни… ?"
