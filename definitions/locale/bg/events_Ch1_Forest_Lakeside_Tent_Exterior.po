msgid "What to do?"
msgstr "Какво да правя?"

msgid "Kill it here"
msgstr "Убий го тук"

msgid "Release it around this area"
msgstr "Пусни го някъде наоколо"

msgid "Do nothing"
msgstr "Не прави нищо"

msgid "It's not wise to do that here."
msgstr "Не е разумно да правиш това тук."

msgid "I don't think I should release it so close to them..."
msgstr "Не мисля че е редно да го пускам толкова близо до тях…"

msgid "HEY! I'M WATCHING YOU!"
msgstr "ЕЙ! ГЛЕДАМ ТЕ!"

msgid "IF YOU LET THAT SHIT FREE I'LL COME OUT AND KILL YOU BOTH MYSELF!!!"
msgstr "АКО ПУСНЕШ ТАЗИ ГАДОСТ НА СВОБОДА, ЩЕ ИЗЛЯЗА И ЩЕ ВИ УБИЯ И ДВАМАТА!!!"

msgid "(...Sorry...)"
msgstr "(…Извинявай…)"

msgid "A rudimentary lamp."
msgstr "Примитивна лампа."

msgid "A tent. Looks rather cozy."
msgstr "Палатка. Изглежда по-скоро уютно."

msgid "There's nothing particularly interesting about the backside of the tent."
msgstr "В задната част на палатката няма нищо особено интересно."

msgid "Stay away!!!"
msgstr "Стой настрана!!!"
