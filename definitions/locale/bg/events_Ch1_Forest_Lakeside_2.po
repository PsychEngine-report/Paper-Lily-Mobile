msgid "Empty the ${item:ch1.bucket_full}?"
msgstr "Изпразни ${item:ch1.bucket_full}?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Не"

msgid "Empty the ${item:ch1.bucket_full_holy}?"
msgstr "Изпразни ${item:ch1.bucket_full_holy}?"

msgid "The faucet isn't working."
msgstr "Кранчето не работи."

msgid "Fill up the ${item:ch1.bucket}?"
msgstr "Напълни ${item:ch1.bucket}?"

msgid "There's a boat paddle here."
msgstr "Тук има гребло за лодка."

msgid "Take ${item:ch1.forest_paddles}?"
msgstr "Вземи ${item:ch1.forest_paddles}?"

msgid "I don't think this is where I'm supposed to put them..."
msgstr "Не мисля, че това е мястото, където трябва да ги сложа…"

msgid "The note said something about a \"little keeper\"...?"
msgstr "В бележката се казваше нещо за \"малък пазител\"…?"

msgid "There's a faucet coming out of the water."
msgstr "Има кранче, което се подава от водата."

msgid "Turn it on?"
msgstr "Включи го?"

msgid "Nothing is coming out of the faucet."
msgstr "От кранчето не излиза нищо."

msgid "The water flows freely from the faucet."
msgstr "Водата тече свободно от кранчето."

msgid "Something's floating near the stream..."
msgstr "Нещо плува край потока…"

msgid "Take ${item:ch1.doorknob_library_fragment}?"
msgstr "Вземи ${item:ch1.doorknob_library_fragment}?"

msgid "Pink water lilies can be seen."
msgstr "Могат да се видят розови водни лилии."

msgid "Take some ${item:ch1.lakeside_petals_pink}?"
msgstr "Вземи малко ${item:ch1.lakeside_petals_pink}?"

msgid "A structure housing a lamp."
msgstr "Структура, в която е разположена лампа."

msgid "The water is calm."
msgstr "Водата е спокойна."
