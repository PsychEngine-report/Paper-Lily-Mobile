msgid "There's a paddle here."
msgstr "Тук има гребло."

msgid "Take ${item:ch1.forest_paddles}?"
msgstr "Вземи ${item:ch1.forest_paddles}?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Не"

msgid "The pier ends here."
msgstr "Пристанът свършва тук."

msgid "Some purple flowers."
msgstr "Няколко лилави цветя."

msgid "They're growing abundantly between these rocks."
msgstr "Те растат в изобилие между тези скали."

msgid "Take some ${item:ch1.lakeside_petals_purple}?"
msgstr "Вземи малко ${item:ch1.lakeside_petals_purple}?"

msgid "A large structure looms over the lake in the distance."
msgstr "В далечината над езерото се извисява голяма постройка."

msgid "What is that place..?"
msgstr "Какво е това място..?"

msgid "..."
msgstr "…"

msgid "Hmm... I can't see the lighthouse from here."
msgstr "Хмм… Не мога да видя фара оттук."

msgid "It might be beyond those trees."
msgstr "Може би е отвъд тези дървета."

msgid "Oh well."
msgstr "Ами добре."
