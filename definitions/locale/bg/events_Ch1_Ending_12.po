msgid "Are you sure you'll be okay?"
msgstr "Убедена ли си че ще си добре?"

msgid "Yeah for sure!"
msgstr "Даа, разбира се!"

msgid "Tip top shape."
msgstr "Тип топ форма."

msgid "..."
msgstr "…"

msgid "Take your time."
msgstr "Не бързайте."

msgid "I mean... it's not like I'm bleeding out or anything."
msgstr "Имам предвид… не е като да кървя или нещо подобно."

msgid "(I need to find an exit fast.)"
msgstr "(Трябва бързо да намеря изход.)"

msgid "Sai is not moving."
msgstr "Саи не се движи."

msgid "She's back..... She's back."
msgstr "Тя се върна… Тя се върна."

msgid "She's singing in my ears....."
msgstr "Тя пее в ушите ми....."

msgid "Singing all the time....."
msgstr "През цялото време пеене....."

msgid "Humming..."
msgstr "Тананикане…"

msgid "Burning..."
msgstr "Изгаряне…"

msgid "Oh no... burning...."
msgstr "О не… горене…"

msgid "Hahahahaha....."
msgstr "А-ха-ха-ха-ха-ха....."

msgid "Burning."
msgstr "Гори."
