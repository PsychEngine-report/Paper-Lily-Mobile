msgid "It's a donation box. The label reads:"
msgstr "Това е кутия за дарения. Етикетът гласи:"

msgid "\"All proceeds go towards the construction of a bridge somewhere. We appreciate your donation!\""
msgstr "\"Всички приходи отиват за построяването на мост някъде. Оценяваме вашето дарение!\""

msgid "The lid is loose, and there's a single coin inside."
msgstr "Капакът е открехнат, а вътре има една монета."

msgid "Take the ${item:ch1.coin}?"
msgstr "Вземи ${item:ch1.coin}?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Не"

msgid "The box is now empty."
msgstr "Кутията вече е празна."
