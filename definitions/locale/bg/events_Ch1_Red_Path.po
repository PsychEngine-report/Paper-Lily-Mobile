msgid "Nothing happened."
msgstr "Нищо не се случи."

msgid "A crack in the wall."
msgstr "Пукнатина в стената."

msgid "There's nothing else in there."
msgstr "Вътре няма нищо друго."

msgid "There seems to be something inside..."
msgstr "Изглежда, че вътре има нещо…"

msgid "Take ${item:ch1.doorknob_library_fragment}?"
msgstr "Вземи ${item:ch1.doorknob_library_fragment}?"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Не"

msgid "The gate is locked. A keypad is attached to it."
msgstr "Портата е заключена. Към нея е прикрепена клавиатура."

msgid "Input a code?"
msgstr "Въведете код?"
