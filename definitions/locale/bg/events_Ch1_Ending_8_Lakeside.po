msgid "There's no boat."
msgstr "Няма лодка."

msgid "Only red."
msgstr "Само червено."

msgid "A red rabbit."
msgstr "Червен заек."

msgid "It's not breathing."
msgstr "То не диша."

msgid "The crow that was here is gone."
msgstr "Враната, която беше тук, вече я няма."

msgid "Wooden logs stick out from the bloody water."
msgstr "От кървавата вода стърчат дървени трупи."

msgid "A note is attached to the tree. It says:"
msgstr "Към дървото е прикрепена бележка. В нея се казва:"

msgid ""
"\"THE MONSTER\n"
"LOVED MEAT\n"
"HATED WATER\""
msgstr ""
"\"ЧУДОВИЩЕТО\n"
"ОБИЧАШЕ МЕСОТО\n"
"МРАЗЕШЕ ВОДАТА\""

msgid "The way to the temple is sealed off."
msgstr "Пътят към храма е запечатан."

msgid "Nothing but trees here."
msgstr "Тук няма нищо друго освен дървета."

msgid "The way back seems to be gone."
msgstr "Изглежда, че пътят за връщане е изчезнал."

msgid "This way is closed off by trees."
msgstr "Пътят е преграден от дървета."
