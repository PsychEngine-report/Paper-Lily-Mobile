msgid "A red tree."
msgstr "Uma árvore vermelha."

msgid "It stands out..."
msgstr "Ela chama a atenção..."

msgid "Is there anything special about it?"
msgstr "Há algo de especial nela?"

msgid "Hmm? There's a paper with something stuck to it."
msgstr "Hmm? Há um papel preso nela."

msgid "Take ${item:ch1.forest_lockedsite_key}?"
msgstr "Levar a ${item:ch1.forest_lockedsite_key}?"

msgid "Yes"
msgstr "Sim"

msgid "No"
msgstr "Não"

msgid "(You don't need that key, so it was discarded.)"
msgstr "(Não precisas dessa chave, então deitaste-a fora.)"

msgid "There's also a note taped to the tree."
msgstr "Também há um bilhete colado à árvore."
