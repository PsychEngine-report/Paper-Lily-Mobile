msgid "What seems like a trash bag."
msgstr "Parece um saco de lixo."

msgid "It has dust all over."
msgstr "Está cheio de pó."

msgid "A wooden crate."
msgstr "Um caixote de madeira."

msgid "A bus. It doesn't seem to have been used in a long time."
msgstr "Um autocarro. Parece que já não é utilizado há muito tempo."

msgid "There's another bus stacked on top of it."
msgstr "Há outro autocarro em cima dele."

msgid "A broken bus is stacked on top of it."
msgstr "Há um autocarro avariado empilhado em cima dele."

msgid "A keypad."
msgstr "Um teclado."

msgid "It doesn't seem to be working."
msgstr "Parece que não está a funcionar."

msgid "Touch some buttons?"
msgstr "Tocar em alguns botões?"

msgid "Yes"
msgstr "Sim"

msgid "No"
msgstr "Não"

msgid "The keypad does not respond in any way."
msgstr "O teclado não reage."

msgid "Looks like a mailbox."
msgstr "Parece uma caixa de correio."

msgid "There's no mail right now."
msgstr "De momento, não há cartas."

msgid "A small light. It changes colors every few seconds."
msgstr "Uma luzinha. Ela muda de cor a cada poucos segundos."

msgid "Strange street signs fill the walls."
msgstr "Sinais de trânsito estranhos enchem as paredes."

msgid "A garage door."
msgstr "Uma porta de garagem."

msgid "Can I get this open somehow?"
msgstr "Será que consigo abrir isto?"
