msgid "Empty the ${item:ch1.bucket_full}?"
msgstr "Esvaziar o ${item:ch1.bucket_full}?"

msgid "Yes"
msgstr "Sim"

msgid "No"
msgstr "Não"

msgid "Empty the ${item:ch1.bucket_full_holy}?"
msgstr "Esvaziar o ${item:ch1.bucket_full_holy}?"

msgid "The faucet isn't working."
msgstr "A torneira não está a funcionar."

msgid "Fill up the ${item:ch1.bucket}?"
msgstr "Encher o ${item:ch1.bucket}?"

msgid "There's a boat paddle here."
msgstr "Está aqui um remo."

msgid "Take ${item:ch1.forest_paddles}?"
msgstr "Levar o ${item:ch1.forest_paddles}?"

msgid "I don't think this is where I'm supposed to put them..."
msgstr "Acho que não é aqui que os tenho que colocar..."

msgid "The note said something about a \"little keeper\"...?"
msgstr "O bilhete dizia qualquer coisa sobre um \"guardiãozinho\"...?"

msgid "There's a faucet coming out of the water."
msgstr "Há uma torneira a sair da água."

msgid "Turn it on?"
msgstr "Girá-la?"

msgid "Nothing is coming out of the faucet."
msgstr "Não sai nada da torneira."

msgid "The water flows freely from the faucet."
msgstr "A água sai livremente da torneira."

msgid "Something's floating near the stream..."
msgstr "Alguma coisa está a flutuar perto do riacho..."

msgid "Take ${item:ch1.doorknob_library_fragment}?"
msgstr "Levar o ${item:ch1.doorknob_library_fragment}?"

msgid "Pink water lilies can be seen."
msgstr "Consigo ver nenúfares cor-de-rosa."

msgid "Take some ${item:ch1.lakeside_petals_pink}?"
msgstr "Levar algumas ${item:ch1.lakeside_petals_pink}?"

msgid "A structure housing a lamp."
msgstr "Uma estrutura com uma lâmpada."

msgid "The water is calm."
msgstr "A água está calma."
