msgid "There's a paddle here."
msgstr "Há aqui um remo."

msgid "Take ${item:ch1.forest_paddles}?"
msgstr "Levar o ${item:ch1.forest_paddles}?"

msgid "Yes"
msgstr "Sim"

msgid "No"
msgstr "Não"

msgid "The pier ends here."
msgstr "O cais termina aqui."

msgid "Some purple flowers."
msgstr "Algumas flores roxas."

msgid "They're growing abundantly between these rocks."
msgstr "Estão a crescer abundantemente entre estas rochas."

msgid "Take some ${item:ch1.lakeside_petals_purple}?"
msgstr "Levar algumas ${item:ch1.lakeside_petals_purple}?"

msgid "A large structure looms over the lake in the distance."
msgstr "Uma grande estrutura ergue-se sobre o lago ao longe."

msgid "What is that place..?"
msgstr "Que sítio é aquele...?"

msgid "..."
msgstr "..."

msgid "Hmm... I can't see the lighthouse from here."
msgstr "Hmm... Não consigo ver o farol daqui."

msgid "It might be beyond those trees."
msgstr "Talvez esteja para lá daquelas árvores."

msgid "Oh well."
msgstr "Bem..."
