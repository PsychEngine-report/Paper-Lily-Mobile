msgid "There's no boat."
msgstr "Não há barco nenhum."

msgid "Only red."
msgstr "Só vermelho."

msgid "A red rabbit."
msgstr "Um coelho vermelho."

msgid "It's not breathing."
msgstr "Não está a respirar."

msgid "The crow that was here is gone."
msgstr "O corvo que estava aqui foi-se embora."

msgid "Wooden logs stick out from the bloody water."
msgstr "Há troncos de madeira na água ensanguentada."

msgid "A note is attached to the tree. It says:"
msgstr "Há um bilhete preso à árvore. Diz:"

msgid ""
"\"THE MONSTER\n"
"LOVED MEAT\n"
"HATED WATER\""
msgstr ""
"\"O MONSTRO\n"
"ADORAVA CARNE\n"
"ODIAVA ÁGUA\""

msgid "The way to the temple is sealed off."
msgstr "O caminho para o templo está fechado."

msgid "Nothing but trees here."
msgstr "Aqui só há árvores."

msgid "The way back seems to be gone."
msgstr "O caminho de regresso parece ter desaparecido."

msgid "This way is closed off by trees."
msgstr "Este caminho está fechado por árvores."
