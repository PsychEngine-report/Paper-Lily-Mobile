msgid "The train schedule is posted here. It seems the train is currently out of service."
msgstr "Tren takvimi buraya yayınlanmış. Tren şimdilik servis dışı gibi görünüyor."

msgid "I don't quite understand these locations..."
msgstr "Bu konumları tam olarak anlamıyorum..."

msgid "...but it seems this train loops around a really large area."
msgstr "……ama görünüşe göre bu tren çok geniş bir alanda döngüde."

msgid "A map of the train stops is posted here."
msgstr "Tren duraklarının haritası buraya yayınlanmış"

msgid "The clock up there... makes no sense."
msgstr "Yukarıdaki saat... hiç mantıklı değil."

msgid "A sign warning passengers not to jump onto the train tracks."
msgstr "Yolcuların tren raylarına atlamamalarını gösteren bir tabela."

msgid "Nah, that ship has already sailed."
msgstr "Yok be, gemi çoktan denize açılmış."

msgid "Or should I say... that train has left the station?"
msgstr "Yoksa şey mi demeliyim... tren istasyondan ayrılmış?"

msgid "A \"missing person\" sign. The photo frame is empty."
msgstr "Bir \"kayıp insan\" ilanı. Çerçeve boş."

msgid "[color=#8080FF]Gün Işığı Geçidi'ni[/color] gösteren tabela eski görkemine kavuştu."
msgstr "[color=#8080FF]「デイライト・ゲート」[/color]"

msgid "Bu tabela[color=#8080FF]\"Gün Işığı Geçidi\"[/color]diyor."
msgstr "[color=#8080FF]「デイライト・ゲート」[/color]と書かれた標識。"

msgid "It's fixed in place, so it cannot be rotated."
msgstr "Yerinde sabit kalmış, bu yüzden yönü çevirilemez"

msgid "A wooden post."
msgstr "Odundan yapılmış bir postane"

msgid "Hm...? Wasn't there a sign here before...?"
msgstr "Hm...? Önceden burada bir tabela yok muydu...?"

msgid "A wooden post. The sign is missing."
msgstr "Odundan yapılmış bir postane. Tabelası kayıp."

msgid "A trash can. It's full of train tickets, pamphlets and such."
msgstr "Bir çöp kutusu. Tren biletleriyle, broşürlerle dolmuş"

msgid "Sadly, the tickets seem to be used."
msgstr "Ne yazık ki, bilet kullanılmış gibi görünüyor."

msgid "There's a coin, though."
msgstr "Ama bir madeni para var."

msgid "A trash can."
msgstr "Bir çöp kutusu."

msgid "It seems to be filled with non-burnable trash."
msgstr "Yakılamaz çöp ile doldurulmuşa benziyor"

msgid "None of it is useful to you."
msgstr "Hiçbiri işine yaramaz."

msgid "A coin-operated vending machine. It's filled with normal-looking snacks."
msgstr "Madeni parayla çalışan bir otomak. Normal görünen atıştırmalıklar ile dolu."

msgid "Buy something?"
msgstr "Bir şey satın alacak mısın?"

msgid "Potato chips (1 coin)"
msgstr "Patates cipsi (1 madeni para)"

msgid "Do not buy"
msgstr "Satın alma"

msgid "You don't have enough coins..."
msgstr "Yeteri kadar paran yok..."

msgid "This... looks like a regular pack of chips."
msgstr "Bu... normal bir paket cipse benziyor."

msgid "Eat the ${item:ch1.forest_harmless_snack}?"
msgstr "${item:ch1.forest_harmless_snack} Yiyecek misin?"

msgctxt "events.Ch1_Forest_Station_Platform.misc_vendingmachine.choice.Eat the ${item:ch1.forest_harmless_snack}?"
msgid "Yes"
msgstr "Evet"

msgctxt "events.Ch1_Forest_Station_Platform.misc_vendingmachine.choice.Eat the ${item:ch1.forest_harmless_snack}?"
msgid "No"
msgstr "Hayır"

msgid "A large window. You can see an empty waiting room inside."
msgstr "Kocaman bir pencere. İçerideki boş odayı görebiliyorsun."

msgid "A large window. You can't see anything through it."
msgstr "Kocaman bir pencere. Baktığında hiçbir şey göremiyorsun."

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend.dlg.narrator"
msgid "There's no need to go back down."
msgstr "Geri çekilmeye gerek yok."

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend.dlg.narrator"
msgid "It's not a good idea to go down there."
msgstr "Aşağıya inmek iyi bir fikir değil."

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend.choice"
msgid "Descend onto the train tracks?"
msgstr "Tren raylarına in?"

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend.choice.Descend onto the train tracks?"
msgid "Yes"
msgstr "Evet"

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend.choice.Descend onto the train tracks?"
msgid "No"
msgstr "Hayır"

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend_2.dlg.narrator"
msgid "There's no need to go back down."
msgstr "Aşağıya inmek için hiçbir sebep yok"

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend_2.dlg.narrator"
msgid "It's not a good idea to go down there."
msgstr "Aşağıya inmmek iyi bir fikir değil."

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend_2.choice"
msgid "Descend onto the train tracks?"
msgstr "Tren raylarına in?"

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend_2.choice.Descend onto the train tracks?"
msgid "Yes"
msgstr "Evet"

msgctxt "events.Ch1_Forest_Station_Platform.move_tracks_descend_2.choice.Descend onto the train tracks?"
msgid "No"
msgstr "Hayır"
