msgid "Cellphone"
msgstr "Cep Telefonu"

msgid "My personal phone. Hiro bought it for me."
msgstr "Benim kişisel telefonum. Hiro benim için aldı."

msgctxt "items.name.ch1.todolist"
msgid "To-Do List"
msgstr "Yapılacaklar Listesi"

msgctxt "items.desc.ch1.todolist"
msgid "A list of things I want to do before I die."
msgstr "Ölmeden önce yapmak istediğim şeylerin bir listesi."

msgctxt "items.name.ch1.todolist_hidden"
msgid "To-Do List"
msgstr "Yapılacaklar Listesi"

