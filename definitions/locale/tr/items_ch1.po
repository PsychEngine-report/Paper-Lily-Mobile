msgid "Pink Petals"
msgstr "Pembe Yapraklar"

msgctxt "items.desc.ch1.lakeside_petals_pink"
msgid "Some flower petals I found."
msgstr "Bulduğum bazı çiçek yaprakları."

msgid "Purple Petals"
msgstr "Mor Yapraklar"

msgctxt "items.desc.ch1.lakeside_petals_purple"
msgid "Some flower petals I found."
msgstr "Bulduğum bazı çiçek yaprakları."

msgid "White Petals"
msgstr "Beyaz Yapraklar"

msgctxt "items.desc.ch1.lakeside_petals_white"
msgid "Some flower petals I found."
msgstr "Bulduğum bazı çiçek yaprakları."

msgid "Handle (Square)"
msgstr "Sap (Kare)"

msgid "A purple handle for a valve mechanism. The protrusion is square-shaped."
msgstr "Bir vana mekanizması için mor bir sap. Çıkıntısı kare şeklinde."

msgid "Handle (Pentagon)"
msgstr "Sap (Beşgen)"

msgid "A red handle for a valve mechanism. The protrusion is pentagon-shaped."
msgstr "Bir vana mekanizması için kırmızı bir sap. Çıkıntısı beşgen şeklinde."

msgid "Handle (Star)"
msgstr "Sap (Yıldız)"

msgid "A yellow handle for a valve mechanism. The protrusion is shaped like a 5-point star."
msgstr "Bir vana mekanizması için sarı bir sap. Çıkıntısı 5 kenarlı yıldız şeklinde."

msgid "Handle (Diamond)"
msgstr "Sap (Elmas)"

msgid "A white handle for a valve mechanism. The protrusion is diamond-shaped."
msgstr "Bir vana mekanizması için Beyaz bir sap. Çıkıntısı elmas şeklinde."

