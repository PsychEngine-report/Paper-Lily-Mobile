msgid "A list of things I want to do before I die."
msgstr "Ölmeden önce yapmak istediğim şeylerin bir listesi."

msgid "Red Ribbon"
msgstr "Kırmızı Kurdele"

msgid "A soft and silky red ribbon."
msgstr "Yumuşak ve ipeksi kırmızı kurdele"

msgid "Red Thread"
msgstr "Kırmızı İplik"

msgid "Some red thread from mother's sewing kit. The color matches my scarf."
msgstr "Annemin dikiş setinden biraz kırmızı iplik. Rengi atkımınkiyle eşleşiyor."

msgid "Red Shoelaces"
msgstr "Kırmızı Ayakkabı Bağcıkları"

msgid "From the shoe rack. Does something like this count?"
msgstr "Ayakkabı rafından. Böyle bir şey sayılır mı?"

msgid "Red Paint"
msgstr "Kırmızı Boya"

msgid "A can of red paint. It's dusty."
msgstr "Bir kutu kırmızı boya. Tozlu."

msgid "Bird Food"
msgstr "Kuş Yemi"

msgid "All-Natural Non-GMO Certified Organic Bird Food. It's as expensive as it sounds."
msgstr "Tamamen Doğal GDO'suz Sertifikalı Organik Kuş Yemi. Kulağa geldiği kadar pahalı."

msgid "Red Marker"
msgstr "Kırmızı Kalem"

msgid "A non-erasable alcohol-based red marker."
msgstr "Silinmeyen alkol bazlı kırmızı kalem."

msgid "Lipstick"
msgstr "Ruj"

msgid "Some red lipstick from mother's makeup set. It says \"Crimson Passion\"."
msgstr "Annemin makyaj setinden kırmızı ruj. Üzerinde \"Kızıl Tutku\" yazıyor."

msgctxt "items.name.ch1.ritual_instructions"
msgid "Ritual Letter"
msgstr "Ritüel Mektubu"

msgctxt "items.desc.ch1.ritual_instructions"
msgid "The ritual instructions I received."
msgstr "Aldığım ritüel talimatları."

msgctxt "items.name.ch1.ritual_instructions_hidden"
