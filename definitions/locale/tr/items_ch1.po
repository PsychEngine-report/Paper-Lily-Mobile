msgid "Table Salt"
msgstr "Sofra Tuzu"

msgid "\"For cooking and baking\". Salt can supposedly ward off spirits and such."
msgstr "\"Pişirme ve fırınlama için\". Tuzun ruhları ve benzerlerini uzak tuttuğuna inanılır."

msgid "Notebook"
msgstr "Not Defteri"

msgid "I keep my personal notes and papers I find here."
msgstr "Burada bulduğum kişisel notlarımı ve evraklarımı saklıyorum."

msgctxt "items.name.ch1.rune_jara"
msgid "Rune"
msgstr "Rün"

msgid "A rune stone I bought from a shady online merchant."
msgstr "Şüpheli bir çevrimiçi satıcıdan satın aldığım bir rün taşı."

