msgstr "_____"

msgid "It's sharp."
msgstr "Keskin."

msgid "Iron Key"
msgstr "Demir Anahtar."

msgid "A fairly large metallic key."
msgstr "Oldukça geniş metal bir anahtar."

msgid "Copper Key"
msgstr "Bakır Anahtar"

msgid "A regular key. It probably opens a door somewhere."
msgstr "Sıradan bir anahtar. Muhtemelen bir yerde bir kapıyı açıyordur."

msgid "Bucket"
msgstr "Kova"

msgid "A metallic bucket. It can transport various liquid substances."
msgstr "Metal bir kova. Bir çok türde sıvıyı çaşıyabilir."

msgid "Bucket of Water"
msgstr "Su Kovası"

msgid "A bucket full of water. It's heavy."
msgstr "İçi su dolu bir kova. Ağır."

msgid "Bucket of Special Water"
msgstr "Özel Su Dolu Kova"

msgid "A bucket full of water. It comes from a special faucet in the forest."
msgstr "İçi su dolu bir kova, Ormandaki özel bir musluktan geliyor."

msgid "Flat Screwdriver"
msgstr "Düz Tornavida"

msgid "A simple screwdriver."
msgstr "Sıradan bir tornavida."

msgid "Coin"
msgstr "Para"

msgid "A coin that's not quite like the ones back home."
msgstr "Evimdekilere benzemeyen bir para."

msgid "Return Doorknob"
msgstr "Dönüş Kapı Kolu"

msgid "Apparently, this is my ticket back home. I purchased it online."
msgstr "Görünüşe göre bu evime dönüşümün bileti. Bunu internetten aldım."

msgid "Doorknob With Flower"
msgstr "Çiçekli Kapı Kolu"

msgid "A doorknob. I found this lying around."
msgstr "Bir kapı kolu. Yerde buldum."

msgctxt "items.name.ch1.doorknob_library_fragment"
msgid "Doorknob Fragment"
msgstr "Kapı Kolu Parçası"

msgctxt "items.desc.ch1.doorknob_library_fragment"
msgid "Pieces of a doorknob. I can't put them back together on my own."
msgstr "Kapı kolu parçaları. Kendi başıma bunları birleştiremem."

msgid "Gray Doorknob"
msgstr "Gri Kapı Kolu"

msgid "A doorknob. It has the same symbol as my letter."
msgstr "Bir kapı kolu. Üzerinde mektubumdakiyle aynı sembol var."

msgid "White Doorknob"
msgstr "Beyaz Kapı Kolu"

msgid "A doorknob. It looks like a white lily."
msgstr "Bir kapı kolu. Beyaz bir zambak gibi görünüyor."

msgid "Doorknob With Eye"
msgstr "Gözlü Kapı Kolu"

msgid "A doorknob I got from the moths. Can probably be used at that door with the slots."
msgstr "Güvelerden aldığım bir kapı kolu. Muhtemelen boş yuvaları olan o kapıda kullanılabilir."

msgctxt "items.name.ch1.doorknob_lighthouse_fragment"
msgid "Doorknob Fragment"
msgstr "Kapı Kolu Parçası"

msgctxt "items.desc.ch1.doorknob_lighthouse_fragment"
msgid "Pieces of a doorknob. I can't put them back together on my own."
msgstr "Kapı kolu parçaları. Kendi başıma bunları birleştiremem."

msgid "Paper Lily Folding Steps"
msgstr "Kağıt Zambak Katlama Adımları"

msgid "Instructions detailing how to fold a piece of paper to look like a lily flower."
msgstr "Kağıdı katlayarak beyaz zambağa nasıl benzetebileceğini detaylıca anlatan talimatlar."

msgid "Facility Map"
msgstr "Tesis Haritası"

msgid "A map of the facility, drawn by someone."
msgstr "Tesisin birisi tarafından çizilmiş haritası."

msgid "Black Knife"
msgstr "Siyah Bıçak"

msgid "A fully black knife. It's still very sharp."
msgstr "Tamamen siyah bir bıçak. Hala çok keskin."

msgid "Knife"
msgstr "Bıçak"

msgid "A knife."
msgstr "Bir bıçak."

msgid "Human Foot"
msgstr "İnsan Ayağı"

msgid "A foot that used to belong to someone."
msgstr "Eskiden birine ait olan bir ayak."

msgid "Sketchbook"
msgstr "Eskiz Defteri"

msgid "A sketchbook full of colors you splattered all over it."
msgstr "Üzerine sıçrattığın renklerle dolu bir eskiz defteri."

msgctxt "items.name.ch1.mk_hand_mirror"
msgid "Black Object"
msgstr "Siyah Nesne"

msgid "An unknown circular object that's fully black. Feels like wood and glass."
msgstr "Tamamen siyah olan bilinmeyen dairesel bir nesne. Ahşap ve cam gibi hissettiriyor."

msgid "Hand Mirror"
msgstr "El Aynası"

msgid "A wooden hand mirror."
msgstr "Tahta bir el aynası."

msgctxt "items.name.ch1.mk_compress"
msgid "Black Object"
msgstr "Siyah Nesne"

msgid "An unknown object that's fully black. Feels like a piece of fabric."
msgstr "Tamamen siyah olan bilinmeyen bir nesne. Bir parça kumaş gibi hissettiriyor."

msgid "Cold Compress"
msgstr "Soğuk kompres"

msgid "A wet rag."
msgstr "Islak bir bez."

msgid "Eyeball"
msgstr "Göz Küresi"

msgid "An eyeball. The owner seems to have had golden eyes."
msgstr "Bir göz küresi. Sahibinin altın gözleri varmış gibi görünüyor."

msgid "Small Key"
msgstr "Küçük Anahtar"

msgid "A small key. Looks like it could belong to a padlock or something similar."
msgstr "Küçük bir anahtar. Bir asma kilide veya buna benzer bir şeye ait olabilir gibi görünüyor."

msgctxt "items.name.ch1.mk_bedroom_key"
msgid "Key"
msgstr "Anahtar"

msgctxt "items.desc.ch1.mk_bedroom_key"
msgid "A key for something."
msgstr "Bir şeyin anahtarı."

msgctxt "items.name.ch1.mk_key_wisteria"
msgid "Key"
msgstr "Anahtar"

msgctxt "items.desc.ch1.mk_key_wisteria"
msgid "A key for something."
msgstr "Bir şeyin anahtarı."

