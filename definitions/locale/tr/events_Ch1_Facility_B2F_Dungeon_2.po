msgid "A broken, bloody baseball bat lies next to a skeleton."
msgstr "Kırılmış ve kanla kaplı bir beyzbol sopası iskeletin yanında duruyor."

msgid "A \"W\" is carved into it."
msgstr "\"W\" harfi işlenmiş"

msgid "The door is unreachable."
msgstr "Kapıya ulaşılamıyor."

msgid "\"Subject D5. Age: 100-150. Status: Dormant. Awaiting further tests.\""
msgstr "\"Denek D5. Yaş: 100-150. Durum: Uykuda. Gelecekteki testler bekleniyor.\""

msgid "\"Subject D8. Age: Unknown. Status: Highly active. Awaiting further tests.\""
msgstr "\"Denek D8. Yaş: Bilinmiyor. Durum: yüksek derecede aktif. Gelecekteki testleri bekleniyor.\""

