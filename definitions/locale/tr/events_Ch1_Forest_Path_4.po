msgctxt "events.Ch1_Forest_Path_4.misc_tree.dlg.narrator"
msgid "A red tree."
msgstr "Kırmızı bir ağaç."

msgid "It stands out..."
msgstr "Öylece duruyor..."

msgid "Is there anything special about it?"
msgstr "Onda özel bir şey var mı?"

msgctxt "events.Ch1_Forest_Path_4.misc_tree_behind.dlg.narrator"
msgid "A red tree."
msgstr "Kırmızı bir ağaç."

msgid "Hmm? There's a paper with something stuck to it."
msgstr "Hmm? Orada sıkışmış bir kağıt var."

msgid "Take ${item:ch1.forest_lockedsite_key}?"
msgstr "${item:ch1.forest_lockedsite_key} Al?"

msgid "Yes"
msgstr "Evet"

msgid "No"
msgstr "Hayır"

msgid "(You don't need that key, so it was discarded.)"
msgstr "(Anahtara ihtiyacın yok, bu yüzden bir kenara atıldı.)"

msgid "There's also a note taped to the tree."
msgstr "Ağaçta aynı zamanda bantlanmış bir not var."
