msgid "(You discarded the extra eye.)"
msgstr "(Fazladan gözü attın.)"

msgid "Enter the painting?"
msgstr "Resme girilsin mi?"

msgid "Yes"
msgstr "Evet"

msgid "No"
msgstr "Hayır"

msgid "A large painting. It seems to be missing both eyes."
msgstr "Büyük bir tablo. İki gözü de eksik gibi görünüyor."

msgid "A spooky painting. It seems to be missing an eye."
msgstr "Ürpertici bir tablo. Tek gözü eksik gibi görünüyor."

msgid "One eye is plenty."
msgstr "Tek göz yeter de artar."

msgid "..."
msgstr "..."
