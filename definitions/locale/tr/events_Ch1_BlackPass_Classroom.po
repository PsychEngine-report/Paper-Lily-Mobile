msgid "Stab self"
msgstr "Kendini bıçakla."

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.choice...."
msgid "Do not"
msgstr "Yapma"

msgid "(This dream...)"
msgstr "(Bu bir rüya...)"

msgid "(The easiest way to get out...)"
msgstr "(Çıkmanın en kolay yolu...)"

msgid "(It's obvious, isn't it?)"
msgstr "(Yeterince açık,değil mi?)"

msgid "...Ah! It hurts! ...it hurts..."
msgstr "...Ah! Acıyor!...acıyor..."

msgid "...When am I waking up..."
msgstr "Ne zaman uyanacağım..."

msgid "...Let this stupid... nightmare... end..."
msgstr "İzin verin bu...aptal kabus...bitsin..."

msgid "...Why..."
msgstr "...Neden..."

msgid "...It's just a dream... so why..."
msgstr "Bu sadece bir rüyayasa...O zaman neden..."

msgid "...It hurts..."
msgstr "...Neden acıyor..."

msgctxt "events.Ch1_BlackPass_Classroom.misc_desk.choice...."
msgid "Eat the bird"
msgstr "Kuşu ye"

msgid "Do nothing"
msgstr "Hiçbir şey yapma"

msgid "There's nothing else to do here."
msgstr "Burda yapılacak başka bir şey yok."

msgctxt "events.Ch1_BlackPass_Classroom.misc_person_left.dlg.unknown"
msgid "Eat it, witch."
msgstr "Ye şunu,cadoloz."

msgid "Sorry, I can't let you pass."
msgstr "Üzgünüm,geçmene izin veremem."

msgid "Please?"
msgstr "Lütfen?"

msgid "Just do what they say."
msgstr "Sadece ne söylüyorlarsa onu yap."

msgid "(A strong force prevents you from entering the wardrobe.)"
msgstr "(Bir güç gardıroba girmeni engelliyor.)"

msgid "(Push through?)"
msgstr "(Zorla geçilsin mi?)"

