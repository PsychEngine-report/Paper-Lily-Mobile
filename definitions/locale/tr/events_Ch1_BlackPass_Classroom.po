msgid "Hey, where do you think you're going?"
msgstr "Pişt,nereye gittiğini sanıyorsun?"

msgctxt "events.Ch1_BlackPass_Classroom.event_bouncer.dlg.lacie"
msgid "..."
msgstr "..."

msgctxt "events.Ch1_BlackPass_Classroom.event_cutscene.dlg.lacie"
msgid "..."
msgstr "..."

msgid "There she is."
msgstr "İşte orada."

msgid "That's her?"
msgstr "Bu o mu?"

msgid "She's so cursed that the bird dropped dead."
msgstr "O kadar lanetli ki kuş öldü."

msgid "If she can make a bird die, I wonder what she could do to people."
msgstr "Eğer bir kuşu öldürebiliyorsa, insanlara kim bilir ne yapar."

msgid "What a freak."
msgstr "Ucube."

msgid "Hey, you killed that poor bird."
msgstr "Baksana, o zavallı kuşu öldürdün."

msgid "...N-no..."
msgstr "...H-hayır..."

msgid "It flew into the window next to YOUR seat."
msgstr "SİZİN koltuğunuzun yanındaki pencereden uçtu."

msgid "...but.. I didn't..."
msgstr "...ama... yapmadım..."

msgid "It died because of you."
msgstr "Senin yüzünden öldü."

msgid "This is your fault."
msgstr "Bu senin suçun."

msgid "Aargh!"
msgstr "Aaağğhh!"

msgid "........"
msgstr "..."

msgid "What the hell!?"
msgstr "Bu da ne!?"

msgid "Did she kill him?"
msgstr "Onu öldürdü mü?"

msgid "Is he dead?"
msgstr "Öldü mü?"

msgctxt "events.Ch1_BlackPass_Classroom.item_knife_on_person_left.dlg.unknown"
msgid "MURDERER!"
msgstr "KATİL!"

msgctxt "events.Ch1_BlackPass_Classroom.item_knife_on_person_left.dlg.unknown"
msgid "MURDERER! MURDERER! MURDERER!"
msgstr "KATİL! KATİL! KATİL!"

msgctxt "events.Ch1_BlackPass_Classroom.item_knife_on_person_left.dlg.lacie"
msgid "....."
msgstr "....."

msgid "Wait... what are you doing!?"
msgstr "Bekle...ne yapıyorsun"

msgid "I'm doing something, unlike you."
msgstr "Senin aksine bir şeyler yapıyorum."

msgid "AAAAH!"
msgstr "AAAHH!"

msgid "She killed him!"
msgstr "Onu öldürdü!"

msgid "Oh my god! She's crazy!"
msgstr "Allahım Yarabbim!Manyağın teki!"

msgctxt "events.Ch1_BlackPass_Classroom.item_knife_on_person_right.dlg.unknown"
msgid "MURDERER!"
msgstr "KATİL!"

