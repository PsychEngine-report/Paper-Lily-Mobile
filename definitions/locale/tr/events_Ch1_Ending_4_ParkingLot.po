msgid "What seems like a trash bag."
msgstr "Çöp poşeti gibi gözüküyor."

msgid "It has dust all over."
msgstr "Her yeri tozla kaplı."

msgid "A wooden crate."
msgstr "Ahşap bir sandık."

msgid "A bus. It doesn't seem to have been used in a long time."
msgstr "Bir otobüs.Uzun zamandır kullanılmış gibi gözükmüyor."

msgid "There's another bus stacked on top of it."
msgstr "Kendi üstüne yığılmış başka bir otobüs daha."

msgid "A broken bus is stacked on top of it."
msgstr "Kendi üstüne yığılmış bozuk bir otobüs. "

msgid "A keypad."
msgstr "Bir klavye."

msgid "It doesn't seem to be working."
msgstr "Çalışıyomuş gibi gözükmüyor."

msgid "Touch some buttons?"
msgstr "Bazı düğmelere dokun?"

msgid "Yes"
msgstr "Evet"

msgid "No"
msgstr "Hayır"

msgid "The keypad does not respond in any way."
msgstr "Klayve hiçbir şekilde yanıt vermiyor."

msgid "Looks like a mailbox."
msgstr "Posta kutusu gibi gözüküyor."

msgid "There's no mail right now."
msgstr "Orada şuan posta yok."

msgid "A small light. It changes colors every few seconds."
msgstr "Küçük bir ışık. Her saniye rengi değişiyor."

msgid "Strange street signs fill the walls."
msgstr "Garip sokak işaretleri duvarı kaplıyor."

msgid "A garage door."
msgstr "Bir garaj kapısı."

msgid "Can I get this open somehow?"
msgstr "Acaba bunu bir şekilde açabilir miyim?"
