msgid "The key fits!"
msgstr "Anahtar uyuyor!"

msgid "You don't know how to use it..."
msgstr "Nasıl kullanılacağını bilmiyorsun..."

msgid "A portrait of a person with a brain for a head."
msgstr "Kafasının yerinde beyin olan birinin portresi."

msgid "A portrait of a scary-looking person."
msgstr "Korkunç görünen birinin portresi."

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_10.dlg.lacie"
msgid "..."
msgstr "..."

msgid "A portrait of a person with a gaping mouth."
msgstr "Ağzı açık birinin portresi."

msgid "...I don't like this one."
msgstr "...Bunu beğenmedim."

msgid "His head looks like a spoon."
msgstr "Kafası kaşığa benziyor."

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_11.dlg.lacie"
msgid "..."
msgstr "..."

msgid "A portrait of a pretty-looking lady."
msgstr "Güzel bir kadının portresi."

msgid "She looks like she's made of porcelain."
msgstr "Sanki porselenden yapılma bir kadın gibi duruyor."

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_13.dlg.narrator"
msgid "A portrait of a person with an animal skull for a head."
msgstr "Kafasının yerirne hayvan kafatası olan birinin portresi."

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_14.dlg.narrator"
msgid "A portrait of a person with an animal skull for a head."
msgstr "Kafasının yerine hayvan kafatası olan birinin portresi."

msgid "A portrait of a person with many eyes."
msgstr "Bir sürü gözü olan birinin portresi."

msgid "Various strange portraits adorn the walls."
msgstr "Duvarlar değişik portrelerle dolu."

msgid "A portrait of a girl with horns growing out of her face."
msgstr "Yüzünden boynuzlar çıkan bir kızın portresi."

msgid "A portrait of a grandma."
msgstr "Yaşlı bir kadının portresi."

msgid "She looks nice... Maybe."
msgstr "Hoş görünüyor...Sanırım."

msgid "A portrait of a person with knifes floating above their head."
msgstr "Kafasının üzerinden bıçaklar uçuşan birinin portresi."

msgid "A portrait of a person with a heart for a head."
msgstr "Kafasının yerine kalp olan birinin portresi."

msgid "A portrait of a person with a crow for a head."
msgstr "Kafasının yerine karga olan birinin portresi."

msgid "It looks nothing like those cute crows I've been seeing around."
msgstr "Gördüğüm diğer tatlış kargalara hiç de benzemiyor."

msgid "A portrait of a happy-looking girl."
msgstr "Mutlu gözüken bir kızın portresi."

msgid "A portrait of a person with a goat for a head."
msgstr "Kafasının yerine keçi olan birinin portresi."

msgid "Creepy portraits adorn the walls."
msgstr "Duvar ürpertici portrelerle dolu."

msgid "A painting that's mostly just red."
msgstr "Biraz fazla kırmızı bir tablo."

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_red.choice"
msgid "Touch it?"
msgstr "Dokunulsun mu?"

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_red.choice.Touch it?"
msgid "Yes"
msgstr "Evet"

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_red.choice.Touch it?"
msgid "No"
msgstr "Hayır"

msgid "A bunch of red powder sticks to your finger."
msgstr "Eline biraz kırmızı toz bulaştı."

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_red.dlg.narrator"
msgid "It should be easy to scrap off and collect more, as long as you have something to carry it with."
msgstr "Yanında taşıyabileceğin bir şey varken parçalara ayırıp taşımak kolay olmalı."

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_red.dlg.narrator"
msgid "(You wipe it off.)"
msgstr "(Sildin.)"

msgid "A painting that's mostly just yellow."
msgstr "Biraz fazla sarı bir resim."

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_yellow.choice"
msgid "Touch it?"
msgstr "Dokunulsun mu?"

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_yellow.choice.Touch it?"
msgid "Yes"
msgstr "Evet"

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_yellow.choice.Touch it?"
msgid "No"
msgstr "Hayır"

msgid "A bunch of yellow powder sticks to your finger."
msgstr "Parmağına biraz sarı toz bulaştı."

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_yellow.dlg.narrator"
msgid "It should be easy to scrap off and collect more, as long as you have something to carry it with."
msgstr "Yanında taşıyabileceğin bir şey varken parçalara ayırıp taşımak kolay olmalı."

msgctxt "events.Ch1_MK_B2F_Hallway.misc_painting_yellow.dlg.narrator"
msgid "(You wipe it off.)"
msgstr "(Sildin.)"
